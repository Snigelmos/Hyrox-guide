---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import {
  CATEGORIES,
  AGE_GROUPS,
  computeExpectedFinish,
  formatHMS,
  CATEGORY_GUIDANCE,
} from "../../../data/hyrox-times";

export async function getStaticPaths() {
  return CATEGORIES.map((cat) => ({
    params: { category: cat.slug },
    props: { category: cat.slug },
  }));
}

const { category } = Astro.props;
const cat = CATEGORIES.find((c) => c.id === category)!;
const guidance = CATEGORY_GUIDANCE[category];

const title = `${cat.label} Hyrox Finish Times by Age Group`;
const description = `Expected Hyrox finish times for ${cat.label} across every age group, with splits and pacing targets. ${cat.description}`;

const faqItems = guidance.faqs;
---

<BaseLayout
  title={`${title} | Hyrox Guide`}
  description={description}
  ogType="article"
  schemaType="Article"
  breadcrumbs={[
    { name: "Race Times", url: "/times/" },
    { name: cat.label },
  ]}
  faqItems={faqItems}
>
  <div class="container-main py-10 md:py-16">
    <nav class="mb-8 text-sm" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 flex-wrap">
        <li><a href="/" class="text-text-muted hover:text-accent transition-colors no-underline">Home</a></li>
        <li class="flex items-center gap-2">
          <span class="text-text-muted/40">/</span>
          <a href="/times/" class="text-text-muted hover:text-accent transition-colors no-underline">Times</a>
        </li>
        <li class="flex items-center gap-2">
          <span class="text-text-muted/40">/</span>
          <span class="text-text">{cat.label}</span>
        </li>
      </ol>
    </nav>

    <header class="mb-10 pb-8 border-b border-border">
      <h1 class="text-4xl md:text-5xl font-black leading-tight text-gradient-accent">
        {title}
      </h1>
      <p class="mt-4 text-lg text-text-muted leading-relaxed max-w-2xl">
        {cat.description}
      </p>
    </header>

    <section class="mb-10 max-w-3xl">
      <h2 class="text-2xl md:text-3xl font-black mb-3">{cat.label}: what this division means</h2>
      <p class="text-text-muted leading-relaxed">{guidance.divisionContext}</p>
    </section>

    <section class="mb-10 max-w-3xl">
      <h2 class="text-2xl md:text-3xl font-black mb-3">Training reality for {cat.label}</h2>
      <p class="text-text-muted leading-relaxed">{guidance.trainingReality}</p>
    </section>

    <section class="mb-4 max-w-3xl">
      <h2 class="text-2xl md:text-3xl font-black mb-3">Average {cat.label} finish times by age group</h2>
      <p class="text-text-muted leading-relaxed">
        Pick your age group below for per-station splits, the pacing plan, and the unique training adjustments at that age band. The figures below are aggregated medians from publicly reported 2024-2025 race results.
      </p>
    </section>

    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mt-6">
      {AGE_GROUPS.map((age) => {
        const finish = computeExpectedFinish(cat.id, age.id);
        const podium = Math.round(finish.totalSeconds * 0.82);
        return (
          <a
            href={`/times/${cat.slug}/${age.slug}/`}
            class="block bg-bg-card border border-border rounded-xl p-5 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline"
          >
            <div class="text-xs font-bold uppercase tracking-wider text-accent mb-1">{cat.label} · Age {age.label}</div>
            <div class="text-2xl font-black text-text-heading tabular-nums">{formatHMS(finish.totalSeconds)}</div>
            <div class="text-xs text-text-muted mt-1">Average. Podium under {formatHMS(podium)}.</div>
          </a>
        );
      })}
    </div>

    <section class="mt-12 max-w-3xl">
      <h2 class="text-2xl md:text-3xl font-black mb-3">Race strategy for {cat.label}</h2>
      <p class="text-text-muted leading-relaxed">{guidance.raceStrategy}</p>
    </section>

    <aside class="mt-16 pt-10 border-t border-border">
      <h2 class="text-2xl font-black text-text-heading mb-4">Compare other divisions</h2>
      <div class="grid gap-3 grid-cols-2 md:grid-cols-3 not-prose">
        {CATEGORIES.filter((c) => c.id !== cat.id).map((c) => (
          <a
            href={`/times/${c.slug}/`}
            class="block bg-bg-card border border-border rounded-xl p-4 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline"
          >
            <div class="text-xs font-bold uppercase tracking-wider text-accent mb-1">{c.label}</div>
            <div class="text-sm text-text-muted">{c.description}</div>
          </a>
        ))}
      </div>
    </aside>
  </div>
</BaseLayout>
