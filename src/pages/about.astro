---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE_SOCIALS } from "../data/socials";
import { AUTHORS } from "../data/authors";

const lastUpdated = "May 9, 2026";
const team = AUTHORS[0];

const organizationLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "HyroxVault",
  url: "https://www.hyroxvault.com",
  logo: "https://www.hyroxvault.com/og-default.png",
  description:
    "Independent editorial site covering Hyrox racing, training, gear and supplements. Written anonymously by an editorial team of three Hyrox racers.",
  foundingDate: "2026",
  publishingPrinciples: "https://www.hyroxvault.com/methodology/",
  ethicsPolicy: "https://www.hyroxvault.com/methodology/",
};

if (SITE_SOCIALS.length > 0) {
  organizationLd.sameAs = SITE_SOCIALS;
}
---

<BaseLayout
  title="About HyroxVault | Editorial Team, Standards & Disclosure"
  description="Who writes HyroxVault, why we publish anonymously, our editorial standards, affiliate disclosure, and how to reach us with corrections."
  breadcrumbs={[{ name: "About", url: "/about/" }]}
>
  <section class="container-main py-16">
    <div class="max-w-3xl mx-auto">
      <p class="text-sm text-text-muted mb-4">Last updated: {lastUpdated}</p>

      <h1 class="text-4xl md:text-5xl font-black mb-6">
        <span class="text-gradient-accent">About HyroxVault</span>
      </h1>

      <div class="prose prose-lg prose-invert max-w-none">
        <p class="text-xl text-text-muted leading-relaxed">
          HyroxVault is an independent, editorially-driven resource for Hyrox
          athletes. It's written by three Hyrox racers publishing anonymously
          under a single editorial-team byline. We don't put names or faces on
          the work because we want every recommendation to stand on the
          evidence behind it, not on personal brand.
        </p>

        <h2 id="team">The team</h2>
        <p>
          Three of us, racing on the European Hyrox circuit. Between us we
          cover the full breadth of the sport:
        </p>
        <ul>
          <li><strong>Strength &amp; stations</strong> — sled push, sled pull, wall balls, sandbag lunges, burpee broad jumps, farmers carry, technique deep-dives, and gym-based programming.</li>
          <li><strong>Running</strong> — pacing, Zone 2, VO2max, heart-rate zones, watch and HRM setup, and every guide written for runners crossing into Hyrox.</li>
          <li><strong>Racing &amp; nutrition</strong> — race-day execution, race-week protocol, sub-X blueprints, doubles, the Roxzone, fuelling, hydration, and supplement coverage.</li>
        </ul>

        <h2 id="why-anonymous">Why we publish anonymously</h2>
        <p>
          A lot of fitness content on the open web leans on personal brand:
          photos, bios, performance claims, social profiles. We've chosen the
          opposite path. The recommendations on this site should hold up
          because the evidence behind them holds up — not because of who's
          signing the byline. Anonymous, but not unaccountable: corrections go
          through the same person regardless of which side of the site is
          affected.
        </p>

        <div class="not-prose my-8">
          <a
            href={`/author/${team.slug}/`}
            class="block bg-bg-card border border-border rounded-2xl p-5 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline"
          >
            <div class="flex items-center gap-4">
              <img
                src={team.image}
                alt=""
                width="56"
                height="56"
                loading="lazy"
                class="w-14 h-14 rounded-2xl object-contain bg-bg border border-border p-1.5 flex-shrink-0"
              />
              <div>
                <div class="text-base font-bold text-text-heading mb-0.5">
                  {team.name}
                </div>
                <div class="text-sm text-text-muted">
                  See every guide bylined to the team and our published editorial standards →
                </div>
              </div>
            </div>
          </a>
        </div>

        <h2>Independent, not affiliated with Hyrox GmbH</h2>
        <p>
          HyroxVault is an independent publication. We are not owned by, paid
          by, or officially connected to Hyrox GmbH or any of its partners.
          "Hyrox" and related marks are trademarks of their respective owners
          and are used here only to identify the sport and its events. We
          cover the race because we race it, not because anyone is paying us
          to.
        </p>

        <h2>How we pick products</h2>
        <p>
          We cover four product categories: <strong>supplements, running
          shoes, training gear, and race-day accessories</strong>. The
          evaluation criteria are:
        </p>
        <ul>
          <li>
            <strong>Published research.</strong> For supplements we rely on
            meta-analyses and position statements from the ISSN, ACSM, and
            IOC, not brand marketing.
          </li>
          <li>
            <strong>Third-party certification.</strong> Where it applies, we
            highlight products with NSF Certified for Sport or Informed Sport
            testing.
          </li>
          <li>
            <strong>Specifications versus race demands.</strong> Shoes,
            watches, HRMs, race bags and similar gear are evaluated against
            the published evidence on running mechanics, indoor traction,
            durability, and the specific load profile of a Hyrox race.
          </li>
          <li>
            <strong>Community consensus.</strong> What experienced age-group
            and Pro athletes are actually using, and what is widely reviewed
            well outside HyroxVault.
          </li>
          <li>
            <strong>Value.</strong> We highlight options that work for a
            normal working athlete, not just the most expensive product.
          </li>
        </ul>
        <p>
          Where we call something an "Editor's Pick" or "Best Value", that
          reflects our read of the available evidence and public reviews — not
          a certification, a sponsorship, or a fabricated lab-test result. The
          full editorial standards are documented on the
          <a href="/methodology/">methodology page</a>.
        </p>

        <h2>How we use sources</h2>
        <p>
          Any precise number on the site — race split, station weight,
          supplement dose, heart-rate zone — has to come from one of three
          places: the official Hyrox rules and results data on
          <a href="https://hyrox.com/rules/" rel="nofollow noopener" target="_blank">hyrox.com</a> and
          <a href="https://results.hyrox.com/" rel="nofollow noopener" target="_blank">results.hyrox.com</a>,
          a peer-reviewed paper or position stand from the ISSN, ACSM, or
          IOC, or our own logged training and racing. If a number cannot be
          tied to one of those, we either remove it or hedge the language.
        </p>

        <h2>Editorial independence</h2>
        <p>
          We do not accept paid placements, sponsored rankings, or
          "pay-to-play" inclusion in our buying guides. Where a brand
          relationship exists it is disclosed, and it does not determine which
          products we recommend.
        </p>

        <h2>Affiliate disclosure</h2>
        <p>
          HyroxVault may earn commissions when readers buy through some of
          our outbound links. Buy links currently point to Amazon via the
          Amazon Associates program. Commissions are paid by Amazon at no
          extra cost to you and do not influence which products are featured.
        </p>
        <p>
          Affiliate links are marked with <code>rel="nofollow sponsored"</code>
          and, where product cards appear, a small disclosure notice nearby.
        </p>

        <h2>Corrections and fact-checking</h2>
        <p>
          Every factual claim — race distances, station standards, product
          specs, commission rates, supplement dosages — is checked against
          primary sources before publishing. Material corrections are logged
          at the bottom of the affected article with a date and a one-line
          description.
        </p>

        <h2>Medical disclaimer</h2>
        <p>
          Training and supplementation advice on HyroxVault is general
          information, not personalised medical guidance. Hyrox is a
          demanding race. If you have an underlying health condition, are
          pregnant, or are taking prescribed medication, speak with a
          qualified healthcare professional before starting a new training
          programme or supplement protocol.
        </p>

        <h2>What we cover</h2>
        <ul>
          <li><strong>Strength &amp; stations</strong> — sled push, sled pull, wall balls, sandbag lunges, burpee broad jumps, farmers carry, technique deep-dives, and gym-based programming.</li>
          <li><strong>Running</strong> — pacing, Zone 2, VO2max, heart-rate zones, watch and HRM setup, and every guide written for runners crossing into Hyrox.</li>
          <li><strong>Racing &amp; format</strong> — race-day execution, race-week protocol, sub-X blueprints, doubles, the Roxzone, population-specific guides, and pacing strategy.</li>
          <li><strong>Nutrition &amp; supplements</strong> — creatine, protein, gels, pre-workout, electrolytes, carb loading, hydration, and post-race recovery.</li>
          <li><strong>Gear reviews</strong> — shoes, clothing, compression, belts, bags, watches, and home-gym equipment.</li>
          <li><strong>Training plans</strong> — beginner, intermediate, advanced and doubles programmes with week-by-week structure.</li>
          <li><strong>Competitions</strong> — upcoming races, sign-up links, and city guides.</li>
          <li><strong>Blog</strong> — race recaps, training notes, deep-dives on technique and strategy.</li>
        </ul>

        <h2>Get in touch</h2>
        <p>
          Spotted a factual error, an out-of-date station weight, or a study
          we should be citing? We'll be adding a public contact mailbox here
          once it's live. In the meantime, see our full editorial standards
          and correction policy on the
          <a href="/methodology/">methodology page</a>.
        </p>

      </div>
    </div>
  </section>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(organizationLd)} />
</BaseLayout>
