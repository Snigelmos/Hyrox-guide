---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE_SOCIALS } from "../data/socials";
import { AUTHORS } from "../data/authors";

const lastUpdated = "May 3, 2026";

const organizationLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "HyroxVault",
  url: "https://www.hyroxvault.com",
  logo: "https://www.hyroxvault.com/og-default.png",
  description:
    "Independent editorial site covering Hyrox racing, training, gear and supplements.",
  foundingDate: "2026",
  publishingPrinciples: "https://www.hyroxvault.com/about/",
  ethicsPolicy: "https://www.hyroxvault.com/about/",
  diversityPolicy: "https://www.hyroxvault.com/about/",
};

if (SITE_SOCIALS.length > 0) {
  organizationLd.sameAs = SITE_SOCIALS;
}
---

<BaseLayout
  title="About HyroxVault | The Team, Review Process & Disclosure"
  description="Who writes HyroxVault, how we test products, our editorial and correction policies, and full affiliate disclosure."
  breadcrumbs={[{ name: "About", url: "/about/" }]}
>
  <section class="container-main py-16">
    <div class="max-w-3xl mx-auto">
      <p class="text-sm text-text-muted mb-4">Last updated: {lastUpdated}</p>

      <h1 class="text-4xl md:text-5xl font-black mb-6">
        <span class="text-gradient-accent">About HyroxVault</span>
      </h1>

      <div class="prose prose-lg prose-invert max-w-none">
        <p class="text-xl text-text-muted leading-relaxed">
          HyroxVault is an independent, editorially-driven resource for Hyrox
          athletes. Three of us run it — Adam, James, and Max. We race, we
          coach, and we read the literature. Every guide is signed by one of us
          by name, and built from real training, testing, and competition data,
          not press releases.
        </p>

        <h2 id="team">The team</h2>
        <p>
          Three of us, all racing Hyrox on the European circuit. Each of us
          writes the side we actually train:
        </p>

        <div class="not-prose grid gap-4 md:grid-cols-3 my-8">
          {AUTHORS.map((a) => (
            <a
              href={`/author/${a.slug}/`}
              class="group flex flex-col bg-bg-card border border-border rounded-2xl p-5 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline"
            >
              <div class="flex items-center gap-3 mb-3">
                <img
                  src={a.image}
                  alt=""
                  width="48"
                  height="48"
                  loading="lazy"
                  class="w-12 h-12 rounded-full object-cover bg-bg border border-border"
                />
                <div>
                  <div class="text-base font-bold text-text-heading group-hover:text-accent transition-colors">
                    {a.name}
                  </div>
                  <div class="text-xs text-text-muted">{a.jobTitle}</div>
                </div>
              </div>
              <p class="text-xs text-text-muted leading-relaxed">{a.tagline}</p>
            </a>
          ))}
        </div>

        <p>
          Read the full bios on the <a href="/author/">team page</a>, or jump
          to <a href="/author/john/">Adam</a>, <a href="/author/niklas/">James</a>, or <a href="/author/jesper/">Max</a>.
        </p>

        <h2>Independent, not affiliated with Hyrox GmbH</h2>
        <p>
          HyroxVault is an independent publication. We are not owned by, paid
          by, or officially connected to Hyrox GmbH or any of its partners.
          "Hyrox" and related marks are trademarks of their respective owners
          and are used here only to identify the sport and its events. We
          cover the race because we race it, not because anyone is paying us
          to.
        </p>

        <h2>How we pick products</h2>
        <p>
          We cover four product categories: <strong>supplements, running
          shoes, training gear, and race-day accessories</strong>. Max owns
          this section. The evaluation criteria are:
        </p>
        <ul>
          <li>
            <strong>Published research.</strong> For supplements we rely on
            meta-analyses and position statements from the ISSN, ACSM, and
            IOC, not brand marketing.
          </li>
          <li>
            <strong>Third-party certification.</strong> Where it applies, we
            highlight products with NSF Certified for Sport or Informed Sport
            testing.
          </li>
          <li>
            <strong>Hands-on testing.</strong> Shoes, watches, HRMs, race bags
            and similar gear go through a fixed evaluation checklist before
            getting a recommendation.
          </li>
          <li>
            <strong>Community consensus.</strong> What experienced age-group
            and Pro athletes are actually using, and what is widely reviewed
            well outside HyroxVault.
          </li>
          <li>
            <strong>Value.</strong> We highlight options that work for a
            normal working athlete, not just the most expensive product.
          </li>
        </ul>
        <p>
          Where we call something an "Editor's Pick" or "Best Value", that
          reflects our read of the available evidence and public reviews — not
          a certification, and not a promise of outcome for any individual
          athlete.
        </p>

        <h2>How we use sources</h2>
        <p>
          Any precise number on the site — race split, station weight,
          supplement dose, heart-rate zone — has to come from one of three
          places: the official Hyrox rules and results data on
          <a href="https://hyrox.com/rules/" rel="nofollow noopener" target="_blank">hyrox.com</a> and
          <a href="https://results.hyrox.com/" rel="nofollow noopener" target="_blank">results.hyrox.com</a>,
          a peer-reviewed paper or position stand from the ISSN, ACSM, or
          IOC, or our own logged training and racing. If a number cannot be
          tied to one of those, we either remove it or hedge the language.
          Adam is the final editor on station and strength claims; James on
          running and pacing; Max on supplements and racing.
        </p>

        <h2>Editorial independence</h2>
        <p>
          We do not accept paid placements, sponsored rankings, or
          "pay-to-play" inclusion in our buying guides. Where a brand
          relationship exists it is disclosed, and it does not determine which
          products we recommend.
        </p>

        <h2>Affiliate disclosure</h2>
        <p>
          HyroxVault may earn commissions when readers buy through some of
          our outbound links. Depending on your country, these links may
          point to retailers such as Amazon, Gymgrossisten, Myprotein, iHerb,
          or direct brand stores. Commissions are paid by the retailer at no
          extra cost to you and do not influence which products are featured.
        </p>
        <p>
          Affiliate links are marked with <code>rel="nofollow sponsored"</code>
          and, where product cards appear, a small disclosure notice nearby.
        </p>

        <h2>Corrections and fact-checking</h2>
        <p>
          Every factual claim — race distances, station standards, product
          specs, commission rates, supplement dosages — is checked against
          primary sources before publishing. Material corrections are logged
          at the bottom of the affected article with a date and a one-line
          description. We do not yet run a public contact mailbox or form;
          one will be added here once it is live.
        </p>

        <h2>Medical disclaimer</h2>
        <p>
          Training and supplementation advice on HyroxVault is general
          information, not personalised medical guidance. Hyrox is a
          demanding race. If you have an underlying health condition, are
          pregnant, or are taking prescribed medication, speak with a
          qualified healthcare professional before starting a new training
          programme or supplement protocol.
        </p>

        <h2>What we cover</h2>
        <ul>
          <li><strong>Strength &amp; stations</strong> — sled push, sled pull, wall balls, sandbag lunges, burpee broad jumps, farmers carry, technique deep-dives, and gym-based programming. Owned by Adam.</li>
          <li><strong>Running</strong> — pacing, Zone 2, VO2max, heart-rate zones, watch and HRM setup, and every guide written for runners crossing into Hyrox. Owned by James.</li>
          <li><strong>Racing &amp; format</strong> — race-day execution, race-week protocol, sub-X blueprints, doubles, the Roxzone, population-specific guides, and pacing strategy. Owned by Max.</li>
          <li><strong>Nutrition &amp; supplements</strong> — creatine, protein, gels, pre-workout, electrolytes, carb loading, hydration, and post-race recovery. Owned by Max.</li>
          <li><strong>Gear reviews</strong> — shoes, clothing, compression, belts, bags, watches, and home-gym equipment. Strength-side gear (heavy-athlete shoes, belts, grip aids) sits with Adam; running watches and HRMs with James; everything else with Max.</li>
          <li><strong>Training plans</strong> — beginner, intermediate, advanced and doubles programmes with week-by-week structure. Running progression by James, strength sessions by Adam.</li>
          <li><strong>Competitions</strong> — upcoming races, sign-up links, and city guides.</li>
          <li><strong>Blog</strong> — race recaps, training notes, deep-dives on technique and strategy.</li>
        </ul>

      </div>
    </div>
  </section>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(organizationLd)} />
</BaseLayout>
