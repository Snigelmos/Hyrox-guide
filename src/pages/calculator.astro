---
import BaseLayout from "../layouts/BaseLayout.astro";
import HyroxCalculator from "../components/HyroxCalculator";
import {
  GOAL_TIME_CONFIGS,
  PRO_GOAL_TIME_CONFIGS,
  DOUBLES_GOAL_TIME_CONFIGS,
  ALL_GOAL_TIME_CONFIGS,
} from "../data/calculator-goals";

// Overview grid: keep one tile per 10-minute bucket on Open + Doubles so men
// and women rows are visually balanced. Pro stays on 5-minute steps so we
// keep the existing 7 men + 7 women guides. Cap Open / Doubles Women at the
// same end-tile their men's row reaches; longer slow-end pages still exist
// as URLs and via the "Jump to your goal time" search input below.
const menGoals       = GOAL_TIME_CONFIGS.filter((g) => g.audience === "open-men"     && g.goalSeconds % 600 === 0);
const womenGoals     = GOAL_TIME_CONFIGS.filter((g) => g.audience === "open-women"   && g.goalSeconds % 600 === 0 && g.goalSeconds <= 7200);
const proMenGoals    = PRO_GOAL_TIME_CONFIGS.filter((g) => g.audience === "pro-men");
const proWomenGoals  = PRO_GOAL_TIME_CONFIGS.filter((g) => g.audience === "pro-women");
const doublesMenGoals   = DOUBLES_GOAL_TIME_CONFIGS.filter((g) => g.audience === "doubles-men");
const doublesWomenGoals = DOUBLES_GOAL_TIME_CONFIGS.filter((g) => g.audience === "doubles-women");
---

<BaseLayout
  title="Hyrox Race Time Predictor — Predict Your Finish Time (2026)"
  description="Free Hyrox race time predictor. Enter your 5K pace, bench press, and deadlift — get a predicted finish time with full station splits for Open or Pro division."
>
  <section class="container-main py-12">

    <!-- Compact header -->
    <div class="mb-8">
      <nav class="mb-4 text-sm" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 flex-wrap">
          <li><a href="/" class="text-text-muted hover:text-accent transition-colors">Home</a></li>
          <li class="flex items-center gap-2"><span class="text-text-muted/40">/</span><span class="text-text">Race Time Predictor</span></li>
        </ol>
      </nav>
      <h1 class="text-3xl md:text-5xl font-black">
        <span class="text-gradient-accent">Race Time Predictor</span>
      </h1>
      <p class="text-base text-text-muted mt-2 max-w-xl">
        Enter your 5 km time, max bench press, and max deadlift — get a predicted Hyrox finish time with full station splits for Open or Pro division.
      </p>
    </div>

    <!-- Calculator first, immediately visible -->
    <HyroxCalculator client:only="react" />

    <div class="max-w-6xl mt-16 pt-10 border-t border-border">
      <h2 class="text-2xl md:text-3xl font-black text-text-heading mb-2">Goal-time split guides</h2>
      <p class="text-text-muted mb-6 max-w-2xl">
        Pick a target finish time and get a pre-built split breakdown — running pace required, station-by-station targets, and the training plan that builds the fitness.
      </p>

      {/* Find-your-guide input */}
      <div class="mb-8 bg-bg-card border border-border rounded-2xl p-5">
        <label class="block text-xs font-bold uppercase tracking-wider text-accent mb-2">
          Jump to your goal time
        </label>
        <div class="flex gap-3 items-center flex-wrap">
          <input
            id="goal-time-input"
            type="text"
            inputmode="numeric"
            placeholder="e.g. 1:28 or 88"
            class="bg-bg border border-border rounded-lg px-4 py-2.5 text-base text-text focus:outline-none focus:border-accent min-h-[44px] w-40"
          />
          <select
            id="goal-audience-input"
            class="bg-bg border border-border rounded-lg px-4 py-2.5 text-base text-text focus:outline-none focus:border-accent min-h-[44px]"
          >
            <option value="open-men">Open Men</option>
            <option value="open-women">Open Women</option>
            <option value="pro-men">Pro Men</option>
            <option value="pro-women">Pro Women</option>
            <option value="doubles-men">Doubles Men</option>
            <option value="doubles-women">Doubles Women</option>
          </select>
          <button
            id="goal-time-btn"
            class="bg-accent text-bg font-bold text-base px-5 py-2.5 rounded-lg hover:bg-accent-hover transition-colors min-h-[44px]"
          >
            Find my guide
          </button>
        </div>
        <p id="goal-time-error" class="text-xs text-red-400 mt-2 hidden">No matching guide found — try a time between 1:00 and 1:45.</p>
      </div>

      {/* ── Open Division ── */}
      <div class="mb-8 rounded-2xl border border-border overflow-hidden">
        <div class="bg-bg-card px-6 py-4 border-b border-border flex items-center gap-3">
          <span class="inline-block w-2.5 h-2.5 rounded-full bg-accent flex-shrink-0"></span>
          <div>
            <span class="text-sm font-black text-text-heading uppercase tracking-wide">Open Division</span>
            <span class="ml-3 text-xs text-text-muted">Standard station weights · all levels</span>
          </div>
        </div>

        {/* Open Men */}
        <div class="px-6 py-5 border-b border-border/50">
          <h3 class="text-xs font-bold uppercase tracking-wider text-accent mb-4 flex items-center gap-2">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            Men
          </h3>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 gap-3">
            {menGoals.map((g) => (
              <a
                href={`/calculator/${g.slug}/`}
                class="bg-bg border border-border rounded-xl p-4 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline group"
              >
                <div class="text-base font-black text-text-heading group-hover:text-accent transition-colors">{g.goalShort}</div>
                <div class="text-xs text-text-muted">{g.goalLabel}</div>
              </a>
            ))}
          </div>
        </div>

        {/* Open Women */}
        <div class="px-6 py-5">
          <h3 class="text-xs font-bold uppercase tracking-wider text-pink-400 mb-4 flex items-center gap-2">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            Women
          </h3>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 gap-3">
            {womenGoals.map((g) => (
              <a
                href={`/calculator/${g.slug}/`}
                class="bg-bg border border-border rounded-xl p-4 hover:border-pink-400/40 hover:bg-bg-card-hover transition-all no-underline group"
              >
                <div class="text-base font-black text-text-heading group-hover:text-pink-400 transition-colors">{g.goalShort}</div>
                <div class="text-xs text-text-muted">{g.goalLabel}</div>
              </a>
            ))}
          </div>
        </div>
      </div>

      {/* ── Pro Division ── */}
      <div class="mb-8 rounded-2xl border border-amber-500/40 overflow-hidden">
        <div class="bg-amber-500/10 px-6 py-4 border-b border-amber-500/20 flex items-center gap-3">
          <span class="inline-block w-2.5 h-2.5 rounded-full bg-amber-400 flex-shrink-0"></span>
          <div>
            <span class="text-sm font-black text-amber-400 uppercase tracking-wide">Pro Division</span>
            <span class="ml-3 text-xs text-text-muted">Heavier station weights · qualification required</span>
          </div>
        </div>

        {/* Pro Men */}
        <div class="px-6 py-5 border-b border-border/50">
          <h3 class="text-xs font-bold uppercase tracking-wider text-amber-400 mb-4 flex items-center gap-2">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            Men
          </h3>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 gap-3">
            {proMenGoals.map((g) => (
              <a
                href={`/calculator/${g.slug}/`}
                class="bg-bg border border-border rounded-xl p-4 hover:border-amber-400/40 hover:bg-bg-card-hover transition-all no-underline group"
              >
                <div class="text-base font-black text-text-heading group-hover:text-amber-400 transition-colors">{g.goalShort}</div>
                <div class="text-xs text-text-muted">{g.goalLabel}</div>
              </a>
            ))}
          </div>
        </div>

        {/* Pro Women */}
        <div class="px-6 py-5">
          <h3 class="text-xs font-bold uppercase tracking-wider text-amber-300 mb-4 flex items-center gap-2">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            Women
          </h3>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 gap-3">
            {proWomenGoals.map((g) => (
              <a
                href={`/calculator/${g.slug}/`}
                class="bg-bg border border-border rounded-xl p-4 hover:border-amber-300/40 hover:bg-bg-card-hover transition-all no-underline group"
              >
                <div class="text-base font-black text-text-heading group-hover:text-amber-300 transition-colors">{g.goalShort}</div>
                <div class="text-xs text-text-muted">{g.goalLabel}</div>
              </a>
            ))}
          </div>
        </div>
      </div>

      {/* ── Doubles Division ── */}
      <div class="mb-8 rounded-2xl border border-violet-500/40 overflow-hidden">
        <div class="bg-violet-500/10 px-6 py-4 border-b border-violet-500/20 flex items-center gap-3">
          <span class="inline-block w-2.5 h-2.5 rounded-full bg-violet-400 flex-shrink-0"></span>
          <div>
            <span class="text-sm font-black text-violet-300 uppercase tracking-wide">Doubles Division</span>
            <span class="ml-3 text-xs text-text-muted">Two-athlete teams · station reps split, all 8 km run together</span>
          </div>
        </div>

        {/* Doubles Men */}
        <div class="px-6 py-5 border-b border-border/50">
          <h3 class="text-xs font-bold uppercase tracking-wider text-violet-300 mb-4 flex items-center gap-2">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            Men
          </h3>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 gap-3">
            {doublesMenGoals.map((g) => (
              <a
                href={`/calculator/${g.slug}/`}
                class="bg-bg border border-border rounded-xl p-4 hover:border-violet-400/40 hover:bg-bg-card-hover transition-all no-underline group"
              >
                <div class="text-base font-black text-text-heading group-hover:text-violet-300 transition-colors">{g.goalShort}</div>
                <div class="text-xs text-text-muted">{g.goalLabel}</div>
              </a>
            ))}
          </div>
        </div>

        {/* Doubles Women */}
        <div class="px-6 py-5">
          <h3 class="text-xs font-bold uppercase tracking-wider text-violet-200 mb-4 flex items-center gap-2">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            Women
          </h3>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 gap-3">
            {doublesWomenGoals.map((g) => (
              <a
                href={`/calculator/${g.slug}/`}
                class="bg-bg border border-border rounded-xl p-4 hover:border-violet-300/40 hover:bg-bg-card-hover transition-all no-underline group"
              >
                <div class="text-base font-black text-text-heading group-hover:text-violet-200 transition-colors">{g.goalShort}</div>
                <div class="text-xs text-text-muted">{g.goalLabel}</div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div class="max-w-6xl mt-12 pt-10 border-t border-border">
      <h2 class="text-2xl md:text-3xl font-black text-text-heading mb-2">More free Hyrox tools</h2>
      <p class="text-text-muted mb-6 max-w-2xl">
        Specialised calculators built on the same race data engine.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a href="/calculator/sled-push-watts/" class="block bg-bg-card border border-border rounded-2xl p-5 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline">
          <div class="text-xs font-bold uppercase tracking-wider text-accent mb-2">Tool</div>
          <h3 class="text-base font-black text-text-heading mb-1">Sled push watts</h3>
          <p class="text-xs text-text-muted">Force, power, watts/kg from sled weight, friction, and time.</p>
        </a>
        <a href="/records/" class="block bg-bg-card border border-border rounded-2xl p-5 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline">
          <div class="text-xs font-bold uppercase tracking-wider text-accent mb-2">Reference</div>
          <h3 class="text-base font-black text-text-heading mb-1">Hyrox world records</h3>
          <p class="text-xs text-text-muted">Open, Pro, Doubles, Relay — fastest confirmed times.</p>
        </a>
        <a href="/race-day-checklist/" class="block bg-bg-card border border-border rounded-2xl p-5 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline">
          <div class="text-xs font-bold uppercase tracking-wider text-accent mb-2">Race day</div>
          <h3 class="text-base font-black text-text-heading mb-1">Race-day checklist</h3>
          <p class="text-xs text-text-muted">Printable, taper to start-line.</p>
        </a>
      </div>
    </div>

    <div class="max-w-6xl mt-12 pt-10 border-t border-border bg-bg-card/40 rounded-2xl p-6">
      <h2 class="text-xl md:text-2xl font-black text-text-heading mb-2">Embed this calculator</h2>
      <p class="text-text-muted text-sm mb-4 max-w-2xl">
        Free for any site or coach to embed. Drop this snippet into a blog post or training page. Link back is appreciated but not required.
      </p>
      <pre class="bg-bg border border-border rounded-lg p-4 text-xs text-text-muted overflow-x-auto"><code>&lt;iframe src="https://www.hyroxvault.com/calculator/embed/" width="100%" height="900" style="border:0;border-radius:12px" title="Hyrox Race Time Predictor"&gt;&lt;/iframe&gt;</code></pre>
    </div>

    <div class="max-w-6xl mt-12 pt-10 border-t border-border">
      <h2 class="text-2xl md:text-3xl font-black text-text-heading mb-2">Age-graded benchmarks</h2>
      <p class="text-text-muted mb-6 max-w-2xl">
        What a "good" Hyrox time looks like by age. Same engine, scaled by Hyrox masters slowdown factors.
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-7 gap-3">
        {[30, 35, 40, 45, 50, 55, 60].map((age) => (
          <a
            href={`/calculator/age-${age}/`}
            class="bg-bg-card border border-border rounded-xl p-4 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline group text-center"
          >
            <div class="text-xs font-bold uppercase tracking-wider text-accent mb-1">Age</div>
            <div class="text-lg font-black text-text-heading group-hover:text-accent transition-colors">{age}</div>
          </a>
        ))}
      </div>
    </div>

    <script is:inline define:vars={{ goalConfigs: ALL_GOAL_TIME_CONFIGS.map(g => ({ slug: g.slug, audience: g.audience, goalSeconds: g.goalSeconds })) }}>
      var btn   = document.getElementById("goal-time-btn");
      var input = document.getElementById("goal-time-input");
      var sel   = document.getElementById("goal-audience-input");
      var err   = document.getElementById("goal-time-error");

      function parseMinutes(raw) {
        var s = raw.trim();
        if (s.indexOf(":") !== -1) {
          var parts = s.split(":");
          var h = Number(parts[0]), m = Number(parts[1]);
          if (isNaN(h) || isNaN(m)) return null;
          return h * 60 + m;
        }
        var n = parseFloat(s);
        return isNaN(n) ? null : n;
      }

      if (btn) btn.addEventListener("click", function() {
        if (err) err.classList.add("hidden");
        var mins = parseMinutes(input ? input.value : "");
        if (mins === null) { if (err) err.classList.remove("hidden"); return; }
        var audience = sel ? sel.value : "open-men";
        var seconds  = mins * 60;
        var pool = goalConfigs;
        var above = pool.filter(function(c) { return c.audience === audience && c.goalSeconds >= seconds; })
                        .sort(function(a, b) { return a.goalSeconds - b.goalSeconds; });
        var match = above[0] || pool.filter(function(c) { return c.audience === audience; })
                                    .sort(function(a, b) { return a.goalSeconds - b.goalSeconds; })[0];
        if (match) {
          window.location.href = "/calculator/" + match.slug + "/";
        } else {
          if (err) err.classList.remove("hidden");
        }
      });

      if (input) input.addEventListener("keydown", function(e) {
        if (e.key === "Enter" && btn) btn.click();
      });
    </script>

    <!-- Methodology — moved to the bottom so the calculator and goal-time guides come first -->
    <div class="max-w-3xl mt-16 pt-10 border-t border-border space-y-8" id="methodology">
      <header>
        <div class="text-xs font-bold uppercase tracking-wider text-accent mb-2">Methodology</div>
        <h2 class="text-2xl md:text-3xl font-black text-text-heading">How this calculator works</h2>
        <p class="mt-2 text-sm text-text-muted leading-relaxed">
          Built by the editorial team against aggregated 2026 results data: running coefficients by James (5K input), strength coefficients by Adam (bench and deadlift), and the race-strategy weighting by Max.
        </p>
      </header>

      <div class="bg-bg-card border border-border rounded-2xl p-6">
        <h3 class="text-base font-black text-text-heading mb-3">Why we ask for these inputs</h3>
        <p class="text-text-muted text-sm leading-relaxed mb-3">
          Three numbers cover most of the variance in Hyrox finish times:
        </p>
        <ul class="text-sm text-text-muted leading-relaxed space-y-2 mb-3">
          <li><strong class="text-text-heading">5 km time:</strong> sets your running baseline. Half of a Hyrox is running, so this number alone explains roughly 40–50% of your finish time.</li>
          <li><strong class="text-text-heading">Bench press 1RM:</strong> proxy for upper-body strength endurance. Drives SkiErg, sled pull, farmers carry, and wall balls.</li>
          <li><strong class="text-text-heading">Deadlift 1RM:</strong> proxy for lower-body strength. Drives sled push, sandbag lunges, and burpee broad jumps recovery.</li>
          <li><strong class="text-text-heading">Bodyweight:</strong> matters in two directions. Heavier athletes pay on running and bodyweight stations; lighter athletes pay on the sleds.</li>
        </ul>
        <p class="text-text-muted text-sm leading-relaxed">
          We chose bench and deadlift instead of, say, sled push 1RM or rowing 500 m PR because most readers know their gym lifts. They are an imperfect proxy, which is the point of the next section.
        </p>
      </div>

      <div class="bg-bg-card border border-border rounded-2xl p-6">
        <h3 class="text-base font-black text-text-heading mb-3">Where the model is weak</h3>
        <p class="text-text-muted text-sm leading-relaxed mb-3">
          The model assumes your strength is roughly balanced and that your aerobic engine matches your 5 km pace under fresh legs. It will be off if any of these are true:
        </p>
        <ul class="text-sm text-text-muted leading-relaxed space-y-2 mb-3">
          <li><strong class="text-text-heading">Strong on lifts, weak on conditioning:</strong> the calculator will under-predict because it does not know how badly you'll fade in the back half. Open the trainer panel below the result and enter real station times for a corrected diagnosis.</li>
          <li><strong class="text-text-heading">Pure runner with no station experience:</strong> we under-weight the technical penalty on first-time wall balls and burpee broad jumps. Expect to land 5–10 minutes slower than the prediction in your first race.</li>
          <li><strong class="text-text-heading">Pacing failures:</strong> going out too hard on SkiErg or sled push can add 10+ minutes to a Hyrox. The model assumes a competent pacing strategy.</li>
        </ul>
        <p class="text-text-muted text-sm leading-relaxed">
          <strong class="text-text-heading">Realistic accuracy band:</strong> most athletes land within 5–15 minutes of their actual finish time on a first prediction. For trained athletes with at least one race under their belt, the band typically narrows to ±5 minutes.
        </p>
      </div>

      <div class="bg-bg-card border border-border rounded-2xl p-6">
        <h3 class="text-base font-black text-text-heading mb-3">Open vs Pro assumptions</h3>
        <p class="text-text-muted text-sm leading-relaxed mb-3">
          Pro division uses heavier sleds, heavier sandbag, heavier wall ball, and heavier kettlebells. The engine multiplies each station's base time by Pro-specific factors when you flip the toggle. The biggest deltas:
        </p>
        <ul class="text-sm text-text-muted leading-relaxed space-y-2">
          <li>Sled push: ~28% longer in Pro</li>
          <li>Sled pull: ~20% longer in Pro</li>
          <li>Burpee broad jumps: ~15% faster (Pro athletes are typically fitter, not heavier-burpees)</li>
          <li>Strength-ratio targets: bench 1.0×bw → 1.25×bw and deadlift 1.5×bw → 1.85×bw for the "competent" Pro Open Men benchmark.</li>
        </ul>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <a
          href="/racing-guide/times/"
          class="group flex items-center gap-4 bg-bg-card border border-border rounded-xl p-5 hover:border-accent/30 transition-all"
        >
          <span class="text-2xl">⏱️</span>
          <div>
            <h3 class="font-bold text-text-heading group-hover:text-accent transition-colors text-sm">Full time benchmarks</h3>
            <p class="text-text-muted text-xs">Detailed benchmark tables for every level</p>
          </div>
        </a>
        <a
          href="/training/"
          class="group flex items-center gap-4 bg-bg-card border border-border rounded-xl p-5 hover:border-accent/30 transition-all"
        >
          <span class="text-2xl">💪</span>
          <div>
            <h3 class="font-bold text-text-heading group-hover:text-accent transition-colors text-sm">Training programs</h3>
            <p class="text-text-muted text-xs">Get faster with structured plans</p>
          </div>
        </a>
      </div>

      <div class="bg-bg-card border border-border rounded-2xl p-6">
        <h3 class="text-base font-black text-text-heading mb-3">Goal-time blueprints — deeper reads</h3>
        <p class="text-text-muted text-sm leading-relaxed mb-4">
          Long-form blueprints with the training block, mindset, and race-day execution behind each tier.
        </p>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-2">
          {[
            { href: "/blog/hyrox-sub-60-blueprint/", label: "Sub-60 blueprint" },
            { href: "/blog/hyrox-sub-75-blueprint/", label: "Sub-75 blueprint" },
            { href: "/blog/hyrox-sub-90-blueprint/", label: "Sub-90 blueprint" },
