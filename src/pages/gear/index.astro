---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContentIcons from "../../components/icons/ContentIcons.astro";
import { GEAR_COMPARISONS } from "../../data/gear-comparisons";
import { getCollection } from "astro:content";

const title = "Hyrox Gear Guide — Shoes, Apparel & Accessories";
const description = "Hyrox gear buying guides for shoes, apparel, accessories, and home-gym kit, plus side-by-side brand comparisons evaluated against race-specific demands.";
const breadcrumbs = [{ name: "Gear" }];

const shoes = GEAR_COMPARISONS.filter((c) => c.category === "shoes");
const equipment = GEAR_COMPARISONS.filter((c) => c.category === "equipment");

const buyingGuides = (await getCollection("gear")).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);

const guideIcons: Record<string, string> = {
  shoes: "shoe",
  clothing: "shirt",
  accessories: "backpack",
  "home-gym": "home",
};
---

<BaseLayout
  title={`${title} | Hyrox Vault`}
  description={description}
  ogType="website"
  schemaType="CollectionPage"
  dateModified="2026-05-09"
  breadcrumbs={breadcrumbs}
>
  <div class="container-main py-10 md:py-16">
    <nav class="mb-8 text-sm" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 flex-wrap">
        <li><a href="/" class="text-text-muted hover:text-accent transition-colors no-underline">Home</a></li>
        <li class="flex items-center gap-2">
          <span class="text-text-muted/40">/</span>
          <span class="text-text">Gear</span>
        </li>
      </ol>
    </nav>

    <header class="mb-10 pb-8 border-b border-border">
      <p class="text-sm text-text-muted mb-3">
        Last reviewed May 2026 · By <a href="/author/" class="text-accent hover:underline">HyroxVault Editorial Team</a>
      </p>
      <h1 class="text-4xl md:text-5xl font-black leading-tight text-gradient-accent">
        Hyrox Gear Guide
      </h1>
      <p class="mt-4 text-lg text-text-muted leading-relaxed max-w-2xl">
        Buying guides and head-to-head comparisons for the gear you'll actually use in Hyrox: race shoes, apparel, accessories, and home-gym kit.
      </p>
      <p class="mt-3 text-sm text-text-muted/80">
        Recommendations are evaluated against the published evidence on running shoes, gear durability, and race-specific demands, plus our own race-day use of category-equivalent products. See our <a href="/methodology/" class="text-accent hover:underline">methodology</a> for the full editorial standards.
      </p>
    </header>

    <section class="mb-16">
      <h2 class="text-3xl font-black text-text-heading mb-2">Buying guides</h2>
      <p class="text-text-muted mb-6 max-w-2xl">
        Start here if you're picking your first Hyrox kit. Category-by-category recommendations with what to look for, why it matters, and our top picks.
      </p>
      <div class="grid gap-4 md:grid-cols-2">
        {buyingGuides.map((g) => (
          <a
            href={`/gear/${g.id}/`}
            class="block bg-bg-card border border-border rounded-2xl p-6 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline"
          >
            <div class="flex items-center gap-3 mb-2">
              <span class="text-accent"><ContentIcons name={guideIcons[g.data.category] ?? "cart"} size={26} /></span>
              <div class="text-xs font-bold uppercase tracking-wider text-accent">
                {g.data.category.replace("-", " ")}
              </div>
            </div>
            <h3 class="text-xl font-black text-text-heading mb-2">{g.data.title}</h3>
            <p class="text-sm text-text-muted leading-relaxed">{g.data.description}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="mb-16">
      <h2 class="text-3xl font-black text-text-heading mb-6">Shoe comparisons</h2>
      <div class="grid gap-4 md:grid-cols-2">
        {shoes.map((c) => (
          <a
            href={`/gear/${c.slug}/`}
            class="block bg-bg-card border border-border rounded-2xl p-6 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline"
          >
            <div class="text-xs font-bold uppercase tracking-wider text-accent mb-2">Shoes</div>
            <h3 class="text-xl font-black text-text-heading mb-2">{c.productALabel} vs {c.productBLabel}</h3>
            <p class="text-sm text-text-muted leading-relaxed">{c.metaDescription}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="mb-16">
      <h2 class="text-3xl font-black text-text-heading mb-6">Equipment comparisons</h2>
      <div class="grid gap-4 md:grid-cols-2">
        {equipment.map((c) => (
          <a
            href={`/gear/${c.slug}/`}
            class="block bg-bg-card border border-border rounded-2xl p-6 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline"
          >
            <div class="text-xs font-bold uppercase tracking-wider text-accent mb-2">Equipment</div>
            <h3 class="text-xl font-black text-text-heading mb-2">{c.productALabel} vs {c.productBLabel}</h3>
            <p class="text-sm text-text-muted leading-relaxed">{c.metaDescription}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="prose md:prose-lg max-w-none">
      <h2>How to use these comparisons</h2>
      <p>
        Every comparison is structured around the question: which one is faster, more durable, or better-suited for your body type and goal time at Hyrox. We don't recommend "the best" — we tell you which choice fits which athlete profile.
      </p>
      <p>
        See also: <a href="/blog/hyrox-shoe-rules/">Hyrox shoe rules</a> for what's legal on race day, and <a href="/compare/">sport comparisons</a> if you're choosing between Hyrox and another race format.
      </p>
    </section>
  </div>
</BaseLayout>
