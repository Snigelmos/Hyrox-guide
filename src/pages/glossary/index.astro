---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { GLOSSARY_TERMS } from "../../data/glossary";

const title = "Hyrox Glossary — Every Hyrox Term Explained";
const description = "Hyrox glossary: definitions of roxzone, doubles handover, wave start, DNF, no-rep, Elite 15, and every other key Hyrox term you'll encounter.";
const breadcrumbs = [{ name: "Glossary" }];

const siteUrl = "https://www.hyroxvault.com";

const sortedTerms = [...GLOSSARY_TERMS].sort((a, b) =>
  a.term.localeCompare(b.term),
);

const termsByLetter = sortedTerms.reduce<Record<string, typeof sortedTerms>>(
  (acc, term) => {
    const letter = term.term[0].toUpperCase();
    if (!acc[letter]) acc[letter] = [];
    acc[letter].push(term);
    return acc;
  },
  {},
);

const letters = Object.keys(termsByLetter).sort();

const definedTermSetSchema = {
  "@context": "https://schema.org",
  "@type": "DefinedTermSet",
  name: "Hyrox Glossary",
  description,
  url: `${siteUrl}/glossary/`,
  hasDefinedTerm: sortedTerms.map((t) => ({
    "@type": "DefinedTerm",
    "@id": `${siteUrl}/glossary/${t.slug}/`,
    name: t.term,
    description: t.longDefinition,
    url: `${siteUrl}/glossary/${t.slug}/`,
    inDefinedTermSet: `${siteUrl}/glossary/`,
  })),
};
---

<BaseLayout
  title={`${title} | Hyrox Vault`}
  description={description}
  ogType="website"
  schemaType="CollectionPage"
  breadcrumbs={breadcrumbs}
>
  <div class="container-main py-10 md:py-16">
    <nav class="mb-8 text-sm" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 flex-wrap">
        <li><a href="/" class="text-text-muted hover:text-accent transition-colors no-underline">Home</a></li>
        <li class="flex items-center gap-2">
          <span class="text-text-muted/40">/</span>
          <span class="text-text">Glossary</span>
        </li>
      </ol>
    </nav>

    <header class="mb-8 pb-6 border-b border-border">
      <h1 class="text-4xl md:text-5xl font-black leading-tight text-gradient-accent">
        Hyrox Glossary
      </h1>
      <p class="mt-4 text-lg text-text-muted leading-relaxed max-w-2xl">
        Every key Hyrox term explained — race format, judging, divisions, gear, and qualifying. {sortedTerms.length} terms, all defined inline.
      </p>
    </header>

    <nav
      aria-label="Jump to letter"
      class="mb-10 flex flex-wrap gap-2 sticky top-16 z-10 bg-bg/95 backdrop-blur py-3 -mx-4 px-4 border-b border-border/50"
    >
      <span class="text-xs font-bold uppercase tracking-wider text-text-muted self-center mr-2">Jump to:</span>
      {letters.map((letter) => (
        <a
          href={`#letter-${letter}`}
          class="inline-flex items-center justify-center min-w-[2rem] h-8 px-2 text-sm font-bold rounded-md border border-border text-text-muted hover:border-accent/40 hover:text-accent hover:bg-accent/5 transition-colors no-underline"
        >
          {letter}
        </a>
      ))}
    </nav>

    <div class="space-y-12">
      {letters.map((letter) => (
        <section id={`letter-${letter}`} aria-labelledby={`letter-${letter}-heading`}>
          <h2
            id={`letter-${letter}-heading`}
            class="text-2xl font-black text-accent mb-5 pb-2 border-b border-border"
          >
            {letter}
          </h2>
          <dl class="space-y-8">
            {termsByLetter[letter].map((t) => (
              <div id={`term-${t.slug}`} class="scroll-mt-24">
                <dt class="text-xl font-black text-text-heading mb-2">
                  <a
                    href={`/glossary/${t.slug}/`}
                    class="hover:text-accent transition-colors no-underline"
                  >
                    {t.term}
                  </a>
                </dt>
                <dd class="text-base text-text-muted leading-relaxed">
                  {t.longDefinition}
                  {" "}
                  <a
                    href={`/glossary/${t.slug}/`}
                    class="text-accent hover:underline whitespace-nowrap"
                    aria-label={`Read more about ${t.term}`}
                  >
                    Read more →
                  </a>
                </dd>
              </div>
            ))}
          </dl>
        </section>
      ))}
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(definedTermSetSchema)} />
</BaseLayout>
