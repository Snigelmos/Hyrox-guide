---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { STATIONS } from "../../data/stations";

const title = "Hyrox Stations — Weights, Standards, and Technique";
const description = "Every Hyrox station explained: official weights by division, common no-reps, and proven technique for SkiErg, sled push, sled pull, burpee broad jumps, row, farmers carry, sandbag lunges, and wall balls.";
---

<BaseLayout
  title={`${title} | Hyrox Vault`}
  description={description}
  ogType="article"
  schemaType="Article"
  breadcrumbs={[{ name: "Stations" }]}
>
  <div class="container-main py-10 md:py-16">
    <header class="mb-10 pb-8 border-b border-border">
      <h1 class="text-4xl md:text-5xl font-black leading-tight text-gradient-accent">
        {title}
      </h1>
      <p class="mt-4 text-lg text-text-muted leading-relaxed max-w-2xl">
        {description}
      </p>
    </header>

    <section class="prose md:prose-lg max-w-none mb-10">
      <p>
        Every Hyrox race contains the same eight stations in the same order, separated by 1km of running. Click any station for the official weight standards, common no-reps, and step-by-step technique.
      </p>
    </section>

    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {STATIONS.map((station) => (
        <a
          href={`/stations/${station.slug}/standards/`}
          class="block bg-bg-card border border-border rounded-2xl p-5 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline"
        >
          <div class="text-xs font-bold uppercase tracking-wider text-accent mb-2">
            Station {station.position}
          </div>
          <div class="text-lg font-bold text-text-heading mb-1">{station.name}</div>
          <div class="text-sm text-text-muted">
            {station.distance ?? station.reps}
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
