---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import HyroxCalculator from "../components/HyroxCalculator";
import GeoAffiliateButton from "../components/GeoAffiliateButton";
import StationCard from "../components/StationCard.astro";
import NewsletterForm from "../components/NewsletterForm.astro";
import AdSlot from "../components/AdSlot.astro";

const supplementStrip = [
  { icon: "💪", name: "Creatine", productKey: "creatine-monohydrate", href: "/supplements/creatine/" },
  { icon: "🥤", name: "Protein", productKey: "protein-powder", href: "/supplements/protein-powder/" },
  { icon: "⚡", name: "Energy Gels", productKey: "energy-gels", href: "/supplements/energy-gels/" },
  { icon: "🔥", name: "Pre-Workout", productKey: "pre-workout", href: "/supplements/pre-workout/" },
  { icon: "💧", name: "Electrolytes", productKey: "electrolytes", href: "/supplements/electrolytes/" },
  { icon: "🔄", name: "Recovery", productKey: "recovery", href: "/supplements/recovery/" },
];

const workoutCategories = [
  {
    id: "full-simulations",
    icon: "🏁",
    label: "Full Simulations",
    description: "Mini, half, and full Hyrox race simulations. The single most effective training sessions you can do.",
    count: "3 workouts",
    color: "border-sky-400/30 hover:border-sky-400/60",
    badge: "text-sky-400 bg-sky-400/10 border-sky-400/20",
  },
  {
    id: "running",
    icon: "🏃",
    label: "Running",
    description: "Intervals, tempo runs, and race-pace treadmill work. Fix the 8km of running that connects every station.",
    count: "3 workouts",
    color: "border-emerald-400/30 hover:border-emerald-400/60",
    badge: "text-emerald-400 bg-emerald-400/10 border-emerald-400/20",
  },
  {
    id: "station-work",
    icon: "🏋️",
    label: "Station Work",
    description: "Targeted sessions for your weak stations — sled, wall balls, burpees, farmers carry, and sandbag lunges.",
    count: "4 workouts",
    color: "border-amber-400/30 hover:border-amber-400/60",
    badge: "text-amber-400 bg-amber-400/10 border-amber-400/20",
  },
  {
    id: "strength-power",
    icon: "💥",
    label: "Strength & Power",
    description: "Heavy gym days for station capacity — back squat, deadlift, posterior chain, and SkiErg pulling strength.",
    count: "3 workouts",
    color: "border-red-400/30 hover:border-red-400/60",
    badge: "text-red-400 bg-red-400/10 border-red-400/20",
  },
];

const stations = [
  { number: 1, name: "SkiErg", metric: "1,000m", description: "Full-body pull simulation that torches your shoulders and core.", icon: "🎿" },
  { number: 2, name: "Sled Push", metric: "50m", description: "Raw leg power. Push a weighted sled across the floor.", icon: "🛷" },
  { number: 3, name: "Sled Pull", metric: "50m", description: "Rope pull a heavy sled toward you, hand over hand.", icon: "🪢" },
  { number: 4, name: "Burpee Broad Jumps", metric: "80m", description: "The most dreaded station. Burpee, jump forward, repeat.", icon: "🤸" },
  { number: 5, name: "Rowing", metric: "1,000m", description: "A full-body grind that tests your aerobic engine.", icon: "🚣" },
  { number: 6, name: "Farmers Carry", metric: "200m", description: "Grip strength and mental grit. Carry heavy kettlebells.", icon: "🏋️" },
  { number: 7, name: "Sandbag Lunges", metric: "100m", description: "Lunges with a sandbag on your shoulder. Legs on fire.", icon: "🎒" },
  { number: 8, name: "Wall Balls", metric: "75–100 reps", description: "The final station. Squat, throw, catch, repeat until done.", icon: "🏐" },
];
---

<BaseLayout
  title="Hyrox Calculator, Workouts & Supplement Guide (2026)"
  description="Free Hyrox calculator, workout library, and evidence-based supplement guide. Predict your finish time, train every station, and pick the supplements that actually work."
>
  <!-- HERO — lighter gradient, focused H1 -->
  <Hero />

  <!-- CALCULATOR — immediately below hero, no scroll needed -->
  <section class="container-main py-10 md:py-14">
    <HyroxCalculator client:only="react" />
  </section>

  <!-- SUPPLEMENT GEO STRIP — 6 tiles, geo-aware buy buttons -->
  <section class="border-y border-border bg-bg-card/40">
    <div class="container-main py-10">
      <div class="flex items-center justify-between mb-6">
        <div>
          <h2 class="text-xl md:text-2xl font-black text-text-heading">Fuel Your Race</h2>
          <p class="text-sm text-text-muted mt-0.5">Evidence-based picks — buy links match your country automatically.</p>
        </div>
        <a href="/supplements/" class="hidden sm:inline-flex items-center gap-1 text-sm font-semibold text-accent hover:underline">
          Full guide
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
        {supplementStrip.map((s) => (
          <div class="bg-bg-card border border-border rounded-xl p-4 flex flex-col items-center text-center hover:border-accent/30 transition-all">
            <a href={s.href} class="flex flex-col items-center mb-3">
              <span class="text-2xl mb-1.5">{s.icon}</span>
              <span class="text-xs font-bold text-text-heading">{s.name}</span>
            </a>
            <GeoAffiliateButton productKey={s.productKey} variant="card" client:visible />
          </div>
        ))}
      </div>
      <p class="text-xs text-text-muted/50 mt-4 text-center">
        Affiliate links — we may earn a commission at no extra cost to you.
      </p>
    </div>
  </section>

  <!-- WORKOUT LIBRARY — 4 category cards -->
  <section class="container-main py-16">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h2 class="text-3xl md:text-4xl font-black text-text-heading">Hyrox Workouts</h2>
        <p class="text-text-muted mt-1">4 categories. All levels. Drop in and train.</p>
      </div>
      <a href="/training/workouts/" class="hidden sm:inline-flex items-center gap-1 text-sm font-semibold text-accent hover:underline">
        All workouts
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {workoutCategories.map((cat) => (
        <a
          href={`/training/workouts/#${cat.id}`}
          class={`group flex flex-col bg-bg-card border ${cat.color} rounded-2xl p-6 transition-all hover:-translate-y-0.5`}
        >
          <span class="text-3xl mb-3">{cat.icon}</span>
          <span class={`self-start mb-3 px-2 py-0.5 text-xs font-bold rounded-full border ${cat.badge}`}>
            {cat.count}
          </span>
          <h3 class="text-lg font-black text-text-heading mb-2 group-hover:text-accent transition-colors">
            {cat.label}
          </h3>
          <p class="text-sm text-text-muted leading-relaxed flex-1">{cat.description}</p>
          <div class="flex items-center gap-1 text-xs font-semibold text-accent mt-4">
            See workouts
            <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </a>
      ))}
    </div>
    <div class="sm:hidden mt-6 text-center">
      <a href="/training/workouts/" class="inline-flex items-center gap-1 text-sm font-semibold text-accent hover:underline">
        All workouts →
      </a>
    </div>
  </section>

  <AdSlot id="home-top" format="banner" />

  <!-- TRAINING PROGRAMS -->
  <section class="container-main pb-16">
    <div class="bg-bg-card border border-border rounded-2xl p-8 md:p-12 lg:flex lg:items-center lg:gap-12">
      <div class="lg:flex-1 mb-6 lg:mb-0">
        <h2 class="text-2xl md:text-3xl font-black text-text-heading mb-2">Need a full training plan?</h2>
        <p class="text-text-muted">
          Structured week-by-week programs from beginner to advanced — built specifically for Hyrox.
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a href="/training/beginner/" class="inline-flex items-center justify-center px-5 py-2.5 bg-accent text-bg font-bold rounded-xl hover:bg-accent-dim transition-colors text-sm">
          Beginner
        </a>
        <a href="/training/intermediate/" class="inline-flex items-center justify-center px-5 py-2.5 border border-accent/30 text-accent font-bold rounded-xl hover:bg-accent/10 transition-colors text-sm">
          Intermediate
        </a>
        <a href="/training/advanced/" class="inline-flex items-center justify-center px-5 py-2.5 border border-border text-text font-bold rounded-xl hover:border-accent/30 transition-colors text-sm">
          Advanced
        </a>
      </div>
    </div>
  </section>

  <!-- WHAT IS HYROX — moved lower, for context after calculator/workouts -->
  <section class="border-t border-border bg-bg-card/30">
    <div class="container-main py-12">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-xl font-black text-text-heading mb-4">What is Hyrox?</h2>
        <p class="text-base text-text-muted leading-relaxed mb-4">
          <strong class="text-text-heading">Hyrox is a global indoor fitness race</strong> — every event follows the exact same format: 8 rounds of 1 km running, each followed by one functional workout station. The stations are always SkiErg, Sled Push, Sled Pull, Burpee Broad Jumps, Rowing, Farmers Carry, Sandbag Lunges, and Wall Balls — in that order, at standardised weights.
        </p>
        <p class="text-base text-text-muted leading-relaxed">
          It's the fastest-growing indoor fitness race in the world with events in 50+ countries. Whether you're a first-timer or chasing a personal best, this site covers everything you need: how to train, what to eat, how to race, and where to sign up next.
        </p>
        <div class="flex flex-wrap gap-3 mt-6">
          <a href="/racing-guide/what-is-hyrox/" class="inline-flex items-center gap-1 text-sm font-semibold text-accent hover:underline">
            Full beginner guide →
          </a>
          <a href="/racing-guide/stations/" class="inline-flex items-center gap-1 text-sm font-semibold text-text-muted hover:text-accent transition-colors">
            The 8 stations →
          </a>
          <a href="/competitions/" class="inline-flex items-center gap-1 text-sm font-semibold text-text-muted hover:text-accent transition-colors">
            Find your next race →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- THE 8 STATIONS — compact -->
  <section class="container-main py-16">
    <h2 class="text-2xl font-black text-text-heading mb-6 text-center">The 8 Stations</h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-8 gap-3">
      {stations.map((station) => (
        <a
          href="/racing-guide/stations/"
          class="group flex flex-col items-center text-center p-3 bg-bg-card border border-border rounded-xl hover:border-accent/30 transition-all"
        >
          <span class="text-2xl mb-1.5">{station.icon}</span>
          <span class="text-xs font-bold text-text-heading group-hover:text-accent transition-colors leading-tight">{station.name}</span>
          <span class="text-xs text-text-muted mt-0.5">{station.metric}</span>
        </a>
      ))}
    </div>
    <div class="text-center mt-6">
      <a href="/racing-guide/stations/" class="inline-flex items-center gap-1 text-sm font-semibold text-accent hover:underline">
        Deep dive into each station →
      </a>
    </div>
  </section>

  <!-- SECONDARY NAV -->
  <section class="container-main pb-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <a href="/competitions/" class="group flex items-center gap-4 bg-bg-card border border-border rounded-xl p-5 hover:border-accent/30 transition-all">
        <span class="text-2xl">📅</span>
        <div>
          <h3 class="font-bold text-text-heading group-hover:text-accent transition-colors text-sm">Upcoming Competitions</h3>
          <p class="text-text-muted text-xs">Find your next race & sign up</p>
        </div>
      </a>
      <a href="/supplements/protocol/" class="group flex items-center gap-4 bg-bg-card border border-border rounded-xl p-5 hover:border-accent/30 transition-all">
        <span class="text-2xl">🗓️</span>
        <div>
          <h3 class="font-bold text-text-heading group-hover:text-accent transition-colors text-sm">Race Day Protocol</h3>
          <p class="text-text-muted text-xs">Exact supplement timing guide</p>
        </div>
      </a>
      <a href="/faq/" class="group flex items-center gap-4 bg-bg-card border border-border rounded-xl p-5 hover:border-accent/30 transition-all">
        <span class="text-2xl">❓</span>
        <div>
          <h3 class="font-bold text-text-heading group-hover:text-accent transition-colors text-sm">FAQ</h3>
          <p class="text-text-muted text-xs">Common questions answered</p>
        </div>
      </a>
    </div>
  </section>

  <div class="container-main py-12">
    <NewsletterForm />
  </div>
</BaseLayout>
