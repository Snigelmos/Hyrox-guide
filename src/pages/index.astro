---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import GeoAffiliateButton from "../components/GeoAffiliateButton";
import NewsletterForm from "../components/NewsletterForm.astro";
import AdSlot from "../components/AdSlot.astro";
import TrainingIcons from "../components/icons/TrainingIcons.astro";
import StationIcons from "../components/icons/StationIcons.astro";
import { getCollection } from "astro:content";

// Latest blog posts
const allPosts = (await getCollection("blog")).sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);
const latestPosts = allPosts.slice(0, 3);

const modules = [
  {
    href: "/racing-guide/what-is-hyrox/",
    icon: "🏁",
    badge: "Start Here",
    badgeColor: "text-accent bg-accent/10 border-accent/20",
    title: "What is Hyrox?",
    description: "New to Hyrox? Learn the race format, the 8 stations, categories, and what makes it the fastest-growing fitness race in the world.",
    cta: "Read the Intro",
    hoverBorder: "hover:border-accent/30",
    svgBg: null,
  },
  {
    href: "/training/",
    icon: "💪",
    badge: "Get Race-Ready",
    badgeColor: "text-emerald-400 bg-emerald-400/10 border-emerald-400/20",
    title: "Training Plans",
    description: "Beginner to advanced programs with week-by-week sessions, station drills, and race simulations. Pick your level.",
    cta: "Start Training",
    hoverBorder: "hover:border-accent/30",
    svgBg: null,
  },
  {
    href: "/training/workouts/",
    icon: "🏋️",
    badge: "13 Workouts",
    badgeColor: "text-sky-400 bg-sky-400/10 border-sky-400/20",
    title: "Workout Library",
    description: "Full simulations, running sessions, station-specific work, and strength days. Drop any session into your training week.",
    cta: "Browse Workouts",
    hoverBorder: "hover:border-accent/30",
    svgBg: null,
  },
  {
    href: "/supplements/",
    icon: "⚡",
    badge: "Fuel Your Race",
    badgeColor: "text-amber-400 bg-amber-400/10 border-amber-400/20",
    title: "Supplements",
    description: "What actually moves the needle — creatine, protein, energy gels, pre-workout. Evidence-based picks, honest reviews.",
    cta: "See Our Picks",
    hoverBorder: "hover:border-amber-400/30",
    svgBg: null,
  },
  {
    href: "/calculator/",
    icon: "⏱️",
    badge: "Free Tool",
    badgeColor: "text-accent bg-accent/10 border-accent/20",
    title: "Race Calculator",
    description: "Enter your 5K pace and strength numbers. Get a full race split breakdown — instantly. Know your target time before race day.",
    cta: "Calculate My Time",
    hoverBorder: "hover:border-accent/30",
    svgBg: null,
  },
  {
    href: "/racing-guide/",
    icon: "📋",
    badge: "Race Day",
    badgeColor: "text-sky-400 bg-sky-400/10 border-sky-400/20",
    title: "Racing Guide",
    description: "Pacing strategy, station tips, transitions, and what to do the week before. Everything you need to race well.",
    cta: "Prepare to Race",
    hoverBorder: "hover:border-accent/30",
    svgBg: null,
  },
];

const supplementStrip = [
  { icon: "💪", name: "Creatine", productKey: "creatine-monohydrate", href: "/supplements/creatine/" },
  { icon: "🥤", name: "Protein", productKey: "protein-powder", href: "/supplements/protein-powder/" },
  { icon: "⚡", name: "Energy Gels", productKey: "energy-gels", href: "/supplements/energy-gels/" },
  { icon: "🔥", name: "Pre-Workout", productKey: "pre-workout", href: "/supplements/pre-workout/" },
  { icon: "💧", name: "Electrolytes", productKey: "electrolytes", href: "/supplements/electrolytes/" },
  { icon: "🔄", name: "Recovery", productKey: "recovery", href: "/supplements/recovery/" },
];
---

<BaseLayout
  title="Hyrox Vault — Race Guide, Training Plans, Calculator & Supplements (2026)"
  description="The complete Hyrox resource: race format guide, training programs, finish time calculator, supplement picks, and workout library. All evidence-based, all in one vault."
>
  <!-- HERO — Vault branding, 6 module quick-links, stats -->
  <Hero />

  <!-- WHAT IS HYROX — brief explainer -->
  <section class="border-b border-border bg-bg-card/30">
    <div class="container-main py-10">
      <div class="max-w-3xl mx-auto text-center">
        <p class="text-base md:text-lg text-text-muted leading-relaxed mb-4">
          <strong class="text-text-heading">Hyrox is a global indoor fitness race</strong> — 8 rounds of 1 km running, each followed by one functional workout station. Always the same format, always the same 8 stations, everywhere in the world.
        </p>
        <p class="text-base md:text-lg text-text-muted leading-relaxed">
          The Hyrox Vault covers everything: how to train, what to eat, how to pace, and what gear actually matters.
        </p>
      </div>
    </div>
  </section>

  <!-- THE VAULT — 6 module cards -->
  <section class="container-main py-16 md:py-20">
    <div class="text-center mb-10">
      <h2 class="text-2xl md:text-3xl font-black text-text-heading mb-2">Inside the Vault</h2>
      <p class="text-text-muted">Six modules. Everything you need to race your best Hyrox.</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-5">
      {modules.map((mod) => (
        <a
          href={mod.href}
          class={`group relative flex flex-col bg-bg-card border border-border ${mod.hoverBorder} rounded-2xl p-7 hover:bg-bg-card-hover transition-all duration-300 hover:-translate-y-0.5`}
        >
          <div class="flex items-start justify-between mb-4">
            <span class="text-3xl">{mod.icon}</span>
            <span class={`text-xs font-bold uppercase tracking-wider px-2.5 py-1 rounded-full border ${mod.badgeColor}`}>
              {mod.badge}
            </span>
          </div>
          <h2 class="text-xl font-black text-text-heading mb-2 group-hover:text-accent transition-colors">
            {mod.title}
          </h2>
          <p class="text-text-muted text-sm leading-relaxed mb-5 flex-1">
            {mod.description}
          </p>
          <div class="flex items-center gap-1 text-sm font-semibold text-accent mt-auto">
            {mod.cta}
            <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </a>
      ))}
    </div>
  </section>

  <AdSlot id="home-top" format="banner" />

  <!-- BLOG — Latest Insights -->
  <section class="container-main pb-16 md:pb-20">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h2 class="text-2xl md:text-3xl font-black text-text-heading">Latest Insights</h2>
        <p class="text-text-muted mt-1">Race strategy, training tips, and evidence-based guides.</p>
      </div>
      <a href="/blog/" class="hidden sm:inline-flex items-center gap-1 text-sm font-semibold text-accent hover:underline">
        All articles
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
      {latestPosts.map((post) => (
        <a
          href={`/blog/${post.id}/`}
          class="group flex flex-col bg-bg-card border border-border rounded-2xl p-6 hover:border-accent/30 hover:-translate-y-0.5 transition-all duration-200"
        >
          <p class="text-xs text-text-muted mb-3">
            {new Date(post.data.pubDate).toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })}
          </p>
          <h3 class="font-black text-text-heading mb-2 leading-snug group-hover:text-accent transition-colors">
            {post.data.title}
          </h3>
          <p class="text-sm text-text-muted leading-relaxed flex-1 mb-4">
            {post.data.description}
          </p>
          <span class="text-xs font-semibold text-accent">Read more →</span>
        </a>
      ))}
    </div>
    <div class="sm:hidden mt-6 text-center">
      <a href="/blog/" class="inline-flex items-center gap-1 text-sm font-semibold text-accent hover:underline">
        All articles →
      </a>
    </div>
  </section>

  <!-- SUPPLEMENT GEO STRIP -->
  <section class="border-y border-border bg-bg-card/40">
    <div class="container-main py-10">
      <div class="flex items-center justify-between mb-6">
        <div>
          <h2 class="text-lg md:text-xl font-black text-text-heading">Fuel Your Race</h2>
          <p class="text-xs text-text-muted mt-0.5">Buy links matched to your country automatically.</p>
        </div>
        <a href="/supplements/" class="hidden sm:inline-flex items-center gap-1 text-sm font-semibold text-accent hover:underline">
          Full guide
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
      <div class="grid grid-cols-3 sm:grid-cols-6 gap-3">
        {supplementStrip.map((s) => (
          <div class="bg-bg-card border border-border rounded-xl p-3 flex flex-col items-center text-center hover:border-accent/30 transition-all">
            <a href={s.href} class="flex flex-col items-center mb-2.5">
              <span class="text-xl mb-1">{s.icon}</span>
              <span class="text-xs font-bold text-text-heading leading-tight">{s.name}</span>
            </a>
            <GeoAffiliateButton productKey={s.productKey} variant="card" client:visible />
          </div>
        ))}
      </div>
      <p class="text-xs text-text-muted/50 mt-3 text-center">
        Affiliate links — we may earn a commission at no extra cost to you.
      </p>
    </div>
  </section>

  <!-- SECONDARY NAV -->
  <section class="container-main py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <a href="/competitions/" class="group flex items-center gap-4 bg-bg-card border border-border rounded-xl p-5 hover:border-accent/30 transition-all">
        <span class="text-2xl">📅</span>
        <div>
          <h3 class="font-bold text-text-heading group-hover:text-accent transition-colors text-sm">Upcoming Competitions</h3>
          <p class="text-text-muted text-xs">Find your next race & sign up</p>
        </div>
      </a>
      <a href="/supplements/protocol/" class="group flex items-center gap-4 bg-bg-card border border-border rounded-xl p-5 hover:border-accent/30 transition-all">
        <span class="text-2xl">🗓️</span>
        <div>
          <h3 class="font-bold text-text-heading group-hover:text-accent transition-colors text-sm">Race Day Protocol</h3>
          <p class="text-text-muted text-xs">Exact supplement timing guide</p>
        </div>
      </a>
      <a href="/faq/" class="group flex items-center gap-4 bg-bg-card border border-border rounded-xl p-5 hover:border-accent/30 transition-all">
        <span class="text-2xl">❓</span>
        <div>
          <h3 class="font-bold text-text-heading group-hover:text-accent transition-colors text-sm">FAQ</h3>
          <p class="text-text-muted text-xs">Common questions answered</p>
        </div>
      </a>
    </div>
  </section>

  <div class="container-main pb-16">
    <NewsletterForm />
  </div>
</BaseLayout>
