---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import HeroBackground from "../../components/HeroBackground.astro";
import blogHero from "../../assets/heroes/blog-hero.png";
import {
  getAllPosts,
  getAllSeries,
  BLOG_CATEGORIES,
  BLOG_CATEGORY_META,
  SERIES_META,
} from "../../data/blog";

const posts = await getAllPosts();
const featuredPost = posts.find((p) => p.data.featured) ?? posts[0];
const restPosts = posts.filter((p) => p.id !== featuredPost?.id);

const series = await getAllSeries();
const activeSeries = series
  .map((s) => ({ ...s, meta: SERIES_META[s.name] }))
  .filter((s) => s.meta);

const categoryCounts = BLOG_CATEGORIES.map((cat) => ({
  slug: cat,
  label: BLOG_CATEGORY_META[cat].label,
  count: posts.filter((p) => p.data.category === cat).length,
})).filter((c) => c.count > 0);
---

<BaseLayout
  title="Hyrox Blog — Training Tips, Race Strategy & News"
  description="Hyrox blog — race recaps, training tips, strategy guides, station masterclasses, and the latest Hyrox news."
>
  <section class="relative overflow-hidden border-b border-border isolate bg-gradient-to-b from-accent/5 to-transparent">
    <HeroBackground image={blogHero} position="object-center" textSide="left" priority />
    <div class="container-main py-16 md:py-20 relative z-10">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-6xl font-black mb-6">
          <span class="text-gradient-accent">Blog</span>
        </h1>
        <p class="text-xl text-text-muted leading-relaxed">
          Training tips, race strategies, station guides, nutrition, and everything Hyrox.
        </p>
      </div>
    </div>
  </section>

  <section class="container-main py-16">

    {categoryCounts.length > 0 && (
      <div class="mb-12">
        <div class="flex flex-wrap gap-2">
          <span class="inline-flex items-center px-4 py-2 bg-accent text-bg text-sm font-bold rounded-full">
            All · {posts.length}
          </span>
          {categoryCounts.map((cat) => (
            <a
              href={`/blog/category/${cat.slug}/`}
              class="inline-flex items-center px-4 py-2 bg-bg-card border border-border text-sm font-semibold text-text-muted rounded-full hover:border-accent/40 hover:text-accent transition-colors no-underline"
            >
              {cat.label} · {cat.count}
            </a>
          ))}
        </div>
      </div>
    )}

    {activeSeries.length > 0 && (
      <div class="mb-16">
        <h2 class="text-sm font-bold uppercase tracking-wider text-accent mb-4">
          Active Series
        </h2>
        <div class="grid gap-4 md:grid-cols-2">
          {activeSeries.map((s) => (
            <a
              href={`/blog/series/${s.name}/`}
              class="group block bg-bg-card border border-border rounded-2xl p-6 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline"
            >
              <div class="flex items-baseline justify-between gap-4 mb-2">
                <h3 class="text-lg font-bold text-text-heading group-hover:text-accent transition-colors leading-snug">
                  {s.meta!.label}
                </h3>
                <span class="text-xs font-bold text-accent whitespace-nowrap">
                  {s.postCount}{s.meta!.totalPlanned ? ` / ${s.meta!.totalPlanned}` : ""} posts
                </span>
              </div>
              <p class="text-sm text-text-muted leading-relaxed line-clamp-2">
                {s.meta!.description}
              </p>
            </a>
          ))}
        </div>
      </div>
    )}

    {featuredPost && (
      <div class="mb-10">
        <PostCard post={featuredPost} variant="featured" />
      </div>
    )}

    <div class="grid gap-6 md:grid-cols-2">
      {restPosts.map((post) => (
        <PostCard post={post} variant="default" />
      ))}
    </div>
  </section>
</BaseLayout>
