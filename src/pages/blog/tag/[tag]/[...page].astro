---
import type { GetStaticPaths, GetStaticPathsOptions } from "astro";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import PostCard from "../../../../components/PostCard.astro";
import { getAllPosts, slugifyTag } from "../../../../data/blog";

export const getStaticPaths: GetStaticPaths = async ({
  paginate,
}: GetStaticPathsOptions) => {
  const posts = await getAllPosts();
  const tagMap = new Map<string, { tag: string; posts: typeof posts }>();

  for (const post of posts) {
    for (const tag of post.data.tags ?? []) {
      const slug = slugifyTag(tag);
      if (!slug) continue;
      const existing = tagMap.get(slug);
      if (existing) {
        existing.posts.push(post);
      } else {
        tagMap.set(slug, { tag, posts: [post] });
      }
    }
  }

  return Array.from(tagMap.entries()).flatMap(([tagSlug, { tag, posts: tagPosts }]) =>
    paginate(tagPosts, {
      params: { tag: tagSlug },
      pageSize: 12,
      props: { tagLabel: tag },
    })
  );
};

const { page, tagLabel } = Astro.props as {
  page: { data: Awaited<ReturnType<typeof getAllPosts>>; url: { prev?: string; next?: string }; currentPage: number; lastPage: number };
  tagLabel: string;
};
---

<BaseLayout
  title={`#${tagLabel} — Hyrox Blog`}
  description={`Every Hyrox blog post tagged "${tagLabel}".`}
  noindex={true}
  breadcrumbs={[
    { name: "Blog", url: "/blog/" },
    { name: `#${tagLabel}` },
  ]}
>
  <section class="container-main py-16">
    <nav class="mb-8 text-sm" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 flex-wrap">
        <li>
          <a href="/" class="text-text-muted hover:text-accent no-underline">Home</a>
        </li>
        <li class="flex items-center gap-2">
          <span class="text-text-muted/40">/</span>
          <a href="/blog/" class="text-text-muted hover:text-accent no-underline">Blog</a>
        </li>
        <li class="flex items-center gap-2">
          <span class="text-text-muted/40">/</span>
          <span class="text-text">#{tagLabel}</span>
        </li>
      </ol>
    </nav>

    <div class="max-w-3xl mb-12">
      <span class="inline-block px-3 py-1 bg-accent/10 text-accent text-xs font-bold rounded-full mb-4 border border-accent/20 uppercase tracking-wider">
        Tag
      </span>
      <h1 class="text-4xl md:text-5xl font-black mb-4">
        <span class="text-gradient-accent">#{tagLabel}</span>
      </h1>
      <p class="text-lg text-text-muted leading-relaxed">
        {page.data.length} post{page.data.length === 1 ? "" : "s"} tagged with "{tagLabel}".
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2">
      {page.data.map((post) => (
        <PostCard post={post} variant="default" />
      ))}
    </div>

    {(page.url.prev || page.url.next) && (
      <div class="mt-12 flex items-center justify-between gap-4">
        {page.url.prev ? (
          <a
            href={page.url.prev}
            class="inline-flex items-center gap-2 px-5 py-3 bg-bg-card border border-border rounded-lg text-sm font-semibold text-text-muted hover:text-accent hover:border-accent/40 transition-colors no-underline"
          >
            ← Newer
          </a>
        ) : <span />}
        <span class="text-sm text-text-muted">
          Page {page.currentPage} of {page.lastPage}
        </span>
        {page.url.next ? (
          <a
            href={page.url.next}
            class="inline-flex items-center gap-2 px-5 py-3 bg-bg-card border border-border rounded-lg text-sm font-semibold text-text-muted hover:text-accent hover:border-accent/40 transition-colors no-underline"
          >
            Older →
          </a>
        ) : <span />}
      </div>
    )}
  </section>
</BaseLayout>
