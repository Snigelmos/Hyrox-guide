---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HeroBackground from "../../components/HeroBackground.astro";
import eventsHero from "../../assets/heroes/events-hero.png";
import { EVENTS, getEventsByYear, formatEventDate, isPastEvent } from "../../data/events";
import { getResults } from "../../data/event-results";

const years = Array.from(new Set(EVENTS.map((e) => e.year))).sort();

// Most-recent completed races that already have a published recap. Surfaced
// at the top of the hub so the freshest indexable results pages get a direct
// internal link instead of being buried in the per-year "Race reports" lists.
const eventTime = (e: (typeof EVENTS)[number]) =>
  new Date(e.endDate ?? e.startDate).getTime();
const latestResults = EVENTS.filter(
  (e) => isPastEvent(e) && getResults(e.year, e.slug),
)
  .sort((a, b) => eventTime(b) - eventTime(a))
  .slice(0, 6);

const title = "Hyrox Events — Find Your Race by City and Year";
const description = "Every upcoming Hyrox race by city and year, with venue, date, and training resources specific to each event.";
---

<BaseLayout
  title={`${title} | Hyrox Vault`}
  description={description}
  ogType="article"
  schemaType="Article"
  breadcrumbs={[{ name: "Events" }]}
>
  <section class="relative overflow-hidden border-b border-border isolate bg-gradient-to-b from-accent/5 to-transparent">
    <HeroBackground image={eventsHero} position="object-center" textSide="left" priority dim />
    <div class="container-main py-16 md:py-20 relative z-10">
      <div class="max-w-2xl">
        <h1 class="text-4xl md:text-5xl font-black leading-tight text-gradient-accent">
          {title}
        </h1>
        <p class="mt-4 text-lg text-text-muted leading-relaxed">
          {description}
        </p>
      </div>
    </div>
  </section>

  <div class="container-main py-10 md:py-16">

    {latestResults.length > 0 && (
      <section class="mb-14">
        <div class="flex items-baseline justify-between flex-wrap gap-2 mb-6">
          <h2 class="text-2xl font-black text-text-heading">Latest results</h2>
          <span class="text-sm text-text-muted">Freshly published race recaps</span>
        </div>
        <div class="grid gap-3 md:grid-cols-2 lg:grid-cols-3">
          {latestResults.map((event) => (
            <a
              href={`/events/${event.year}/${event.slug}/results/`}
              class="block bg-gradient-to-br from-accent/10 via-bg-card to-bg-card border border-accent/30 rounded-xl p-5 hover:border-accent/50 hover:bg-bg-card-hover transition-all no-underline"
            >
              <div class="text-xs font-bold uppercase tracking-wider text-accent mb-1">{event.country} · {event.year}</div>
              <div class="text-lg text-text-heading font-bold mb-1">Hyrox {event.city}</div>
              <div class="text-sm text-text-muted mb-2">{formatEventDate(event.startDate, event.endDate)}</div>
              <div class="text-xs text-accent font-semibold">Podium, splits &amp; recap →</div>
            </a>
          ))}
        </div>
      </section>
    )}

    {years.map((year) => {
      const yearEvents = getEventsByYear(year);
      const upcoming = yearEvents.filter((e) => !isPastEvent(e));
      const past = yearEvents.filter((e) => isPastEvent(e));
      return (
        <section class="mb-14">
          <h2 class="text-2xl font-black text-text-heading mb-6">{year} Season</h2>

          {upcoming.length > 0 && (
            <div class="mb-8">
              <h3 class="text-sm font-bold uppercase tracking-wider text-text-muted mb-3">Upcoming races</h3>
              <div class="grid gap-3 md:grid-cols-2 lg:grid-cols-3">
                {upcoming.map((event) => (
                  <a
                    href={`/events/${event.year}/${event.slug}/`}
                    class="block bg-bg-card border border-border rounded-xl p-5 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline"
                  >
                    <div class="text-xs font-bold uppercase tracking-wider text-accent mb-1">{event.country}</div>
                    <div class="text-lg text-text-heading font-bold mb-1">Hyrox {event.city}</div>
                    <div class="text-sm text-text-muted">{formatEventDate(event.startDate, event.endDate)}</div>
                  </a>
                ))}
              </div>
            </div>
          )}

          {past.length > 0 && (
            <div>
              <h3 class="text-sm font-bold uppercase tracking-wider text-text-muted mb-3">Race reports</h3>
              <div class="grid gap-3 md:grid-cols-2 lg:grid-cols-3">
                {past.map((event) => {
                  const hasResults = !!getResults(event.year, event.slug);
                  return (
                    <a
                      href={hasResults
                        ? `/events/${event.year}/${event.slug}/results/`
                        : `/events/${event.year}/${event.slug}/`}
                      class="block bg-bg-card border border-border rounded-xl p-5 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline opacity-80"
                    >
                      <div class="flex items-center justify-between mb-2">
                        <div class="text-xs font-bold uppercase tracking-wider text-text-muted">{event.country}</div>
                        <div class="inline-flex items-center gap-1 text-xs font-semibold text-slate-400 bg-slate-500/10 border border-slate-500/20 rounded-full px-2 py-0.5">
                          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                          Race complete
                        </div>
                      </div>
                      <div class="text-lg text-text-heading font-bold mb-1">Hyrox {event.city}</div>
                      <div class="text-sm text-text-muted mb-2">{formatEventDate(event.startDate, event.endDate)}</div>
                      {hasResults ? (
                        <div class="text-xs text-accent font-semibold">View results →</div>
                      ) : (
                        <div class="text-xs text-text-muted/60">Results pending</div>
                      )}
                    </a>
                  );
                })}
              </div>
            </div>
          )}
        </section>
      );
    })}
  </div>
</BaseLayout>
