---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import LiveAthleteFinder from "../../../components/LiveAthleteFinder";
import RaceWeekPanel from "../../../components/RaceWeekPanel.astro";
import EventCourseSection from "../../../components/EventCourseSection.astro";
import {
  EVENTS,
  allEventPaths,
  allRetiredExplainerPaths,
  getRetiredExplainer,
  formatEventDate,
  isPastEvent,
  type HyroxEvent,
} from "../../../data/events";
import { getResults } from "../../../data/event-results";
import { getCityEvergreen } from "../../../data/city-evergreens";
import { getGymsByCity, hasIndexablePage } from "../../../data/gym-finder";
import {
  buildResultsHyroxUrl,
  isEventLiveNow,
  liveEventDayLabel,
} from "../../../lib/hyrox-live";
import {
  isRaceWeek,
  localRaceWeekTerms,
  raceWeekStatusLabel,
} from "../../../lib/race-week";

export async function getStaticPaths() {
  const activePaths = allEventPaths().map(({ year, slug }) => ({
    params: { year: String(year), city: slug },
    props: { kind: "active" as const, year, slug },
  }));
  const explainerPaths = allRetiredExplainerPaths().map(({ year, slug }) => ({
    params: { year: String(year), city: slug },
    props: { kind: "explainer" as const, year, slug },
  }));
  return [...activePaths, ...explainerPaths];
}

type Props =
  | { kind: "active"; year: number; slug: string }
  | { kind: "explainer"; year: number; slug: string };

const props = Astro.props as Props;

// ============================================================================
// EXPLAINER BRANCH — retired city with year-specific search demand
// ============================================================================
const explainer =
  props.kind === "explainer" ? getRetiredExplainer(props.year, props.slug) : null;
const explainerSubstituteEvents = explainer
  ? explainer.substitutes
      .map((s) => ({
        sub: s,
        event: EVENTS.find((e) => e.year === s.year && e.slug === s.slug),
      }))
      .filter((x): x is { sub: typeof explainer.substitutes[number]; event: HyroxEvent } => Boolean(x.event))
  : [];

// ============================================================================
// ACTIVE BRANCH — real event with full data
// ============================================================================
const event: HyroxEvent | null =
  props.kind === "active"
    ? EVENTS.find((e) => e.year === props.year && e.slug === props.slug) ?? null
    : null;
const isPast = event ? isPastEvent(event) : false;
const isLiveNow = event ? isEventLiveNow(event) : false;
const raceResults = event ? getResults(event.year, event.slug) : null;

// World Championship branch — flips the page from a generic Hyrox stop into a
// Worlds-aware experience. Triggered by `event.notes === "World Championship"`
// (set on the 2026 Stockholm entry; future Worlds editions inherit the same
// treatment by setting the same flag). When true, we lead with the head-term
// "Hyrox World Championships {year}" instead of "Hyrox {city} {year}", swap
// the plan-your-race grid for a qualified-athlete/spectator-aware version,
// add qualifying-paths and watch/follow sections, override the FAQ, and drop
// the fabricated `offers` schema block (Worlds is invitation-only).
const isWorldChampionship = event?.notes === "World Championship";

// Race-week capture state. We expand the title, description, and FAQ
// when the event is within the GSC-validated 14-days-out window so the
// page surfaces for queries like `hyrox helsinki 2026 schedule` and
// `hyrox helsinki 2026 aikataulu` without spinning up duplicate URLs.
const inRaceWeek = event ? isRaceWeek(event) : false;
const raceWeekTerms = event ? localRaceWeekTerms(event) : null;
const raceWeekStatus = event ? raceWeekStatusLabel(event) : null;

// Cross-link material — evergreen city guide + local gyms. Both are
// optional: only render the section when we actually have content, so
// we never advertise empty pages.
const cityEvergreen = event ? getCityEvergreen(event.slug) : null;
const localGyms = event
  ? getGymsByCity(cityEvergreen?.citySlug ?? event.slug)
      .filter(hasIndexablePage)
      .slice(0, 6)
  : [];

// Lightweight projection passed to the React island so it doesn't import the
// full HyroxEvent shape. Only used when the event is currently live.
const finderEvents = event && isLiveNow
  ? [
      {
        slug: event.slug,
        year: event.year,
        city: event.city,
        country: event.country,
        searchUrl: buildResultsHyroxUrl(event),
        startDate: event.startDate,
        endDate: event.endDate ?? event.startDate,
      },
    ]
  : [];
const liveDayLabel = event && isLiveNow ? liveEventDayLabel(event) : "";

// Shared values for layout
const year = props.year;
const slug = props.slug;

// Active-event computed values (only meaningful when event !== null).
const sponsorPrefix = event?.sponsor ? `${event.sponsor} ` : "";
const localNamesList = event?.localNames?.length
  ? event.localNames.join(" / ")
  : "";
const cityWithLocalNames = event
  ? localNamesList
    ? `${event.city} (${localNamesList})`
    : event.city
  : "";
const activeTitle = event
  ? inRaceWeek && !isPast
    ? // Race-week title — captures schedule/start-list/live queries (incl.
      // local-language synonyms via the H2/FAQ inside the page).
      isLiveNow
      ? isWorldChampionship
        ? `Hyrox World Championships ${year} Live — ${event.city} Track Athletes & Start List`
        : `Hyrox ${event.city} ${year} Live — Track Athletes, Schedule, Start List`
      : isWorldChampionship
        ? `Hyrox World Championships ${year} — Schedule, Start List & Live Tracker (${event.city}, ${formatEventDate(event.startDate, event.endDate)})`
        : `Hyrox ${event.city} ${year} — Schedule, Start List & Live Tracker (${formatEventDate(event.startDate, event.endDate)})`
    : isWorldChampionship
      ? // Lead with the head term so we rank for "Hyrox World Championships
        // 2026" / "Hyrox Worlds 2026" before the city qualifier. The ${year}
        // page still owns "Hyrox Stockholm 2026" via the H1, body, and FAQ.
        `Hyrox World Championships ${year} — ${event.city} Schedule, Divisions & Qualifying (${formatEventDate(event.startDate, event.endDate)})`
      : `Hyrox ${cityWithLocalNames} ${year} — ${formatEventDate(event.startDate, event.endDate)}`
  : "";
const activeDescription = event
  ? isPast
    ? isWorldChampionship
      ? `The ${year} Hyrox World Championships at ${event.venue}, ${event.city} — race report, ${formatEventDate(event.startDate, event.endDate)}. ${raceResults ? `${raceResults.totalAthletes?.toLocaleString() ?? "The qualified"} athletes contested the season's premier event. Elite 15 finals, age-group worlds, full podium and takeaways.` : "Elite 15 finals, age-group worlds, and full podium recap."}`
      : `Hyrox ${event.city} ${year}${localNamesList ? ` (Hyrox ${localNamesList} ${year})` : ""} race report — ${formatEventDate(event.startDate, event.endDate)} at ${event.venue}. ${raceResults ? `${raceResults.totalAthletes?.toLocaleString() ?? "Thousands of"} athletes competed. Full podium, results, and key takeaways.` : "Full results and recap."}`
    : inRaceWeek
      ? isWorldChampionship
        ? `The ${year} Hyrox World Championships at ${event.venue}, ${event.city}, ${formatEventDate(event.startDate, event.endDate)}. Schedule${raceWeekTerms?.isLocalised ? ` (${raceWeekTerms.schedule})` : ""}, Elite 15 finals start list, live tracker, and spectator info for the season's premier event.`
        : `Hyrox ${event.city} ${year} race weekend at ${event.venue}, ${formatEventDate(event.startDate, event.endDate)}. Race-day schedule${raceWeekTerms?.isLocalised ? ` (${raceWeekTerms.schedule})` : ""}, start list, live tracker for every wave, and spectator info — everything you need ahead of Hyrox ${event.country} ${year}.`
      : event.confirmed
        ? isWorldChampionship
          ? `The ${year} Hyrox World Championships run ${formatEventDate(event.startDate, event.endDate)} at ${event.venue}, ${event.city}. Qualified-only field, Elite 15 finals, age-group worlds, divisions, schedule, and how to follow live.`
          : `${sponsorPrefix}Hyrox ${event.city} ${year}${localNamesList ? ` (Hyrox ${localNamesList} ${year})` : ""} runs ${formatEventDate(event.startDate, event.endDate)} at ${event.venue}. Race format, divisions, training prep, and travel info.`
        : `Hyrox ${event.city} ${year}${localNamesList ? ` (Hyrox ${localNamesList} ${year})` : ""} expected ${formatEventDate(event.startDate, event.endDate)} at ${event.venue}. Indicative date pending official confirmation. Get prep guidance and pacing strategy.`
  : "";

const activeBreadcrumbs = event
  ? [
      { name: "Events", url: "/events/" },
      { name: String(year), url: `/events/${year}/` },
      { name: event.city },
    ]
  : [];

const startIso = event?.startDate ?? "";
const endIso = event?.endDate ?? event?.startDate ?? "";
const validUntilIso = endIso;

const eventSchema = event
  ? {
      "@context": "https://schema.org",
      "@type": "SportsEvent",
      name: `${sponsorPrefix}Hyrox ${event.city} ${year}`,
      description: activeDescription,
      startDate: startIso,
      endDate: endIso,
      eventStatus: isPast
        ? "https://schema.org/EventCompleted"
        : event.confirmed
          ? "https://schema.org/EventScheduled"
          : "https://schema.org/EventPostponed",
      eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
      sport: "Hyrox",
      location: {
        "@type": "Place",
        name: event.venue,
        address: {
          "@type": "PostalAddress",
          addressLocality: event.city,
          addressCountry: event.countryCode,
        },
      },
      organizer: {
        "@type": "Organization",
        name: "Hyrox",
        url: "https://hyrox.com/",
      },
      ...(event.officialUrl ? { url: event.officialUrl } : {}),
      ...(event.sponsor
        ? {
            sponsor: {
              "@type": "Organization",
              name: event.sponsor,
            },
          }
        : {}),
      // Skip the `offers` block for World Championships — registration is
      // invitation-only post-qualifying, so a public price/availability
      // offer would be fabricated commercial schema (a quality-signal
      // violation per Google's structured-data guidelines).
      ...(isWorldChampionship
        ? {}
        : {
            offers: {
              "@type": "Offer",
              url: event.registrationUrl ?? event.officialUrl,
              priceCurrency: "EUR",
              price: "139",
              availability: "https://schema.org/LimitedAvailability",
              validFrom: "2025-09-01",
              validThrough: validUntilIso,
            },
          }),
    }
  : null;

const activeFaqItems = event
  ? isWorldChampionship
    ? [
        // World Championship FAQ — replaces the generic event FAQ. The
        // schema serialiser only emits questions that are visibly rendered,
        // which is why we branch the dataset rather than mixing both.
        {
          question: isPast
            ? `When and where was the Hyrox World Championship ${year}?`
            : `When and where is the Hyrox World Championship ${year}?`,
          answer: isPast
            ? `The ${year} Hyrox World Championships took place ${formatEventDate(event.startDate, event.endDate)} at ${event.venue} in ${event.city}, ${event.country} — also searched for as Hyrox VM ${year}, Hyrox Worlds ${year}, and Hyrox World Champs ${year}.`
            : `The ${year} Hyrox World Championships run ${formatEventDate(event.startDate, event.endDate)} at ${event.venue} in ${event.city}, ${event.country} — also searched for as Hyrox VM ${year}, Hyrox Worlds ${year}, and Hyrox World Champs ${year}.`,
        },
        {
          question: `Who races at the Hyrox World Championship?`,
          answer: `Only qualified athletes — there is no Open division at the Hyrox World Championships. The field is made up of age-group winners from regional Open events, athletes who hit the published Pro qualifying time for their age group, and the Elite 15 (the top 15 Pro athletes per division on the season ranking points board). Age-group, Pro Singles, Pro Doubles, and Adaptive divisions all race across the four-day weekend.`,
        },
        {
          question: `Can I still enter Hyrox ${event.city} ${year}?`,
          answer: `No — Hyrox World Championship entry is invitation-only. You qualify by either winning your age group at a regional Hyrox Open event, hitting the Pro qualifying time, or earning a top-15 spot in your Pro division on season ranking points. Once you qualify, Hyrox emails an invitation with a registration link. There are no general-public entries on sale.`,
        },
        {
          question: `What is the Hyrox Elite 15?`,
          answer: `The Elite 15 is the championship-division finals at the Hyrox World Championship. The top 15 athletes per Pro division (Pro Men, Pro Women, Pro Doubles Men, Pro Doubles Women) qualify based on season-ranking points and race in a head-to-head finals format. Typical Pro Men podium times are sub-55, Pro Women sub-65.`,
        },
        {
          question: `How do I qualify for the next Hyrox World Championship?`,
          answer: `Three paths: (1) win your age group at a regional Hyrox Open Singles event, (2) hit the published Pro qualifying time for your age group at any Open event, or (3) finish in the top 15 of your Pro division on the season ranking points board. Full thresholds and event-by-event detail are on our qualifiers hub.`,
        },
        {
          question: `Where can I watch the Hyrox World Championship ${year}?`,
          answer: `Hyrox typically streams the World Championship finals on hyrox.com/live and the official Hyrox YouTube channel. The full broadcast schedule is published a few days before race weekend. Spectator tickets to ${event.venue} are sold separately via the official event page when available — race-day tickets often sell out.`,
        },
        {
          question: `Why is the Hyrox World Championship in ${event.city}?`,
          answer: `Hyrox rotates the World Championship between flagship cities each season. Stockholm hosts the ${year} edition at ${event.venue} (formerly Friends Arena), a 50,000-seat football stadium that becomes the largest indoor floor on the entire Hyrox calendar. The previous and next host cities are confirmed on the official Hyrox season calendar.`,
        },
        // Race-week additions for Worlds — same shape as the standard
        // event variant, so the FAQPage schema stays accurate when these
        // questions are rendered.
        ...(inRaceWeek && !isPast
          ? [
              {
                question: `What's the schedule for Hyrox World Championships ${year}?`,
                answer: `Hyrox publishes the official wave-by-wave Worlds schedule in the Hyrox app and on results.hyrox.com about 7-10 days before race weekend. ${event.city} runs across four days: age-group and Pro Singles fill the front of the weekend, Doubles and Adaptive land mid-weekend, with the Elite 15 head-to-head finals typically anchoring the final day at ${event.venue}.`,
              },
              {
                question: `Where can I find the Hyrox World Championships ${year} start list?`,
                answer: `The official start list goes live on results.hyrox.com a few days before race weekend. Open the season's event list, pick Hyrox World Championships ${year}, then switch to the Start List tab to see every qualified athlete's bib number, division, and wave. If the list isn't published yet, save names to your live-tracker watchlist on /live/ so they're ready the moment timing opens.`,
              },
              {
                question: `How do I follow the Hyrox World Championships ${year} live?`,
                answer: `Splits land on the official Hyrox timing system within seconds of each athlete crossing a station timing mat. Use the live tracker on /live/ to search by name, team, or bib — HyroxVault renders splits, station times, and share links locally on the page. Hyrox typically broadcasts the Elite 15 finals separately on hyrox.com/live and YouTube; the broadcast schedule lands a few days out.`,
              },
            ]
          : []),
      ]
    : [
      {
        question: isPast
          ? `When was Hyrox ${event.city} ${year}?`
          : `When is Hyrox ${event.city} ${year}?`,
        answer: isPast
          ? `Hyrox ${event.city} ${year} took place ${formatEventDate(event.startDate, event.endDate)} at ${event.venue}.${localNamesList ? ` The race is also known locally as Hyrox ${localNamesList} ${year}.` : ""}${raceResults?.totalAthletes ? ` ${raceResults.totalAthletes.toLocaleString()} athletes competed.` : ""}`
          : event.confirmed
            ? `Hyrox ${event.city} ${year} runs ${formatEventDate(event.startDate, event.endDate)} at ${event.venue}.${localNamesList ? ` The race is also known locally as Hyrox ${localNamesList} ${year}.` : ""}`
            : `Hyrox ${event.city} ${year} is expected around ${formatEventDate(event.startDate, event.endDate)} at ${event.venue}, based on previous seasons. Always verify dates on the official Hyrox schedule before booking travel.`,
      },
      {
        question: `Where is the Hyrox ${event.city} ${year} venue?`,
        answer: `The event is held at ${event.venue} in ${event.city}, ${event.country}. Public transport is almost always the fastest option — parking around major expo centres sells out race weekend.`,
      },
      {
        question: `How do I register for Hyrox ${event.city} ${year}?`,
        answer: `Registration opens on the official Hyrox website (link below). Most major Hyrox stops sell out 4-8 weeks before race day. Early-bird pricing typically saves €20-30 vs late entry.`,
      },
      {
        question: `What divisions does Hyrox ${event.city} offer?`,
        answer: `Standard divisions are: ${(event.divisions ?? ["Open", "Pro", "Doubles", "Doubles Mixed", "Relay"]).join(", ")}. All divisions race the same 8 functional stations and 8 km of running, with weights varying by division.`,
      },
      {
        question: `How early should I arrive for Hyrox ${event.city}?`,
        answer:
          "Arrive at the venue 90 minutes before your start wave. This gives you time to check in, warm up, and drop your bag. Waves run every 10 minutes across the full event day, so missing your slot means losing your entry.",
      },
      {
        question: `How do I train for Hyrox ${event.city}?`,
        answer:
          "Follow an 8–12 week structured plan that covers running, sled work, and high-rep wall balls. Most first-timers underestimate how much running matters — 8 km of running under fatigue is the single biggest time variable.",
      },
      // Race-week FAQ block — only added inside the 14-day capture window so
      // the schema matches what's actually rendered on the page (Schema.org
      // FAQPage requires every Q&A to be visible).
      ...(inRaceWeek && !isPast
        ? [
            {
              question: raceWeekTerms?.isLocalised
                ? `What's the schedule (${raceWeekTerms.schedule}) for Hyrox ${event.city} ${year}?`
                : `What's the schedule for Hyrox ${event.city} ${year}?`,
              answer: `Hyrox publishes the official wave-by-wave race-day schedule in the Hyrox app and on results.hyrox.com about 7-10 days before race weekend. The standard race-day shape is: doors open ~90 minutes before the first wave, Pro/Elite waves go off first, and a new ~70-athlete wave leaves every 8-10 minutes through the day until the final Open wave clears Wall Balls. Awards typically run late afternoon at ${event.venue}.`,
            },
            {
              question: raceWeekTerms?.isLocalised
                ? `Where can I find the Hyrox ${event.city} ${year} start list (${raceWeekTerms.startList})?`
                : `Where can I find the Hyrox ${event.city} ${year} start list?`,
              answer: `The official start list goes live on results.hyrox.com a few days before the race. Open the season's event list, pick Hyrox ${event.city} ${year}, then switch to the Start List tab to see every athlete's bib number and wave assignment. If the list isn't published yet, save the athlete's name to your live-tracker watchlist on /live/ so it's ready the moment timing opens.`,
            },
            {
              question: `How do I follow Hyrox ${event.city} ${year} live?`,
              answer: `Splits land on the official Hyrox timing system within seconds of each athlete or team crossing a station timing mat. Use the live tracker on /live/ to search by name, team name, or bib — HyroxVault renders the dashboard locally on the page, including run splits, station splits, and share links. Typical Open finishers are on the floor for 75-110 minutes, so you can usually catch a full race in one sitting.`,
            },
          ]
        : []),
      // Year-round localised FAQ — added for non-English markets regardless
      // of race-week status. Captures evergreen queries like
      // `hyrox finland tulokset`, `hyrox madrid inscripción`, `hyrox 인천 결과`.
      // These three questions are stable evergreen content, so we render
      // them every day of the year (the schema stays accurate because the
      // text below renders too).
      ...(raceWeekTerms?.isLocalised
        ? [
            {
              question: `Is Hyrox ${event.country} ${year} the same as Hyrox ${event.city} ${year}?`,
              answer: `Yes — Hyrox ${event.city} ${year} is the ${year} Hyrox stop in ${event.country}, so any "Hyrox ${event.country} ${year}" search refers to the ${formatEventDate(event.startDate, event.endDate)} race at ${event.venue}.${localNamesList ? ` Locally the race is also called Hyrox ${localNamesList} ${year}.` : ""}`,
            },
            isPast
              ? {
                  question: `Where can I find the Hyrox ${event.city} ${year} results (${raceWeekTerms.results})?`,
                  answer: `Official Hyrox ${event.city} ${year} results (${raceWeekTerms.results}) are published on results.hyrox.com under the season event list. Open the ${year} season, pick Hyrox ${event.city}, then filter by division (Open, Pro, Doubles, Mixed, Relay) and age group. Our /events/${year}/${event.slug}/results/ page mirrors the podium and key takeaways so you can compare splits without leaving the site.`,
                }
              : {
                  question: `How do I register (${raceWeekTerms.register}) for Hyrox ${event.city} ${year}?`,
                  answer: `Registration (${raceWeekTerms.register}) for Hyrox ${event.city} ${year} is on the official Hyrox website (hyrox.com). Most stops sell out 4-8 weeks before race day, and early-bird pricing typically saves €20-30 vs late entry. Doubles and Relay categories sell out earliest; Open Singles last. The race is at ${event.venue} on ${formatEventDate(event.startDate, event.endDate)}.`,
                },
          ]
        : []),
    ]
  : [];

const otherEventsInYear = event
  ? EVENTS.filter((e) => e.year === year && e.slug !== event.slug).slice(0, 9)
  : [];

// Pull the top podium entry from the marquee divisions so the city page
// can surface "this is who won" without bouncing the user to /results/.
function findWinner(divisionMatchers: string[]) {
  if (!raceResults) return undefined;
  for (const matcher of divisionMatchers) {
    const d = raceResults.divisions.find((x) =>
      x.division.toLowerCase().includes(matcher),
    );
    if (d?.podium?.[0]) return { division: d.division, ...d.podium[0] };
  }
  return undefined;
}
const proMenWinner = event ? findWinner(["pro men", "elite 15 men", "men"]) : undefined;
const proWomenWinner = event ? findWinner(["pro women", "elite 15 women", "women"]) : undefined;

// Explainer computed values
const explainerCityHeadline = explainer
  ? explainer.localCity
    ? `${explainer.city} (${explainer.localCity})`
    : explainer.city
  : "";
const explainerTitle = explainer
  ? `Hyrox ${explainer.localCity ?? explainer.city} ${year}: Not on the Calendar`
  : "";
const explainerDescription = explainer
  ? `Hyrox ${explainer.city} ${year} is not on the official Hyrox calendar. Closest substitute races, training options, and what to do if you searched for a Hyrox in ${explainer.city}.`
  : "";
const explainerBreadcrumbs = explainer
  ? [
      { name: "Events", url: "/events/" },
      { name: String(year), url: `/events/${year}/` },
      { name: explainer.city },
    ]
  : [];
const explainerFaqItems = explainer
  ? [
      {
        question: `Is Hyrox ${explainer.localCity ?? explainer.city} ${year} happening?`,
        answer: `Hyrox ${explainer.localCity ?? explainer.city} ${year} is not on the official Hyrox calendar. ${explainer.intro[0]}`,
      },
      {
        question: `What is the closest Hyrox to ${explainer.city} in ${year}?`,
        answer: explainer.substitutes.length
          ? `The closest Hyrox races to ${explainer.city} on the ${year} calendar are: ${explainer.substitutes.map((s) => `Hyrox ${s.city} ${s.year}`).join(", ")}. ${explainer.substitutes[0].note}`
          : `There are no nearby Hyrox stops on the ${year} calendar. Check hyrox.com for the latest schedule.`,
      },
      {
        question: `Will Hyrox return to ${explainer.city}?`,
        answer: `Hyrox stops rotate year to year. ${explainer.city} has hosted Hyrox in past seasons and may return on future calendars. Always confirm on the official Hyrox schedule before booking travel.`,
      },
    ]
  : [];
---

{props.kind === "active" && event && (
<BaseLayout
  title={`${activeTitle} | Hyrox Vault`}
  description={activeDescription}
  ogType="article"
  schemaType="Article"
  breadcrumbs={activeBreadcrumbs}
  faqItems={activeFaqItems}
>
  <div class="container-main py-10 md:py-16">
    <nav class="mb-8 text-sm" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 flex-wrap">
        <li><a href="/" class="text-text-muted hover:text-accent transition-colors no-underline">Home</a></li>
        <li class="flex items-center gap-2">
          <span class="text-text-muted/40">/</span>
          <a href="/events/" class="text-text-muted hover:text-accent transition-colors no-underline">Events</a>
        </li>
        <li class="flex items-center gap-2">
          <span class="text-text-muted/40">/</span>
          <a href={`/events/${year}/`} class="text-text-muted hover:text-accent transition-colors no-underline">{year}</a>
        </li>
        <li class="flex items-center gap-2">
          <span class="text-text-muted/40">/</span>
          <span class="text-text">{event.city}</span>
        </li>
      </ol>
    </nav>

    <header class="mb-10 pb-8 border-b border-border">
      {isWorldChampionship && (
        <div class="inline-flex items-center gap-2 bg-amber-400/10 border border-amber-400/30 rounded-full px-4 py-1.5 text-xs font-black uppercase tracking-[0.18em] text-amber-300 mb-4">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 15a3 3 0 100-6 3 3 0 000 6z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19.5 12a7.5 7.5 0 11-15 0 7.5 7.5 0 0115 0zM8 21l1.5-4.5M16 21l-1.5-4.5" /></svg>
          World Championship · {event.city} {year}
        </div>
      )}
      <h1 class="text-4xl md:text-5xl font-black leading-tight text-gradient-accent">
        {isWorldChampionship ? `Hyrox World Championships ${year}` : `Hyrox ${event.city} ${year}`}
      </h1>
      {isWorldChampionship ? (
        <p class="mt-2 text-base text-text-muted/80 leading-relaxed">
