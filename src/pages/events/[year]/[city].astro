          <a href="/events/" class="text-text-muted hover:text-accent transition-colors no-underline">Events</a>
        </li>
        <li class="flex items-center gap-2">
          <span class="text-text-muted/40">/</span>
          <a href={`/events/${year}/`} class="text-text-muted hover:text-accent transition-colors no-underline">{year}</a>
        </li>
        <li class="flex items-center gap-2">
