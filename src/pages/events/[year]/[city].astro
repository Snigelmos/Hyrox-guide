                <div class="bg-bg-card-hover border border-border rounded-xl p-4">
                  <div class="text-xs font-bold uppercase tracking-wider text-accent mb-1">{proWomenWinner.division} winner</div>
                  <div class="text-lg font-black text-text-heading leading-tight">{proWomenWinner.athlete}</div>
                  <div class="text-2xl font-black font-mono text-accent mt-1">{proWomenWinner.time}</div>
                  {proWomenWinner.country && <div class="text-xs text-text-muted mt-1">{proWomenWinner.country}</div>}
                </div>
              )}
            </div>
          )}

          <div class="flex flex-wrap gap-3">
            <a href={`/events/${year}/${event.slug}/results/`} class="inline-flex items-center gap-2 bg-accent text-white font-bold text-sm rounded-xl px-5 py-2.5 hover:opacity-90 transition-opacity no-underline">
              {raceResults ? "Read the race report →" : "Results page →"}
            </a>
            {event.resultsUrl && (
              <a href={event.resultsUrl} rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-bg-card border border-border text-text font-semibold text-sm rounded-xl px-5 py-2.5 hover:border-accent/40 transition-colors no-underline">
                Official leaderboard ↗
              </a>
            )}
          </div>
        </div>
      ) : (
        <>
          <h2>After the race</h2>
          <p>
            Race results are typically posted on hyrox.com within 24–48 hours of the final wave. We publish a full <a href={`/events/${year}/${event.slug}/results/`}>Hyrox {event.city} {year} results recap</a> the Monday after the event with finish-time histograms, podiums, and key takeaways for next year.
          </p>
        </>
      )}
    </section>

    {/* Local Hyrox-affiliated training gyms + evergreen city-guide
        cross-link. Only renders for cities where we have curated gyms
        or an evergreen page — never advertises empty content. */}
    {(localGyms.length > 0 || cityEvergreen) && (
      <section class="mt-16 pt-10 border-t border-border">
        <h2 class="text-2xl font-black text-text-heading mb-2">
          Train for Hyrox {event.city} locally
        </h2>
        <p class="text-text-muted mb-6 max-w-3xl">
          {localGyms.length > 0
            ? `Hyrox-affiliated training clubs near ${event.venue} — most run dedicated Hyrox classes through the build-up to race weekend.`
            : `Use the ${event.city} city guide for the local training-club ecosystem, race history, and pacing notes that don't change between years.`}
        </p>
        {localGyms.length > 0 && (
          <div class="grid gap-3 md:grid-cols-2 lg:grid-cols-3 mb-6 not-prose">
            {localGyms.map((gym) => (
              <a
                href={`/gyms/g/${gym.slug}/`}
                class="block bg-bg-card border border-border rounded-xl p-4 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline"
              >
                <div class="text-xs font-bold uppercase tracking-wider text-accent mb-1">
                  {gym.neighbourhood ?? gym.city}
                </div>
                <div class="text-base text-text-heading font-bold mb-1 leading-tight">
                  {gym.name}
                </div>
                <div class="text-xs text-text-muted">
                  {gym.affiliationType === "official-training-club"
                    ? "Official Hyrox training club"
                    : gym.affiliationType === "chain-partner"
                      ? "Hyrox chain partner"
                      : gym.affiliationType === "crossfit-box"
                        ? "CrossFit box"
                        : "Boutique studio"}
                </div>
              </a>
            ))}
          </div>
        )}
        <div class="flex flex-wrap gap-3">
          {cityEvergreen && (
            <a href={`/hyrox/${cityEvergreen.slug}/`} class="inline-flex items-center gap-1.5 bg-accent text-bg font-bold text-sm rounded-xl px-5 py-2.5 hover:bg-accent/90 transition-colors no-underline">
              Hyrox {event.city} city guide →
            </a>
          )}
          {localGyms.length > 0 && (
            <a href={`/gyms/${cityEvergreen?.citySlug ?? event.slug}/`} class="inline-flex items-center gap-1.5 bg-bg-card border border-border text-text font-semibold text-sm rounded-xl px-5 py-2.5 hover:border-accent/40 transition-colors no-underline">
              All {event.city} Hyrox gyms →
            </a>
          )}
        </div>
      </section>
    )}

    <aside class="mt-16 pt-10 border-t border-border">
      <h2 class="text-2xl font-black text-text-heading mb-4">Other Hyrox races in {year}</h2>
      <div class="grid gap-3 md:grid-cols-2 lg:grid-cols-3 not-prose">
        {otherEventsInYear.map((e) => {
          const eIsPast = isPastEvent(e);
          return (
            <a
              href={`/events/${e.year}/${e.slug}/`}
              class={`block bg-bg-card border border-border rounded-xl p-4 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline${eIsPast ? " opacity-75" : ""}`}
            >
              <div class="flex items-center justify-between mb-1">
                <div class={`text-xs font-bold uppercase tracking-wider ${eIsPast ? "text-text-muted" : "text-accent"}`}>{e.country}</div>
                {eIsPast && (
                  <div class="inline-flex items-center gap-1 text-xs text-slate-400">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                    Done
                  </div>
                )}
              </div>
              <div class="text-sm text-text-heading font-bold">{e.city}</div>
              <div class="text-xs text-text-muted mt-1">{formatEventDate(e.startDate, e.endDate)}</div>
            </a>
          );
        })}
      </div>
    </aside>
  </div>

  {eventSchema && <script type="application/ld+json" set:html={JSON.stringify(eventSchema)} slot="head" />}
</BaseLayout>
)}

{props.kind === "explainer" && explainer && (
<BaseLayout
  title={`${explainerTitle} | Hyrox Vault`}
  description={explainerDescription}
  ogType="article"
  schemaType="Article"
  breadcrumbs={explainerBreadcrumbs}
  faqItems={explainerFaqItems}
>
  <div class="container-main py-10 md:py-16">
    <nav class="mb-8 text-sm" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 flex-wrap">
        <li><a href="/" class="text-text-muted hover:text-accent transition-colors no-underline">Home</a></li>
        <li class="flex items-center gap-2">
          <span class="text-text-muted/40">/</span>
          <a href="/events/" class="text-text-muted hover:text-accent transition-colors no-underline">Events</a>
        </li>
        <li class="flex items-center gap-2">
          <span class="text-text-muted/40">/</span>
          <a href={`/events/${year}/`} class="text-text-muted hover:text-accent transition-colors no-underline">{year}</a>
        </li>
        <li class="flex items-center gap-2">
          <span class="text-text-muted/40">/</span>
          <span class="text-text">{explainer.city}</span>
        </li>
      </ol>
    </nav>

    <header class="mb-10 pb-8 border-b border-border">
      <div class="inline-flex items-center gap-2 bg-amber-500/10 border border-amber-500/30 rounded-full px-4 py-1.5 text-xs font-bold uppercase tracking-wider text-amber-400 mb-4">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01M5.636 5.636L18.364 18.364M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        Not on the {year} calendar
      </div>
      <h1 class="text-4xl md:text-5xl font-black leading-tight text-gradient-accent">
        Hyrox {explainerCityHeadline} {year}
      </h1>
      <p class="mt-4 text-lg text-text-muted leading-relaxed max-w-2xl">
        Hyrox {explainer.localCity ?? explainer.city} {year} is not on the official Hyrox calendar. Below: closest substitute races, training options, and where to follow if Hyrox returns to {explainer.city}.
      </p>
    </header>

    <section class="prose md:prose-lg max-w-none mb-10">
      {explainer.intro.map((p) => <p>{p}</p>)}
    </section>

    {explainerSubstituteEvents.length > 0 && (
      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-black text-text-heading mb-2">Closest Hyrox races to {explainer.city} in {year}</h2>
        <p class="text-text-muted mb-6 max-w-3xl">Race the closest Hyrox on the {year} calendar instead. Open any city for full event details, venue, and registration.</p>
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {explainerSubstituteEvents.map(({ sub, event: subEvent }) => (
            <a
              href={`/events/${subEvent.year}/${subEvent.slug}/`}
              class="block bg-bg-card border border-border rounded-2xl p-5 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline"
            >
              <div class="text-xs font-bold uppercase tracking-wider text-accent mb-1">{subEvent.country}</div>
              <div class="text-lg font-black text-text-heading mb-1">Hyrox {subEvent.city} {subEvent.year}</div>
              <div class="text-xs text-text-muted mb-2">{formatEventDate(subEvent.startDate, subEvent.endDate)} · {subEvent.venue}</div>
              <div class="text-sm text-text-muted leading-relaxed">{sub.note}</div>
            </a>
          ))}
        </div>
      </section>
    )}

    {explainer.evergreenCitySlug && (
      <section class="mb-12 bg-bg-card border border-border rounded-2xl p-6">
        <div class="text-xs font-bold uppercase tracking-wider text-accent mb-2">Hyrox in {explainer.city}</div>
        <h2 class="text-xl md:text-2xl font-black text-text-heading mb-3">Evergreen guide to Hyrox {explainer.city}</h2>
        <p class="text-text-muted leading-relaxed mb-4">
          The local training-club ecosystem, race history, and venue notes don't change just because the calendar moves. Use the evergreen city guide to find Hyrox-affiliated training clubs in {explainer.city} and follow when the race returns.
        </p>
        <a href={`/hyrox/${explainer.evergreenCitySlug}/`} class="inline-flex items-center gap-2 bg-accent text-white font-bold text-sm rounded-xl px-5 py-2.5 hover:opacity-90 transition-opacity no-underline">
          Open the Hyrox {explainer.city} guide →
        </a>
      </section>
    )}

    <section class="prose md:prose-lg max-w-none mb-10">
      <h2>How to train for Hyrox without a home race</h2>
      <p>
        If your home city isn't on the calendar, the build-up looks the same as any other Hyrox cycle: 8 to 16 weeks of running, sled work, and high-rep wall balls. The only adjustment is that race weekend includes travel. Most athletes plan one final long-haul training session 10-14 days out, then taper and travel.
      </p>
      <ul>
        <li>Use the <a href="/calculator/">Hyrox time calculator</a> to set a realistic finish target.</li>
        <li>Browse <a href="/training-plans/">structured training plans</a> by goal time and experience level.</li>
        <li>Check the <a href={`/gyms/${explainer.evergreenCitySlug ?? explainer.city.toLowerCase()}/`}>{explainer.city} gym directory</a> for local Hyrox-affiliated training clubs.</li>
        <li>Read the <a href="/blog/hyrox-race-week-protocol/">race-week taper protocol</a> for the final 7 days before any away race.</li>
      </ul>

      <h2>Other Hyrox races in {year}</h2>
      <p>
        See the full <a href={`/events/${year}/`}>Hyrox {year} calendar</a> for every race city, venue, and date. The calendar covers all confirmed stops globally.
      </p>
    </section>
  </div>
</BaseLayout>
)}
