---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { EVENTS, getEventsByYear, formatEventDate, isPastEvent } from "../../../data/events";
import { getResults } from "../../../data/event-results";

export async function getStaticPaths() {
  const years = Array.from(new Set(EVENTS.map((e) => e.year)));
  return years.map((year) => ({
    params: { year: String(year) },
    props: { year },
  }));
}

const { year } = Astro.props;
const yearEvents = getEventsByYear(year);
const upcoming = yearEvents.filter((e) => !isPastEvent(e));
const past = yearEvents.filter((e) => isPastEvent(e));

const title = `Hyrox ${year} Events Calendar`;
const description = `Every confirmed Hyrox ${year} race by city and date, with venue details, registration links, and training resources for each event.`;
---

<BaseLayout
  title={`${title} | Hyrox Vault`}
  description={description}
  ogType="website"
  schemaType="CollectionPage"
  breadcrumbs={[
    { name: "Events", url: "/events/" },
    { name: String(year) },
  ]}
>
  <div class="container-main py-10 md:py-16">
    <nav class="mb-8 text-sm" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 flex-wrap">
        <li><a href="/" class="text-text-muted hover:text-accent transition-colors no-underline">Home</a></li>
        <li class="flex items-center gap-2">
          <span class="text-text-muted/40">/</span>
          <a href="/events/" class="text-text-muted hover:text-accent transition-colors no-underline">Events</a>
        </li>
        <li class="flex items-center gap-2">
          <span class="text-text-muted/40">/</span>
          <span class="text-text">{year}</span>
        </li>
      </ol>
    </nav>

    <header class="mb-10 pb-8 border-b border-border">
      <h1 class="text-4xl md:text-5xl font-black leading-tight text-gradient-accent">
        {title}
      </h1>
      <p class="mt-4 text-lg text-text-muted leading-relaxed max-w-2xl">
        {description}
      </p>
    </header>

    {upcoming.length > 0 && (
      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-black text-text-heading mb-2">Upcoming Hyrox {year} races</h2>
        <p class="text-text-muted mb-6 max-w-3xl">
          Click any city to open the full event page with venue details, training resources, and registration links.
        </p>
        <div class="grid gap-3 md:grid-cols-2 lg:grid-cols-3">
          {upcoming.map((event) => (
            <a
              href={`/events/${event.year}/${event.slug}/`}
              class="block bg-bg-card border border-border rounded-xl p-5 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline"
            >
              <div class="text-xs font-bold uppercase tracking-wider text-accent mb-1">{event.country}</div>
              <div class="text-lg text-text-heading font-bold mb-1">Hyrox {event.city}</div>
              <div class="text-sm text-text-muted">{formatEventDate(event.startDate, event.endDate)}</div>
              <div class="text-xs text-text-muted mt-2 opacity-70">{event.venue}</div>
            </a>
          ))}
        </div>
      </section>
    )}

    {past.length > 0 && (
      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-black text-text-heading mb-2">Race reports — {year} completed events</h2>
        <p class="text-text-muted mb-6 max-w-3xl">
          These races have already taken place. Click any event to read the full race report with podium results, participant numbers, and key takeaways.
        </p>
        <div class="grid gap-3 md:grid-cols-2 lg:grid-cols-3">
          {past.map((event) => {
            const hasResults = !!getResults(event.year, event.slug);
            return (
              <a
                href={`/events/${event.year}/${event.slug}/`}
                class="block bg-bg-card border border-border rounded-xl p-5 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline opacity-80"
              >
                <div class="flex items-center justify-between mb-2">
                  <div class="text-xs font-bold uppercase tracking-wider text-text-muted">{event.country}</div>
                  <div class="inline-flex items-center gap-1 text-xs font-semibold text-slate-400 bg-slate-500/10 border border-slate-500/20 rounded-full px-2 py-0.5">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                    Race complete
                  </div>
                </div>
                <div class="text-lg text-text-heading font-bold mb-1">Hyrox {event.city}</div>
                <div class="text-sm text-text-muted mb-1">{formatEventDate(event.startDate, event.endDate)}</div>
                <div class="text-xs text-text-muted opacity-70 mb-2">{event.venue}</div>
                {hasResults ? (
                  <div class="text-xs text-accent font-semibold">View race report →</div>
                ) : (
                  <div class="text-xs text-text-muted/60">Results pending</div>
                )}
              </a>
            );
          })}
        </div>
      </section>
    )}

    <section class="mt-16 pt-12 border-t border-border">
      <h2 class="text-2xl md:text-3xl font-black text-text-heading mb-2">Plan your {year} Hyrox race</h2>
      <p class="text-text-muted mb-6 max-w-3xl">
        Whichever city you race, the planning questions are the same. Start here.
      </p>
      <div class="grid gap-3 md:grid-cols-2 lg:grid-cols-3">
        <a href="/gyms/map/" class="block bg-bg-card border border-border rounded-xl p-5 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline">
          <div class="text-xs font-bold uppercase tracking-wider text-accent mb-1">Train</div>
          <div class="text-base text-text-heading font-bold mb-1">Find a Hyrox-affiliated gym</div>
          <div class="text-xs text-text-muted">The global map of training clubs running official Hyrox classes — filter by country and city.</div>
        </a>
        <a href="/blog/how-much-does-hyrox-cost/" class="block bg-bg-card border border-border rounded-xl p-5 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline">
          <div class="text-xs font-bold uppercase tracking-wider text-accent mb-1">Budget</div>
          <div class="text-base text-text-heading font-bold mb-1">How much does Hyrox cost?</div>
          <div class="text-xs text-text-muted">Entry £80–135 + gear + travel — full breakdown by budget, mid-range, and premium tiers.</div>
        </a>
        <a href="/blog/hyrox-race-week-protocol/" class="block bg-bg-card border border-border rounded-xl p-5 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline">
          <div class="text-xs font-bold uppercase tracking-wider text-accent mb-1">Race week</div>
          <div class="text-base text-text-heading font-bold mb-1">Race-week protocol</div>
          <div class="text-xs text-text-muted">Taper, sleep, nutrition, travel — the 7-day countdown that gets you to the start line fresh.</div>
        </a>
        <a href="/blog/best-hyrox-shoes-for-heavy-athletes/" class="block bg-bg-card border border-border rounded-xl p-5 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline">
          <div class="text-xs font-bold uppercase tracking-wider text-accent mb-1">Shoes</div>
          <div class="text-base text-text-heading font-bold mb-1">Best Hyrox shoes for heavy athletes</div>
          <div class="text-xs text-text-muted">Cushioning, support, and sled-friendly platforms for athletes 90 kg+.</div>
        </a>
        <a href="/blog/best-hyrox-shoes-for-wide-feet/" class="block bg-bg-card border border-border rounded-xl p-5 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline">
          <div class="text-xs font-bold uppercase tracking-wider text-accent mb-1">Shoes</div>
          <div class="text-base text-text-heading font-bold mb-1">Best Hyrox shoes for wide feet</div>
          <div class="text-xs text-text-muted">Wide-toe-box picks across Reebok, NoBull, Altra, and the brands that fit feet bigger than E.</div>
        </a>
        <a href="/blog/best-heart-rate-monitor-for-hyrox/" class="block bg-bg-card border border-border rounded-xl p-5 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline">
          <div class="text-xs font-bold uppercase tracking-wider text-accent mb-1">Wearables</div>
          <div class="text-base text-text-heading font-bold mb-1">Best heart-rate monitor for Hyrox</div>
          <div class="text-xs text-text-muted">Chest strap vs optical vs upper-arm — accuracy and dropouts under sled and burpee load.</div>
        </a>
        <a href="/blog/coros-hyrox-setup/" class="block bg-bg-card border border-border rounded-xl p-5 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline">
          <div class="text-xs font-bold uppercase tracking-wider text-accent mb-1">Wearables</div>
          <div class="text-base text-text-heading font-bold mb-1">Coros Hyrox setup</div>
          <div class="text-xs text-text-muted">Activity profile, screens, and auto-lap settings that work without manual intervention during stations.</div>
        </a>
        <a href="/blog/garmin-hyrox-activity-profile/" class="block bg-bg-card border border-border rounded-xl p-5 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline">
          <div class="text-xs font-bold uppercase tracking-wider text-accent mb-1">Wearables</div>
          <div class="text-base text-text-heading font-bold mb-1">Garmin Hyrox activity profile</div>
          <div class="text-xs text-text-muted">The exact field setup and Connect IQ data screens that give you sub-1-second splits.</div>
        </a>
        <a href="/blog/apple-watch-hyrox-workout/" class="block bg-bg-card border border-border rounded-xl p-5 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline">
          <div class="text-xs font-bold uppercase tracking-wider text-accent mb-1">Wearables</div>
          <div class="text-base text-text-heading font-bold mb-1">Apple Watch Hyrox workout</div>
          <div class="text-xs text-text-muted">The Functional Strength + custom workout setup that captures all 8 stations cleanly.</div>
        </a>
      </div>
    </section>
  </div>
</BaseLayout>
