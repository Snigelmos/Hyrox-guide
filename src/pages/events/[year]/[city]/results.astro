---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import {
  EVENTS,
  allEventPaths,
  formatEventDate,
  type HyroxEvent,
} from "../../../../data/events";
import { getResults } from "../../../../data/event-results";

export async function getStaticPaths() {
  return allEventPaths().map(({ year, slug }) => ({
    params: { year: String(year), city: slug },
    props: { year, slug },
  }));
}

const { year, slug } = Astro.props;
const event: HyroxEvent = EVENTS.find((e) => e.year === year && e.slug === slug)!;
const results = getResults(year, slug);

// Only link to a next-year edition if it actually exists. Linking blindly to
// /events/<year+1>/<slug>/ generated hundreds of 404s for events that have no
// confirmed next-year date yet.
const nextYearEvent = EVENTS.find((e) => e.year === year + 1 && e.slug === slug);

const eventDate = new Date(event.endDate ?? event.startDate);
const today = new Date();
const isPast = today > eventDate;
const isPending = isPast && !results;
const isUpcoming = !isPast && !results;

const title = results
  ? `Hyrox ${event.city} ${year} Results — Podium, Splits, and Recap`
  : isUpcoming
    ? `Hyrox ${event.city} ${year} Results — Coming ${formatEventDate(event.endDate ?? event.startDate)}`
    : `Hyrox ${event.city} ${year} Results — Recap Pending`;

const description = results
  ? `Hyrox ${event.city} ${year} full results recap: podium finishers across all divisions, finish-time distribution, and key takeaways from the ${results.totalAthletes ?? "thousands of"} athletes who raced.`
  : isUpcoming
    ? `Live results for Hyrox ${event.city} ${year} will be posted here within 48 hours of the final wave on ${formatEventDate(event.endDate ?? event.startDate)}. Bookmark this page.`
    : `Hyrox ${event.city} ${year} race recap is being compiled. Check back shortly.`;

const breadcrumbs = [
  { name: "Events", url: "/events/" },
  { name: String(year), url: `/events/${year}/` },
  { name: event.city, url: `/events/${year}/${event.slug}/` },
  { name: "Results" },
];

const faqItems = [
  {
    question: `Where can I find Hyrox ${event.city} ${year} results?`,
    answer: results
      ? `Full Hyrox ${event.city} ${year} results are published on this page including podium times for every division. The official Hyrox leaderboard at hyrox.com/results carries the complete rankings.`
      : `Official Hyrox ${event.city} ${year} results will appear on hyrox.com/results within 24-48 hours of the final wave. Our recap (with finish-time histogram and podium breakdown) goes live on this page typically the Monday after race weekend.`,
  },
  {
    question: `Who won Hyrox ${event.city} ${year}?`,
    answer: results && results.divisions[0]?.podium?.[0]
      ? `The Pro Men winner was ${results.divisions[0].podium[0].athlete} in ${results.divisions[0].podium[0].time}. Full division-by-division podium below.`
      : `Winner not yet confirmed. Race is ${isPast ? "complete — recap pending" : `scheduled for ${formatEventDate(event.startDate, event.endDate)}`}.`,
  },
  {
    question: `How many athletes raced at Hyrox ${event.city} ${year}?`,
    answer: results?.totalAthletes
      ? `${results.totalAthletes.toLocaleString()} athletes raced across all divisions at Hyrox ${event.city} ${year}.`
      : `Athlete count will be confirmed in the post-race recap. Major Hyrox stops typically host between 5,000 and 50,000 athletes across the race weekend.`,
  },
  {
    question: `What's a good Hyrox ${event.city} time?`,
    answer: `Hyrox times are globally standardised — a "good" time at ${event.city} matches a "good" time anywhere else. See our full breakdown by division and age group in the time benchmarks section.`,
  },
];

// Pull marquee winners for the hero stats strip. Match common division
// names; fall back gracefully if the event uses non-standard labels.
function pickWinner(matchers: string[]) {
  if (!results) return undefined;
  for (const matcher of matchers) {
    const d = results.divisions.find((x) =>
      x.division.toLowerCase().includes(matcher),
    );
    if (d?.podium?.[0]) return { division: d.division, ...d.podium[0] };
  }
  return undefined;
}
const heroMen = pickWinner(["pro men", "elite 15 men", "men"]);
const heroWomen = pickWinner(["pro women", "elite 15 women", "women"]);
---

<BaseLayout
  title={`${title} | Hyrox Vault`}
  description={description}
  ogType="article"
  schemaType="Article"
  breadcrumbs={breadcrumbs}
  faqItems={faqItems}
  noindex={!results}
>
  <div class="container-main py-10 md:py-16">
    <nav class="mb-8 text-sm" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 flex-wrap">
        <li><a href="/" class="text-text-muted hover:text-accent transition-colors no-underline">Home</a></li>
        <li class="flex items-center gap-2">
          <span class="text-text-muted/40">/</span>
          <a href="/events/" class="text-text-muted hover:text-accent transition-colors no-underline">Events</a>
        </li>
        <li class="flex items-center gap-2">
          <span class="text-text-muted/40">/</span>
          <a href={`/events/${year}/`} class="text-text-muted hover:text-accent transition-colors no-underline">{year}</a>
        </li>
        <li class="flex items-center gap-2">
          <span class="text-text-muted/40">/</span>
          <a href={`/events/${year}/${event.slug}/`} class="text-text-muted hover:text-accent transition-colors no-underline">{event.city}</a>
        </li>
        <li class="flex items-center gap-2">
          <span class="text-text-muted/40">/</span>
          <span class="text-text">Results</span>
        </li>
      </ol>
    </nav>

    <header class="mb-8 md:mb-10">
      <h1 class="text-4xl md:text-5xl font-black leading-tight text-gradient-accent">
        Hyrox {event.city} {year} Results
      </h1>
      <p class="mt-4 text-lg text-text-muted leading-relaxed max-w-2xl">
        {formatEventDate(event.startDate, event.endDate)} · {event.venue}
      </p>
      {!results && (
        <div class="mt-6 bg-accent/5 border border-accent/20 rounded-xl p-4 text-sm text-text-muted">
          {isPast ? (
            <>
              Recap is being compiled from the official Hyrox leaderboard. Check back shortly — full podium and finish-time histogram will land here within 48 hours of the final wave.
            </>
          ) : (
            <>
              Race day is <strong>{formatEventDate(event.startDate, event.endDate)}</strong>. Official results land on <a href="https://hyrox.com/results/" rel="noopener noreferrer" class="text-accent underline">hyrox.com/results</a> within 24 hours of the final wave; our full recap (podium, splits, takeaways) goes live on this page the Monday after.
            </>
          )}
        </div>
      )}
    </header>

    {results && (
      <>
        {/* ---- Hero stats strip ----------------------------------- */}
        <section class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-10 pb-10 border-b border-border">
          <div class="bg-bg-card border border-border rounded-xl p-5">
            <div class="text-xs font-bold uppercase tracking-wider text-text-muted mb-2">Athletes</div>
            <div class="text-3xl md:text-4xl font-black font-mono text-text-heading">
              {results.totalAthletes ? results.totalAthletes.toLocaleString() : "—"}
            </div>
            <div class="text-xs text-text-muted mt-2">across all divisions</div>
          </div>

          <div class="bg-bg-card border border-border rounded-xl p-5">
            <div class="text-xs font-bold uppercase tracking-wider text-text-muted mb-2">Race date</div>
            <div class="text-2xl md:text-3xl font-black text-text-heading leading-tight">
              {formatEventDate(event.startDate, event.endDate)}
            </div>
            <div class="text-xs text-text-muted mt-2">{event.venue}</div>
          </div>

          {heroMen ? (
            <div class="bg-gradient-to-br from-accent/10 to-bg-card border border-accent/30 rounded-xl p-5">
              <div class="text-xs font-bold uppercase tracking-wider text-accent mb-2">{heroMen.division} winner</div>
              <div class="text-3xl md:text-4xl font-black font-mono text-text-heading">{heroMen.time}</div>
              <div class="text-sm text-text font-bold mt-2 truncate">{heroMen.athlete}</div>
              {heroMen.country && <div class="text-xs text-text-muted mt-0.5">{heroMen.country}</div>}
            </div>
          ) : (
            <div class="bg-bg-card border border-border rounded-xl p-5 opacity-60">
              <div class="text-xs font-bold uppercase tracking-wider text-text-muted mb-2">Pro Men winner</div>
              <div class="text-2xl font-black text-text-muted">—</div>
            </div>
          )}

          {heroWomen ? (
            <div class="bg-gradient-to-br from-accent/10 to-bg-card border border-accent/30 rounded-xl p-5">
              <div class="text-xs font-bold uppercase tracking-wider text-accent mb-2">{heroWomen.division} winner</div>
              <div class="text-3xl md:text-4xl font-black font-mono text-text-heading">{heroWomen.time}</div>
              <div class="text-sm text-text font-bold mt-2 truncate">{heroWomen.athlete}</div>
              {heroWomen.country && <div class="text-xs text-text-muted mt-0.5">{heroWomen.country}</div>}
            </div>
          ) : (
            <div class="bg-bg-card border border-border rounded-xl p-5 opacity-60">
              <div class="text-xs font-bold uppercase tracking-wider text-text-muted mb-2">Pro Women winner</div>
              <div class="text-2xl font-black text-text-muted">—</div>
            </div>
          )}
        </section>

        {/* ---- Headlines (story cards) ---------------------------- */}
        {results.notableStories && results.notableStories.length > 0 && (
          <section class="mb-12">
            <h2 class="text-2xl md:text-3xl font-black text-text-heading mb-5">Headlines from race weekend</h2>
            <div class="grid gap-3 md:grid-cols-2">
              {results.notableStories.map((story) => (
                <div class="relative bg-bg-card border border-border rounded-xl p-5 pl-6">
                  <div class="absolute left-0 top-4 bottom-4 w-1 rounded-r bg-accent/60" />
                  <p class="text-sm md:text-base text-text leading-relaxed m-0">{story}</p>
                </div>
              ))}
            </div>
          </section>
        )}

        {/* ---- Podium cards + splits per division ----------------- */}
        <section class="mb-12">
          <h2 class="text-2xl md:text-3xl font-black text-text-heading mb-6">Podium results by division</h2>

          {results.divisions.map((d) => {
            const podium = d.podium ?? [];
            const first = podium.find((p) => p.rank === 1);
            const second = podium.find((p) => p.rank === 2);
            const third = podium.find((p) => p.rank === 3);
            const hasSplits = podium.some((p) => p.splits && p.splits.length > 0);
            const isSingleEntry = podium.length === 1;

            return (
              <div class="mb-10 last:mb-0">
                <div class="flex items-baseline justify-between flex-wrap gap-2 mb-4">
                  <h3 class="text-xl md:text-2xl font-black text-text-heading">{d.division}</h3>
                  <div class="text-xs text-text-muted">
                    {d.athleteCount && <span>{d.athleteCount.toLocaleString()} athletes</span>}
                    {d.athleteCount && d.medianTime && <span class="mx-2">·</span>}
                    {d.medianTime && <span>median {d.medianTime}</span>}
                    {(d.athleteCount || d.medianTime) && d.fastestTime && <span class="mx-2">·</span>}
                    {d.fastestTime && <span>fastest {d.fastestTime}</span>}
                  </div>
                </div>

                {podium.length === 0 ? (
                  <div class="bg-bg-card border border-border rounded-xl p-5 text-sm text-text-muted">
                    Podium not yet published for this division.
                  </div>
                ) : (
                  <div class={`grid gap-3 ${isSingleEntry ? "" : "md:grid-cols-3"}`}>
                    {first && (
                      <article class={`relative bg-gradient-to-br from-amber-500/15 via-bg-card to-bg-card border-2 border-amber-500/40 rounded-2xl p-5 md:p-6 ${isSingleEntry ? "" : "md:col-span-3 lg:col-span-1 lg:row-span-2"}`}>
                        <div class="flex items-center gap-2 mb-3">
                          <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-amber-500/20 border border-amber-500/40 text-amber-300 font-black text-base">1</span>
                          <span class="text-xs font-bold uppercase tracking-wider text-amber-300">Champion</span>
                        </div>
                        <div class="text-xl md:text-2xl lg:text-3xl font-black text-text-heading leading-tight mb-3 break-words">
                          {first.athlete}
                        </div>
                        <div class="text-3xl md:text-4xl lg:text-5xl font-black font-mono text-accent leading-none">
                          {first.time}
                        </div>
                        <div class="mt-3 flex items-center gap-2 flex-wrap">
                          {first.country && <span class="text-xs font-bold uppercase tracking-wider text-text-muted">{first.country}</span>}
                          {first.notes && (
                            <span class="inline-block text-xs font-bold uppercase tracking-wider text-amber-300 bg-amber-500/10 border border-amber-500/30 rounded-full px-2.5 py-1">
                              {first.notes}
                            </span>
                          )}
                        </div>
                      </article>
                    )}

                    {second && (
                      <article class="bg-bg-card border border-border rounded-2xl p-4 md:p-5">
                        <div class="flex items-center gap-2 mb-2">
                          <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-slate-400/20 border border-slate-400/40 text-slate-300 font-black text-sm">2</span>
                          <span class="text-xs font-bold uppercase tracking-wider text-slate-300">Silver</span>
                        </div>
                        <div class="text-base md:text-lg font-black text-text-heading leading-tight mb-2 break-words">
                          {second.athlete}
                        </div>
                        <div class="text-2xl md:text-3xl font-black font-mono text-text">{second.time}</div>
                        {second.country && <div class="mt-2 text-xs font-bold uppercase tracking-wider text-text-muted">{second.country}</div>}
                      </article>
                    )}

                    {third && (
                      <article class="bg-bg-card border border-border rounded-2xl p-4 md:p-5">
                        <div class="flex items-center gap-2 mb-2">
                          <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-orange-700/30 border border-orange-700/50 text-orange-300 font-black text-sm">3</span>
                          <span class="text-xs font-bold uppercase tracking-wider text-orange-300">Bronze</span>
                        </div>
                        <div class="text-base md:text-lg font-black text-text-heading leading-tight mb-2 break-words">
                          {third.athlete}
                        </div>
                        <div class="text-2xl md:text-3xl font-black font-mono text-text">{third.time}</div>
                        {third.country && <div class="mt-2 text-xs font-bold uppercase tracking-wider text-text-muted">{third.country}</div>}
                      </article>
                    )}
                  </div>
                )}

                {hasSplits && first?.splits && (
                  <details class="mt-4 group bg-bg-card border border-border rounded-xl overflow-hidden">
                    <summary class="cursor-pointer flex items-center justify-between px-5 py-3 hover:bg-bg-card-hover transition-colors">
                      <span class="text-sm font-bold text-text-heading">
                        Station splits — {first.athlete}
                      </span>
                      <svg class="w-4 h-4 text-text-muted transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                      </svg>
                    </summary>
                    <div class="border-t border-border">
                      <table class="w-full text-sm">
                        <thead class="bg-bg-card-hover/50">
                          <tr class="text-xs uppercase tracking-wider text-text-muted">
                            <th class="text-left p-3 font-bold">Segment</th>
                            <th class="text-right p-3 font-bold">Split</th>
                            {first.splits.some((s) => s.cumulativeTime) && (
                              <th class="text-right p-3 font-bold hidden sm:table-cell">Cumulative</th>
                            )}
                          </tr>
                        </thead>
                        <tbody class="divide-y divide-border/60">
                          {first.splits.map((s) => {
                            const isStation = !s.segment.toLowerCase().startsWith("run");
                            return (
                              <tr class={isStation ? "bg-accent/5" : ""}>
                                <td class={`p-3 ${isStation ? "text-text-heading font-semibold" : "text-text-muted"}`}>
                                  {s.segment}
                                </td>
                                <td class="p-3 text-right font-mono text-text-heading font-bold">
                                  {s.segmentTime}
                                </td>
                                {first.splits!.some((x) => x.cumulativeTime) && (
                                  <td class="p-3 text-right font-mono text-text-muted hidden sm:table-cell">
                                    {s.cumulativeTime ?? "—"}
                                  </td>
                                )}
                              </tr>
                            );
                          })}
                        </tbody>
                      </table>
                      <div class="px-5 py-3 text-xs text-text-muted bg-bg-card-hover/30">
                        Stations highlighted; runs in muted text. Splits sourced from published race-day data.
                      </div>
                    </div>
                  </details>
                )}
              </div>
            );
          })}
        </section>

        {/* ---- Finish-time histogram ------------------------------ */}
        {results.histogram && results.histogram.length > 0 && (
          <section class="mb-12">
            <h2 class="text-2xl md:text-3xl font-black text-text-heading mb-3">Finish-time distribution</h2>
            <p class="text-text-muted mb-6 max-w-2xl">
              Across the Open division, here's how the field broke down by finish-time band. Use this to benchmark where your time would have placed.
            </p>
            <div class="space-y-2">
              {(() => {
                const max = Math.max(...results.histogram!.map((b) => b.count));
                return results.histogram!.map((b) => (
                  <div class="flex items-center gap-3">
                    <div class="w-24 text-sm font-mono text-text-muted shrink-0">{b.bucket}</div>
                    <div class="flex-1 bg-bg-card border border-border rounded h-7 relative overflow-hidden">
                      <div
                        class="absolute inset-y-0 left-0 bg-accent/30 border-r border-accent/50"
                        style={`width: ${(b.count / max) * 100}%`}
                      />
                      <div class="absolute inset-0 flex items-center justify-end pr-2 text-xs font-bold text-text-heading">
                        {b.count.toLocaleString()}
                      </div>
                    </div>
                  </div>
                ));
              })()}
            </div>
          </section>
        )}

        {/* ---- Takeaways (story cards) ---------------------------- */}
        {results.takeaways && results.takeaways.length > 0 && (
          <section class="mb-12">
            <h2 class="text-2xl md:text-3xl font-black text-text-heading mb-5">Key takeaways for next year</h2>
            <div class="grid gap-3 md:grid-cols-2">
              {results.takeaways.map((t) => (
                <div class="relative bg-bg-card border border-border rounded-xl p-5 pl-6">
                  <div class="absolute left-0 top-4 bottom-4 w-1 rounded-r bg-emerald-500/60" />
                  <p class="text-sm md:text-base text-text leading-relaxed m-0">{t}</p>
                </div>
              ))}
            </div>
          </section>
        )}

        {/* ---- Outbound CTAs -------------------------------------- */}
        <section class="prose md:prose-lg max-w-none">
          <h2>Want to race here next year?</h2>
          <ul>
            {nextYearEvent ? (
              <li>Read our <a href={`/events/${year + 1}/${event.slug}/`}>Hyrox {event.city} {year + 1} preview</a>.</li>
            ) : (
              <li>Browse <a href="/events/">all upcoming Hyrox events</a> to find next season's date.</li>
            )}
            <li>Use the <a href="/calculator/">Hyrox time calculator</a> to set a target based on this year's median finish.</li>
            <li>Browse <a href="/training/">training programs</a> matched to your goal.</li>
          </ul>
        </section>
      </>
    )}

    {!results && isPast && (
      <section class="prose md:prose-lg max-w-none">
        <h2>While we compile the official recap</h2>
        <ul>
          <li>Check the live <a href="https://hyrox.com/results/" rel="noopener noreferrer">official Hyrox leaderboard</a> for individual results.</li>
          <li>Browse our <a href="/times/">global Hyrox time benchmarks</a> to see how your finish stacks up.</li>
          <li>Read our <a href="/blog/best-hyrox-pacing-strategy/">pacing strategy</a> guide if you've spotted weak points.</li>
        </ul>
      </section>
    )}

    {!results && !isPast && (
      <section class="prose md:prose-lg max-w-none">
        <h2>Until race weekend</h2>
        <ul>
          <li>Read the full <a href={`/events/${year}/${event.slug}/`}>Hyrox {event.city} {year} preview</a> with venue and registration details.</li>
          <li>Use the <a href="/calculator/">Hyrox time calculator</a> to set a goal time before race day.</li>
          <li>Pick a <a href="/training/">training program</a> that fits the time remaining.</li>
          <li>Lock in your <a href="/blog/hyrox-race-week-protocol/">race-week protocol</a> seven days out.</li>
        </ul>
      </section>
    )}
  </div>
</BaseLayout>
