---
import BaseLayout from "../../layouts/BaseLayout.astro";
import WorkoutLibrary from "../../components/WorkoutLibrary.astro";
import HeroBackground from "../../components/HeroBackground.astro";
import workoutsHero from "../../assets/heroes/recovery.png";
import { WORKOUTS } from "../../data/workouts";
import { LIBRARY_TOTAL_WORKOUTS } from "../../data/workout-library";

const title = "Hyrox Workouts — Benchmarks, Simulations, and Session Library";
const description = `Named Hyrox benchmarks plus a ${LIBRARY_TOTAL_WORKOUTS}-session training library: full simulations, race-pace intervals, station drills, strength, and conditioning. All levels.`;
const breadcrumbs = [{ name: "Workouts" }];
---

<BaseLayout
  title={`${title} | Hyrox Vault`}
  description={description}
  ogType="website"
  schemaType="CollectionPage"
  breadcrumbs={breadcrumbs}
>
  <section class="relative overflow-hidden border-b border-border isolate bg-gradient-to-b from-accent/5 to-transparent">
    <HeroBackground image={workoutsHero} position="object-center" textSide="left" priority />
    <div class="container-main py-12 md:py-20 relative z-10">
      <nav class="mb-6 text-sm" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 flex-wrap">
          <li><a href="/" class="text-text-muted hover:text-accent transition-colors no-underline">Home</a></li>
          <li class="flex items-center gap-2">
            <span class="text-text-muted/40">/</span>
            <span class="text-text">Workouts</span>
          </li>
        </ol>
      </nav>
      <div class="max-w-2xl">
        <h1 class="text-4xl md:text-5xl font-black leading-tight text-gradient-accent">
          Hyrox Benchmark Workouts
        </h1>
        <p class="mt-4 text-lg text-text-muted leading-relaxed">
          Named Hyrox simulation tests, benchmark workouts, and key training sessions — all with scoring, benchmarks, and how to use them in your prep.
        </p>
      </div>
    </div>
  </section>

  <div class="container-main py-10 md:py-16">

    <section aria-labelledby="benchmarks-heading" class="grid gap-4 md:grid-cols-2">
      <h2 id="benchmarks-heading" class="sr-only">Named benchmark workouts</h2>
      {WORKOUTS.map((w) => (
        <a
          href={`/workouts/${w.slug}/`}
          class="block bg-bg-card border border-border rounded-2xl p-6 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline"
        >
          <div class="text-xs font-bold uppercase tracking-wider text-accent mb-2">{w.durationLabel}</div>
          <h3 class="text-xl font-black text-text-heading mb-2">{w.name}</h3>
          <p class="text-sm text-text-muted leading-relaxed">{w.shortDescription}</p>
        </a>
      ))}
    </section>

    <WorkoutLibrary />
  </div>
</BaseLayout>
