---
import GuideLayout from "../../layouts/GuideLayout.astro";
import TrainingIcons from "../../components/icons/TrainingIcons.astro";
import StationIcons from "../../components/icons/StationIcons.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const guides = await getCollection("training");
  return guides.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const illustrationMap: Record<string, { type: "training" | "station"; variant: string }> = {
  beginner: { type: "training", variant: "beginner" },
  intermediate: { type: "training", variant: "intermediate" },
  advanced: { type: "training", variant: "advanced" },
  running: { type: "station", variant: "running" },
  stations: { type: "training", variant: "intermediate" },
  nutrition: { type: "training", variant: "nutrition" },
};

const illustration = illustrationMap[entry.id];
---

<GuideLayout
  title={entry.data.title}
  description={entry.data.description}
  breadcrumbs={[
    { label: "Training", href: "/training/" },
    { label: entry.data.title },
  ]}
  showIllustration={!!illustration}
>
  {illustration?.type === "training" && (
    <TrainingIcons slot="illustration" variant={illustration.variant} size={240} />
  )}
  {illustration?.type === "station" && (
    <StationIcons slot="illustration" station={illustration.variant} size={240} />
  )}
  <Content />
</GuideLayout>
