---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionCard from "../../components/SectionCard.astro";
import TrainingIcons from "../../components/icons/TrainingIcons.astro";
import { getCollection } from "astro:content";

const guides = (await getCollection("training")).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)
);

const difficultyConfig: Record<string, { label: string; variant: string }> = {
  beginner:     { label: "8 weeks · First Hyrox",          variant: "beginner" },
  intermediate: { label: "10 weeks · Drop 10–20 min",      variant: "intermediate" },
  advanced:     { label: "12 weeks · Sub 1:10 / 1:20",     variant: "advanced" },
};
---

<BaseLayout
  title="Hyrox Training Plans — Beginner, Intermediate & Advanced Programs"
  description="Structured Hyrox training programs for every level — beginner to advanced. Get race-ready with our proven plans."
>
  <section class="container-main py-16">
    <div class="max-w-3xl mb-10">
      <h1 class="text-4xl md:text-6xl font-black mb-6">
        <span class="text-gradient-accent">Training Programs</span>
      </h1>
      <p class="text-xl text-text-muted leading-relaxed mb-5">
        Structured plans to get you race-ready, no matter where you're starting from. Pick your level and start training today.
      </p>
      <p class="text-base text-text-muted leading-relaxed">
        Hyrox rewards athletes who train specifically for it — you can't wing a sled push after 8km of running if you've never practised it. Our programs combine running fitness with station-specific strength so you're genuinely prepared for race day, not just fit enough to survive it. If you're not ready to commit to a full program, scroll down to our Sample Workouts — pick one session and train like a Hyrox athlete today.
      </p>
    </div>

    {/* Sample Workouts — featured at the top */}
    <div class="mb-12">
      <a
        href="/workouts/"
        class="group block bg-bg-card border-2 border-accent/20 rounded-2xl p-8 hover:border-accent/40 hover:bg-bg-card-hover transition-all duration-300 hover:-translate-y-1"
      >
        <div class="md:flex md:items-center md:gap-8">
          <div class="flex-1">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full text-accent bg-accent/10 border border-accent/20">
                No commitment needed
              </span>
            </div>
            <h2 class="text-2xl font-black text-text-heading mb-2 group-hover:text-accent transition-colors">
              Sample Hyrox Workouts
            </h2>
            <p class="text-text-muted text-sm leading-relaxed mb-0">
              23 ready-to-go sessions — Hyrox-specific simulations, station-focused circuits, Norwegian 4×4 intervals, and CrossFit-inspired conditioning. Pick one and train. Includes pacing targets for all levels.
            </p>
          </div>
          <div class="flex items-center gap-1 text-sm font-semibold text-accent flex-shrink-0 mt-4 md:mt-0">
            View Workouts
            <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </div>
      </a>
    </div>

    {/* Train at a Hyrox-affiliated gym */}
    <div class="mb-12">
      <a
        href="/gyms/map/"
        class="group block bg-bg-card border-2 border-accent/20 rounded-2xl p-8 hover:border-accent/40 hover:bg-bg-card-hover transition-all duration-300 hover:-translate-y-1"
      >
        <div class="md:flex md:items-center md:gap-8">
          <div class="flex-1">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full text-accent bg-accent/10 border border-accent/20">
                Train at a real Hyrox box
              </span>
            </div>
            <h2 class="text-2xl font-black text-text-heading mb-2 group-hover:text-accent transition-colors">
              Find a Hyrox-affiliated gym near you
            </h2>
            <p class="text-text-muted text-sm leading-relaxed mb-0">
              Plans work better when you can train on the actual rig. Use our Hyrox Gym Finder to locate Affiliated Training Clubs and partner gyms with sleds, wall-ball targets, and SkiErgs in your city.
            </p>
          </div>
          <div class="flex items-center gap-1 text-sm font-semibold text-accent flex-shrink-0 mt-4 md:mt-0">
            Open Gym Finder
            <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </div>
      </a>
    </div>

    {/* Goal-time and constraint plans hub */}
    <div class="mb-12">
      <a
        href="/training-plans/"
        class="group block bg-bg-card border-2 border-accent/20 rounded-2xl p-8 hover:border-accent/40 hover:bg-bg-card-hover transition-all duration-300 hover:-translate-y-1"
      >
        <div class="md:flex md:items-center md:gap-8">
          <div class="flex-1">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full text-accent bg-accent/10 border border-accent/20">
                Goal-time and schedule plans
              </span>
            </div>
            <h2 class="text-2xl font-black text-text-heading mb-2 group-hover:text-accent transition-colors">
              Hyrox Training Plans by Goal Time, Duration, and Schedule
            </h2>
            <p class="text-text-muted text-sm leading-relaxed mb-0">
              11 free programmatic plans — sub-60 to sub-100, 4 weeks to 12 weeks, 3-day-a-week, women's plans, and Hyrox Doubles. Pick by your exact goal or constraint.
            </p>
          </div>
          <div class="flex items-center gap-1 text-sm font-semibold text-accent flex-shrink-0 mt-4 md:mt-0">
            Browse plans
            <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </div>
      </a>
    </div>

    <h2 class="text-sm font-bold uppercase tracking-wider text-accent mb-6">Multi-Week Programs — Choose Your Level</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
      {guides.filter(g => g.data.difficulty).map((guide, i) => {
        const config = difficultyConfig[guide.data.difficulty ?? "beginner"];
        return (
          <a
            href={`/training/${guide.id}/`}
            class="group relative flex flex-col bg-bg-card border border-border rounded-2xl p-8 hover:border-accent/30 hover:bg-bg-card-hover transition-all duration-300 hover:-translate-y-1 overflow-hidden"
          >
            <div class="absolute -right-4 -top-2 opacity-[0.04] group-hover:opacity-[0.08] transition-opacity pointer-events-none">
              <TrainingIcons variant={config.variant} size={180} />
            </div>
            <div class="relative z-10 flex flex-col flex-1">
              <div class="flex items-start justify-between mb-5">
                <div class="text-accent/50 group-hover:text-accent/80 transition-colors">
                  <TrainingIcons variant={config.variant} size={48} />
                </div>
                <span class="text-xs font-bold uppercase tracking-wider text-text-muted border border-border px-2 py-0.5 rounded">
                  Level {i + 1}
                </span>
              </div>
              <h3 class="text-xl font-bold text-text-heading mb-2 group-hover:text-accent transition-colors">
                {guide.data.title}
              </h3>
              <p class="text-text-muted text-sm leading-relaxed flex-1">{guide.data.description}</p>
              <div class="mt-4 pt-4 border-t border-border/50 flex items-center justify-between">
                <span class="text-xs text-text-muted">{config.label}</span>
                <span class="flex items-center gap-1 text-sm font-semibold text-accent opacity-60 group-hover:opacity-100 transition-opacity">
                  Start
                  <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </span>
              </div>
            </div>
          </a>
        );
      })}
    </div>

    <h2 class="text-sm font-bold uppercase tracking-wider text-accent mt-16 mb-6">Specialized Guides</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {guides.filter(g => !g.data.difficulty).map((guide) => (
        <SectionCard
          title={guide.data.title}
          description={guide.data.description}
          href={`/training/${guide.id}/`}
          icon={guide.data.icon ?? "📖"}
        />
      ))}
    </div>

    {/* Topic guides — hub-and-spoke into the deep blog content */}
    <h2 class="text-sm font-bold uppercase tracking-wider text-accent mt-16 mb-2">Train each station</h2>
    <p class="text-text-muted text-sm mb-6 max-w-2xl">
      Adam's technique deep-dives. Each one covers the movement pattern, the common mistakes, and the drills we actually program for athletes. For per-station playbooks with sets, reps, and progression, see the <a href="/training/stations/" class="text-accent hover:underline">station playbooks hub</a>; for official weights and no-rep rules, see the <a href="/stations/" class="text-accent hover:underline">stations standards page</a>.
    </p>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
      {[
        { href: "/blog/hyrox-skierg-technique-pacing/", label: "SkiErg technique & pacing" },
        { href: "/blog/hyrox-sled-push-technique/", label: "Sled push technique" },
        { href: "/blog/hyrox-sled-pull-technique/", label: "Sled pull technique" },
        { href: "/blog/hyrox-burpee-broad-jumps-strategy/", label: "Burpee broad jump strategy" },
        { href: "/blog/hyrox-rowing-technique/", label: "Rowing technique" },
        { href: "/blog/hyrox-farmers-carry-sandbag-lunges/", label: "Farmers carry & lunges" },
        { href: "/blog/hyrox-wall-balls-technique/", label: "Wall ball technique" },
        { href: "/blog/hyrox-running-strategy/", label: "Running strategy" },
      ].map((link) => (
        <a
          href={link.href}
          class="group flex items-center justify-between gap-2 bg-bg-card border border-border rounded-xl px-4 py-3 hover:border-accent/30 hover:bg-bg-card-hover transition-all no-underline min-h-[44px]"
        >
          <span class="text-sm font-semibold text-text-heading group-hover:text-accent transition-colors leading-tight">
            {link.label}
          </span>
          <span class="text-accent/60 text-sm flex-shrink-0">→</span>
        </a>
      ))}
    </div>

    <h2 class="text-sm font-bold uppercase tracking-wider text-accent mt-16 mb-2">Train without a gym</h2>
    <p class="text-text-muted text-sm mb-6 max-w-2xl">
      No rig, no problem. The no-gym track covers expectations, a 12-week bodyweight plan, hotel and park sessions, and a race-week taper that does not need equipment.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
      {[
        { href: "/blog/hyrox-training-without-gym-realistic-expectations/", label: "Realistic no-gym expectations" },
        { href: "/blog/hyrox-12-week-no-equipment-training-plan/", label: "12-week no-equipment plan" },
        { href: "/blog/hyrox-50-pound-equipment-upgrade/", label: "£50 home equipment upgrade" },
        { href: "/blog/hyrox-park-outdoor-training/", label: "Park & outdoor training" },
        { href: "/blog/hyrox-hotel-room-training/", label: "Hotel room sessions" },
        { href: "/blog/hyrox-race-week-no-gym-taper/", label: "No-gym race-week taper" },
      ].map((link) => (
        <a
          href={link.href}
          class="group flex items-center justify-between gap-2 bg-bg-card border border-border rounded-xl px-4 py-3 hover:border-accent/30 hover:bg-bg-card-hover transition-all no-underline min-h-[44px]"
        >
          <span class="text-sm font-semibold text-text-heading group-hover:text-accent transition-colors leading-tight">
            {link.label}
          </span>
          <span class="text-accent/60 text-sm flex-shrink-0">→</span>
        </a>
      ))}
    </div>

    <h2 class="text-sm font-bold uppercase tracking-wider text-accent mt-16 mb-2">Race-prep workouts</h2>
    <p class="text-text-muted text-sm mb-6 max-w-2xl">
      Tests and simulations to use in the back half of any block.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
      {[
        { href: "/workouts/compromised-running-test/", label: "Compromised running test" },
        { href: "/blog/hyrox-simulation-workouts/", label: "Hyrox race simulations" },
        { href: "/blog/hyrox-peak-for-race/", label: "Peak for race" },
        { href: "/blog/hyrox-race-week-protocol/", label: "Race-week protocol" },
        { href: "/blog/hyrox-warmup-protocol/", label: "Race-day warm-up" },
        { href: "/race-day-checklist/", label: "Race-day checklist (printable)" },
      ].map((link) => (
        <a
          href={link.href}
          class="group flex items-center justify-between gap-2 bg-bg-card border border-border rounded-xl px-4 py-3 hover:border-accent/30 hover:bg-bg-card-hover transition-all no-underline min-h-[44px]"
        >
          <span class="text-sm font-semibold text-text-heading group-hover:text-accent transition-colors leading-tight">
            {link.label}
          </span>
          <span class="text-accent/60 text-sm flex-shrink-0">→</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
