---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { STATION_PLAYBOOKS } from "../../../data/station-playbooks";
import { STATIONS } from "../../../data/stations";

const title = "Hyrox Station Training Playbooks — Fix Your Weakest Station";
const description =
  "Free training playbooks for every Hyrox station — SkiErg, sled push, sled pull, burpee broad jumps, rowing, farmers carry, sandbag lunges, wall balls, and running. Drills, key sessions, and benchmarks for each.";

const breadcrumbs = [
  { name: "Training", url: "/training/" },
  { name: "Station playbooks" },
];

const faqItems = [
  {
    question: "What is a Hyrox station playbook?",
    answer:
      "A focused training guide for one specific Hyrox station (or running). Each playbook covers the top 3 limiters, key sessions to fix them, drill tips, peer benchmarks, and which training plans to combine it with.",
  },
  {
    question: "How do I find which Hyrox station to focus on?",
    answer:
      "Open the Hyrox calculator, enter your actual station times in the trainer panel, and the diagnosis ranks your weakest stations against peer benchmarks. Each weak station links straight to its playbook.",
  },
  {
    question: "Do playbooks replace a Hyrox training plan?",
    answer:
      "No. Playbooks are layered on top of a structured plan. Pick a 12-week or goal-time training plan as your weekly schedule, then use the playbook for the station you're trying to improve.",
  },
];

// Order: stations 1–8 by position, then running last.
const orderedPlaybooks = STATION_PLAYBOOKS.slice().sort((a, b) => {
  if (a.slug === "running") return 1;
  if (b.slug === "running") return -1;
  const aPos = STATIONS.find((s) => s.slug === a.slug)?.position ?? 99;
  const bPos = STATIONS.find((s) => s.slug === b.slug)?.position ?? 99;
  return aPos - bPos;
});
---

<BaseLayout
  title={`${title} | Hyrox Vault`}
  description={description}
  ogType="article"
  schemaType="Article"
  breadcrumbs={breadcrumbs}
  faqItems={faqItems}
>
  <div class="container-main py-10 md:py-16">
    <nav class="mb-8 text-sm" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 flex-wrap">
        <li><a href="/" class="text-text-muted hover:text-accent transition-colors no-underline">Home</a></li>
        <li class="flex items-center gap-2">
          <span class="text-text-muted/40">/</span>
          <a href="/training/" class="text-text-muted hover:text-accent transition-colors no-underline">Training</a>
        </li>
        <li class="flex items-center gap-2">
          <span class="text-text-muted/40">/</span>
          <span class="text-text">Station playbooks</span>
        </li>
      </ol>
    </nav>

    <header class="mb-12 pb-8 border-b border-border">
      <div class="text-xs font-bold uppercase tracking-wider text-accent mb-3">Free Hyrox training</div>
      <h1 class="text-4xl md:text-6xl font-black leading-tight text-gradient-accent">
        Station Training Playbooks
      </h1>
      <p class="mt-5 text-lg text-text-muted leading-relaxed max-w-3xl">
        Nine focused playbooks — one per Hyrox station and one for running. Each covers the top limiters, key sessions, drill tips, and peer benchmarks. Use them with the calculator's trainer panel to target your weakest station first.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href="/calculator/#trainer"
          class="inline-flex items-center gap-2 bg-accent text-bg font-bold px-5 py-3 rounded-xl text-sm hover:bg-accent-dim transition-colors no-underline"
        >
          Diagnose your weakest station →
        </a>
        <a
          href="/training-plans/"
          class="inline-flex items-center gap-2 bg-bg-card border border-border text-text-heading font-bold px-5 py-3 rounded-xl text-sm hover:border-accent/40 transition-colors no-underline"
        >
          Browse training plans
        </a>
      </div>
    </header>

    <section class="mb-12">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {orderedPlaybooks.map((p) => {
          const station = STATIONS.find((s) => s.slug === p.slug);
          const positionLabel = station ? `Station ${station.position}` : "Running";
          return (
            <a
              href={`/training/stations/${p.slug}/`}
              class="block bg-bg-card border border-border rounded-2xl p-6 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline"
            >
              <div class="text-xs font-bold uppercase tracking-wider text-accent mb-3">{positionLabel}</div>
              <h2 class="text-xl font-black text-text-heading mb-2">{p.name}</h2>
              <p class="text-sm text-text-muted leading-relaxed mb-4">{p.tagline}</p>
              <div class="text-xs font-bold uppercase tracking-wider text-text-muted">
                Top fix · <span class="text-accent normal-case font-medium tracking-normal">{p.topFixHint}</span>
              </div>
            </a>
          );
        })}
      </div>
    </section>

    <section class="prose md:prose-lg max-w-none">
      <h2>How to use a station playbook</h2>
      <p>
        Station playbooks are designed to be layered on top of a complete training plan, not used as standalone programs. The flow that works best:
      </p>
      <ol>
        <li>
          <strong>Pick a structured plan.</strong> Choose a <a href="/training-plans/">12-week or goal-time training plan</a> as your weekly schedule.
        </li>
        <li>
          <strong>Find your weak station.</strong> Open the <a href="/calculator/#trainer">calculator's trainer panel</a> and enter your actual station times — the diagnosis ranks your top 3 weakest stations against peer benchmarks.
        </li>
        <li>
          <strong>Open the matching playbook.</strong> Each weak station links straight to its playbook. Read the limiters, watch which sessions are recommended, and look at the drill tips.
        </li>
        <li>
          <strong>Substitute, don't add.</strong> If your plan has one station session a week, swap it for one from the playbook — don't add an extra training day. More volume isn't better; more specific volume is.
        </li>
        <li>
          <strong>Re-test monthly.</strong> Run the same station test every 4 weeks (e.g. 100 wall ball test, 2 km row test) and watch the gap to your peer benchmark close.
        </li>
      </ol>

      <h2>Are these Hyrox station guides free?</h2>
      <p>
        Yes — every playbook on this page is free, no email gate, no PDF download. The content lives on the page so it stays current as we update sessions, benchmarks, and recommended plans through the season.
      </p>
    </section>
  </div>
</BaseLayout>
