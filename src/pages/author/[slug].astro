---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { AUTHORS } from "../../data/authors";
import { getAllPosts } from "../../data/blog";
import PostCard from "../../components/PostCard.astro";

export async function getStaticPaths() {
  return AUTHORS.map((author) => ({
    params: { slug: author.slug },
    props: { author },
  }));
}

const { author } = Astro.props;

const allPosts = await getAllPosts();
const authorPosts = allPosts.filter(
  (p) => (p.data.author ?? "").toLowerCase() === author.name.toLowerCase()
);

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: author.name,
  url: new URL(`/author/${author.slug}/`, Astro.site).toString(),
  image: new URL(author.image, Astro.site).toString(),
  jobTitle: author.jobTitle,
  worksFor: {
    "@type": "Organization",
    name: "HyroxVault",
    url: Astro.site?.toString(),
  },
  description: author.bio,
  ...(author.sameAs && author.sameAs.length > 0 ? { sameAs: author.sameAs } : {}),
  knowsAbout: author.topics,
};
---

<BaseLayout
  title={`${author.name} | Hyrox Guide`}
  description={author.bio}
  breadcrumbs={[
    { name: "Team", url: "/author/" },
    { name: author.name },
  ]}
>
  <div class="container-main py-10 md:py-16">
    <nav class="mb-8 text-sm" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 flex-wrap">
        <li><a href="/" class="text-text-muted hover:text-accent transition-colors no-underline">Home</a></li>
        <li class="flex items-center gap-2">
          <span class="text-text-muted/40">/</span>
          <a href="/author/" class="text-text-muted hover:text-accent transition-colors no-underline">Team</a>
        </li>
        <li class="flex items-center gap-2">
          <span class="text-text-muted/40">/</span>
          <span class="text-text">{author.name}</span>
        </li>
      </ol>
    </nav>

    <header class="mb-10 pb-8 border-b border-border">
      <div class="flex flex-col sm:flex-row sm:items-center gap-6">
        <img
          src={author.image}
          alt={`Portrait of ${author.name}`}
          width="128"
          height="128"
          loading="eager"
          class="w-32 h-32 rounded-full object-cover bg-bg-card border border-border flex-shrink-0"
        />
        <div>
          <div class="text-xs font-bold uppercase tracking-wider text-accent mb-2">
            {author.jobTitle}
          </div>
          <h1 class="text-4xl md:text-5xl font-black leading-tight text-gradient-accent">
            {author.name}
          </h1>
          <p class="mt-3 text-lg text-text-heading font-semibold">
            {author.tagline}
          </p>
        </div>
      </div>
    </header>

    <section class="prose md:prose-lg max-w-none">
      <p class="text-text-muted leading-relaxed">{author.longBio}</p>

      <h2>What {author.firstName} writes about</h2>
      <ul>
        {author.topics.map((t) => <li>{t}</li>)}
      </ul>

      <h2>Credentials</h2>
      <ul>
        {author.credentials.map((c) => <li>{c}</li>)}
      </ul>

      <h2>Editorial approach</h2>
      <p>
        Every guide on HyroxVault is signed by one of us by name. Numbers, splits, and pacing targets come from published race data, primary rules documents, or hands-on training — never from a guess. Read the <a href="/about/">full editorial policy and affiliate disclosure</a> for details.
      </p>
    </section>

    {authorPosts.length > 0 && (
      <section class="mt-16 pt-10 border-t border-border">
        <h2 class="text-2xl md:text-3xl font-black text-text-heading mb-6">
          Articles by {author.firstName}
        </h2>
        <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
          {authorPosts.map((post) => <PostCard post={post} variant="default" />)}
        </div>
      </section>
    )}
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} slot="head" />
</BaseLayout>
