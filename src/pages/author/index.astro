---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { AUTHORS } from "../../data/authors";

const title = "Meet the team";
const description =
  "The three people behind HyroxVault — who we are, what we race, and what each of us writes.";
---

<BaseLayout
  title={`${title} | Hyrox Guide`}
  description={description}
  breadcrumbs={[{ name: "Team" }]}
>
  <div class="container-main py-10 md:py-16">
    <header class="mb-10 pb-8 border-b border-border max-w-3xl">
      <div class="text-xs font-bold uppercase tracking-wider text-accent mb-3">
        Editorial team
      </div>
      <h1 class="text-4xl md:text-5xl font-black leading-tight text-gradient-accent">
        {title}
      </h1>
      <p class="mt-4 text-lg text-text-muted leading-relaxed">
        HyroxVault is run by three people. We race, we coach, we read the
        literature, and we write what we wish had existed when we entered our
        first Hyrox. Every guide on the site is owned by one of us by name.
      </p>
    </header>

    <div class="grid gap-5 md:grid-cols-3">
      {AUTHORS.map((a) => (
        <a
          href={`/author/${a.slug}/`}
          class="group flex flex-col bg-bg-card border border-border rounded-2xl p-6 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline"
        >
          <div class="flex items-center gap-4 mb-4">
            <img
              src={a.image}
              alt=""
              width="64"
              height="64"
              loading="lazy"
              class="w-16 h-16 rounded-full object-cover bg-bg border border-border"
            />
            <div>
              <div class="text-xs font-bold uppercase tracking-wider text-accent">
                {a.jobTitle}
              </div>
              <div class="text-xl font-bold text-text-heading group-hover:text-accent transition-colors">
                {a.name}
              </div>
            </div>
          </div>
          <p class="text-sm text-text-heading font-semibold mb-2">
            {a.tagline}
          </p>
          <p class="text-sm text-text-muted leading-relaxed">{a.bio}</p>
        </a>
      ))}
    </div>

    <p class="mt-10 text-sm text-text-muted max-w-3xl">
      We sign every article with a real first name. Surnames are kept off the
      public site by choice. For editorial pitches or corrections, see the
      contact details on the <a href="/about/" class="text-accent hover:underline">About</a> page.
    </p>
  </div>
</BaseLayout>
