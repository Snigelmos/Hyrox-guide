---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { AUTHORS } from "../../data/authors";

const title = "Authors — Hyrox Guide";
const description = "Meet the Hyrox racers, coaches, and editors behind HyroxVault.";
---

<BaseLayout
  title={`${title} | Hyrox Guide`}
  description={description}
  breadcrumbs={[{ name: "Author" }]}
>
  <div class="container-main py-10 md:py-16">
    <header class="mb-10 pb-8 border-b border-border">
      <h1 class="text-4xl md:text-5xl font-black leading-tight text-gradient-accent">
        {title}
      </h1>
      <p class="mt-4 text-lg text-text-muted leading-relaxed max-w-2xl">
        {description}
      </p>
    </header>

    <div class="grid gap-5 md:grid-cols-2">
      {AUTHORS.map((a) => (
        <a
          href={`/author/${a.slug}/`}
          class="block bg-bg-card border border-border rounded-2xl p-6 hover:border-accent/40 hover:bg-bg-card-hover transition-all no-underline"
        >
          <div class="text-xs font-bold uppercase tracking-wider text-accent mb-2">
            {a.jobTitle}
          </div>
          <div class="text-xl font-bold text-text-heading mb-2">{a.name}</div>
          <p class="text-sm text-text-muted leading-relaxed">{a.bio}</p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
