---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionCard from "../../components/SectionCard.astro";
import ContentIcons from "../../components/icons/ContentIcons.astro";
import HeroBackground from "../../components/HeroBackground.astro";
import GeoAffiliateButton from "../../components/GeoAffiliateButton";
import suppHero from "../../assets/heroes/supplements-hero.png";
import { getCollection } from "astro:content";

const supplementGuides = (await getCollection("supplements")).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)
);

const icons: Record<string, string> = {
  creatine: "strength",
  protein: "shaker",
  gels: "bolt",
  "pre-workout": "flame",
  electrolytes: "droplet",
  recovery: "recovery",
};

type Product = {
  name: string;
  description: string;
  price?: string;
  rating?: number;
  affiliateUrl: string;
  badge?: string;
  image?: string;
  category: string;
  guideUrl: string;
};

const featuredProducts: Product[] = supplementGuides.flatMap((guide) =>
  (guide.data.products ?? [])
    .filter((p) => p.badge)
    .slice(0, 1)
    .map((p) => ({
      ...p,
      category: guide.data.category,
      guideUrl: `/supplements/${guide.id}/`,
    }))
);

const raceDayEssentials = supplementGuides
  .filter((g) =>
    ["gels", "electrolytes", "pre-workout"].includes(g.data.category)
  )
  .flatMap((guide) =>
    (guide.data.products ?? []).slice(0, 1).map((p) => ({
      ...p,
      category: guide.data.category,
      guideUrl: `/supplements/${guide.id}/`,
    }))
  );
---

<BaseLayout
  title="Hyrox Race-Day Fuelling: Gels, Electrolytes & Caffeine Timing (2026)"
  description="What to take, when to take it, and what the evidence says. Creatine, protein, gels, pre-workout, and electrolytes for Hyrox, reviewed against ISSN, ACSM, and IOC consensus."
  dateModified="2026-05-09"
>
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-border isolate bg-gradient-to-b from-accent/5 to-transparent">
    <HeroBackground image={suppHero} position="object-[72%_center]" textSide="left" priority />
    <div class="container-main py-16 md:py-20 relative z-10">
      <div class="max-w-3xl">
        <p class="text-sm text-text-muted mb-3">
          Last reviewed May 2026 · By <a href="/author/" class="text-accent hover:underline">HyroxVault Editorial Team</a>
        </p>
        <h1 class="text-4xl md:text-6xl font-black mb-6 leading-tight">
          Supplements for <span class="text-gradient-accent">Hyrox Athletes</span>
        </h1>
        <p class="text-lg md:text-xl text-text-muted leading-relaxed max-w-2xl mb-3">
          Hyrox is a uniquely demanding event — 8 km of running plus 8 functional stations lasting 60–120 minutes. The right supplements are not optional extras; they are a measurable edge.
        </p>
        <p class="text-sm text-text-muted/80 max-w-2xl mb-6">
          Every product on this site is evaluated against ISSN/ACSM evidence, third-party purity testing, and our own training-day use. See <a href="/methodology/" class="text-accent hover:underline">how we vet supplements</a>.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#why-supplements" class="inline-flex items-center gap-2 px-6 py-3 bg-accent text-bg font-bold rounded-xl hover:bg-accent-dim transition-colors">
            Why it matters
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
          </a>
          <a href="#featured" class="inline-flex items-center gap-2 px-6 py-3 border border-border text-text font-bold rounded-xl hover:border-accent/40 hover:text-accent transition-colors">
            Top Picks
          </a>
          <a href="/supplements/protocol/" class="inline-flex items-center gap-2 px-6 py-3 border border-accent/20 text-accent font-bold rounded-xl hover:border-accent/40 hover:bg-accent/5 transition-colors">
            Race Day Protocol →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Supplements Matter (educational section) -->
  <section id="why-supplements" class="container-main py-14">
    <div class="max-w-3xl mb-10">
      <h2 class="text-2xl md:text-3xl font-black text-text-heading mb-4">Why supplements actually matter for Hyrox</h2>
      <p class="text-base text-text-muted leading-relaxed mb-4">
        Most fitness events are either a cardio test or a strength test. Hyrox is both — simultaneously. You're running hard enough to deplete glycogen while also doing repeated high-effort strength movements that tear muscle fibres. Your body is under a unique combination of metabolic stress that normal training nutrition doesn't fully address.
      </p>
      <p class="text-base text-text-muted leading-relaxed">
        The good news: the science on a small number of supplements is very clear. They work, they're safe, and they're cheap. You don't need a shelf full of products. You need four things done right.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {[
        {
          icon:"strength",
          name:"Creatine",
          impact:"Station power",
          evidence:"Grade A evidence",
          why:"Increases phosphocreatine stores — the fuel for explosive, repeated efforts. Directly improves sled push, wall balls, burpees, and every other short-burst station. Effect: 5–15% more power output.",
          href:"/supplements/creatine/",
          accentClass:"border-sky-400/20 hover:border-sky-400/40",
        },
        {
          icon:"shaker",
          name:"Protein",
          impact:"Recovery & muscle",
          evidence:"Grade A evidence",
          why:"Hyrox training is brutal on muscle tissue. Without enough protein (1.6–2.2 g/kg/day), you can't recover between sessions or adapt to training load. Recovery is where fitness is built.",
          href:"/supplements/protein-powder/",
          accentClass:"border-emerald-400/20 hover:border-emerald-400/40",
        },
        {
          icon:"bolt",
          name:"Energy Gels",
          impact:"Mid-race fuel",
          evidence:"Grade A evidence",
          why:"At the 45–55 min mark your glycogen is running low. One gel = 25–30 g of fast carbs = enough fuel to sustain pace through the final four stations. Without it, you slow down or blow up.",
          href:"/supplements/energy-gels/",
          accentClass:"border-amber-400/20 hover:border-amber-400/40",
        },
        {
          icon:"flame",
          name:"Caffeine",
          impact:"Focus & endurance",
          evidence:"Grade A evidence",
          why:"200 mg of caffeine consistently delivers 2–4% improvement in endurance performance and reduces perceived effort. At race pace, that's 2–5 minutes. It's the most evidence-backed performance supplement that exists.",
          href:"/supplements/pre-workout/",
          accentClass:"border-red-400/20 hover:border-red-400/40",
        },
      ].map(({icon,name,impact,evidence,why,href,accentClass}) => (
        <div class={`bg-bg-card border ${accentClass} rounded-2xl p-5 flex flex-col transition-all`}>
          <div class="flex items-center gap-3 mb-3">
            <span class="text-accent"><ContentIcons name={icon} size={26} /></span>
            <div>
              <h3 class="font-bold text-text-heading text-sm">{name}</h3>
              <span class="text-xs text-text-muted">{impact}</span>
            </div>
          </div>
          <span class="inline-block self-start mb-3 px-2 py-0.5 text-xs font-bold rounded bg-emerald-400/10 text-emerald-400 border border-emerald-400/20">{evidence}</span>
          <p class="text-xs text-text-muted leading-relaxed flex-1">{why}</p>
          <a href={href} class="mt-4 text-xs font-semibold text-accent hover:underline">Full guide →</a>
        </div>
      ))}
    </div>

    <div class="mt-8 p-5 bg-bg-card border border-border rounded-2xl flex items-start gap-4">
      <span class="flex-shrink-0 text-accent"><ContentIcons name="clipboard" size={26} /></span>
      <div>
        <h3 class="font-bold text-text-heading mb-1">Not sure when to take what?</h3>
        <p class="text-sm text-text-muted">Our <a href="/supplements/protocol/" class="text-accent hover:underline">Race Day Protocol</a> gives you the exact timing — night before, race morning, during the race, and recovery window. One page, zero guesswork.</p>
      </div>
    </div>
  </section>

  <!-- Race Day Protocol Banner -->
  <section class="container-main pt-12 pb-0">
    <a
      href="/supplements/protocol/"
      class="group relative flex flex-col sm:flex-row items-start sm:items-center gap-4 bg-accent/5 border border-accent/20 rounded-2xl px-6 py-5 hover:bg-accent/10 hover:border-accent/40 transition-all overflow-hidden"
    >
      <div class="w-12 h-12 rounded-xl bg-accent/10 border border-accent/20 flex items-center justify-center flex-shrink-0 text-accent"><ContentIcons name="calendar" size={24} /></div>
      <div class="flex-1">
        <div class="flex items-center gap-2 mb-1">
          <span class="text-xs font-bold uppercase tracking-wider text-accent">Race Day Protocol</span>
        </div>
        <h2 class="text-lg font-black text-text-heading group-hover:text-accent transition-colors">What to take and when — exact timing guide</h2>
        <p class="text-sm text-text-muted mt-0.5">Night before, race morning, during the race, and recovery. A step-by-step protocol for every supplement.</p>
      </div>
      <div class="flex items-center gap-1 text-sm font-bold text-accent opacity-60 group-hover:opacity-100 transition-opacity flex-shrink-0">
        View Protocol
        <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </div>
    </a>
  </section>

  <!-- Featured Picks -->
  <section id="featured" class="container-main py-16">
    <div class="flex items-end justify-between mb-8">
      <div>
        <h2 class="text-3xl md:text-4xl font-black text-text-heading">
          Editor's Picks
        </h2>
        <p class="text-text-muted mt-2">
          The #1 product in each category. We may earn a small commission via Amazon.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {
        featuredProducts.map((product) => {
          const productKey =
            product.category === "protein" ? "protein-powder" :
            product.category === "gels" ? "energy-gels" :
            product.category;
          return (
            <div class="bg-bg-card border border-border rounded-2xl p-5 flex flex-col hover:border-accent/30 transition-all">
              {product.badge && (
                <span class="self-start mb-3 px-2.5 py-1 text-xs font-bold rounded-full bg-accent/10 text-accent border border-accent/20">
                  {product.badge}
                </span>
              )}
              <h3 class="font-bold text-text-heading mb-2">{product.name}</h3>
              <p class="text-sm text-text-muted leading-relaxed flex-1 mb-4">{product.description}</p>
              <div class="flex items-center gap-3 mb-4">
                {product.rating && (
                  <div class="flex items-center gap-1">
                    <span class="text-amber-400 text-sm">★</span>
                    <span class="text-sm font-bold text-text-heading">{product.rating}</span>
                  </div>
                )}
                {product.price && (
                  <span class="text-sm text-text-muted">{product.price}</span>
                )}
              </div>
              <GeoAffiliateButton productKey={productKey} variant="primary" client:visible />
            </div>
          );
        })
      }
    </div>
  </section>

  <!-- Priority Stack with Geo Buy Buttons -->
  <section class="container-main py-16">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-4">
        <h2 class="text-3xl md:text-4xl font-black text-text-heading">
          The Hyrox Supplement Stack
        </h2>
        <p class="text-text-muted mt-3">
          Ranked by evidence and impact. Start at #1 and work your way down.
        </p>
      </div>

      <!-- Affiliate notice -->
      <div class="flex items-center gap-2 text-xs text-text-muted bg-bg-card border border-border rounded-xl px-4 py-2.5 mb-8 justify-center text-center">
        <svg class="w-3.5 h-3.5 flex-shrink-0 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        All buy links go to Amazon. We may earn a small commission at no extra cost to you.
      </div>

      <ol class="space-y-4">
        {
          supplementGuides.map((guide, i) => (
            <li class="bg-bg-card border border-border rounded-2xl p-5 hover:border-accent/30 transition-all">
              <div class="flex items-start gap-4">
                <span class="flex-shrink-0 w-10 h-10 bg-accent/10 text-accent font-black rounded-xl flex items-center justify-center text-lg">
                  {i + 1}
                </span>
                <span class="flex-shrink-0 mt-0.5 text-accent">
                  <ContentIcons name={icons[guide.data.category] ?? "capsule"} size={24} />
                </span>
                <div class="flex-1 min-w-0">
                  <div class="flex flex-wrap items-start justify-between gap-2 mb-1">
                    <a href={`/supplements/${guide.id}/`} class="font-bold text-text-heading hover:text-accent transition-colors">
                      {guide.data.title
                        .replace("Best ", "")
                        .replace(" for Hyrox Athletes", "")
                        .replace(" for Hyrox", "")
                        .replace(" for Hyrox Race Day", "")}
                    </a>
                  </div>
                  <p class="text-text-muted text-sm mb-3">
                    {guide.data.description.split("—")[0]?.trim().replace(/\.$/, "")}
                  </p>
                  <div class="flex flex-wrap gap-2">
                    <GeoAffiliateButton
                      productKey={
                        guide.data.category === "protein" ? "protein-powder" :
                        guide.data.category
                      }
                      variant="secondary"
                      client:visible
                    />
                    <a
                      href={`/supplements/${guide.id}/`}
                      class="inline-flex items-center gap-1.5 px-3 py-2 text-xs font-semibold text-text-muted border border-border rounded-lg hover:border-accent/30 hover:text-accent transition-all"
                    >
                      Full guide →
                    </a>
                  </div>
                </div>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- Browse by Category -->
  <section id="categories" class="container-main py-16">
    <h2 class="text-3xl md:text-4xl font-black text-text-heading mb-3">
      Browse by Category
    </h2>
    <p class="text-text-muted mb-8">
      Dive deep into each supplement type — what the science says, what to look
      for, and our tested picks.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        supplementGuides.map((guide, i) => (
          <SectionCard
            title={guide.data.title}
            description={guide.data.description}
            href={`/supplements/${guide.id}/`}
            icon={icons[guide.data.category] ?? "capsule"}
            accent={i === 0}
          />
        ))
      }
    </div>
  </section>

  <!-- Affiliate Disclosure (compact) -->
  <section class="container-main pb-16">
    <div
      class="flex items-start gap-4 p-6 bg-bg-card border border-border rounded-xl"
    >
      <span class="flex-shrink-0 text-accent"><ContentIcons name="money" size={26} /></span>
      <div>
        <h3 class="text-sm font-bold text-text-heading mb-1">
          Affiliate Disclosure
        </h3>
        <p class="text-text-muted text-xs leading-relaxed">
          Some links on this page are affiliate links — we may earn a small
          commission if you purchase through them, at no extra cost to you. We
          only recommend products we've researched and genuinely believe in.
          Editorial content is never influenced by partnerships.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
