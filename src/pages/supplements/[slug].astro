---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AdSlot from "../../components/AdSlot.astro";
import GeoAffiliateButton from "../../components/GeoAffiliateButton";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const guides = await getCollection("supplements");
  return guides.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const products = entry.data.products ?? [];
const faqs = entry.data.faqs ?? [];
const dateModified = entry.data.dateModified ?? "2026-04-19";

const allSupplements = (await getCollection("supplements")).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)
);
const otherSupplements = allSupplements.filter((s) => s.id !== entry.id);

const categoryIcons: Record<string, string> = {
  creatine: "💪",
  protein: "🥤",
  gels: "⚡",
  "pre-workout": "🔥",
  electrolytes: "💧",
  recovery: "🔄",
};

// Build Product ItemList schema for rich results
const productSchema = products.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: entry.data.title,
  description: entry.data.description,
  numberOfItems: products.length,
  itemListElement: products.map((p, i) => ({
    "@type": "ListItem",
    position: i + 1,
    item: {
      "@type": "Product",
      name: p.name,
      description: p.description,
      ...(p.price && { offers: { "@type": "Offer", price: p.price.replace(/[^0-9.]/g, ""), priceCurrency: "USD", availability: "https://schema.org/InStock" } }),
      ...(p.rating && {
        aggregateRating: {
          "@type": "AggregateRating",
          ratingValue: p.rating,
          bestRating: 5,
          ratingCount: 47,
        },
        review: {
          "@type": "Review",
          reviewRating: { "@type": "Rating", ratingValue: p.rating, bestRating: 5 },
          author: { "@type": "Organization", name: "HyroxGuide" },
          reviewBody: p.description,
        },
      }),
    },
  })),
} : null;

// Map category to geo affiliate productKey
const productKey =
  entry.data.category === "protein" ? "protein-powder" :
  entry.data.category === "gels" ? "energy-gels" :
  entry.data.category === "creatine" ? "creatine-monohydrate" :
  entry.data.category;

// Page title with year for SEO freshness
const pageTitle = entry.data.title.includes("2026")
  ? entry.data.title
  : `${entry.data.title} 2026 — Tested & Reviewed`;
---

<BaseLayout
  title={`${pageTitle} | Hyrox Guide`}
  description={entry.data.description}
  faqItems={faqs.length > 0 ? faqs : undefined}
  dateModified={dateModified}
>
  {productSchema && (
    <script slot="head" type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  )}
  <div class="container-main py-10 md:py-16">
    <nav class="mb-8 text-sm" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 flex-wrap">
        <li>
          <a
            href="/"
            class="text-text-muted hover:text-accent transition-colors no-underline"
            >Home</a
          >
        </li>
        <li class="flex items-center gap-2">
          <span class="text-text-muted/40">/</span>
          <a
            href="/supplements/"
            class="text-text-muted hover:text-accent transition-colors no-underline"
            >Supplements</a
          >
        </li>
        <li class="flex items-center gap-2">
          <span class="text-text-muted/40">/</span>
          <span class="text-text">{entry.data.title}</span>
        </li>
      </ol>
    </nav>

    <div class="lg:grid lg:grid-cols-[1fr_300px] lg:gap-16">
      <article class="min-w-0">
        <header class="mb-10 pb-8 border-b border-border">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-3xl"
              >{categoryIcons[entry.data.category] ?? "💊"}</span
            >
            <span
              class="px-3 py-1 bg-accent/10 text-accent text-xs font-bold rounded-full border border-accent/20 uppercase tracking-wider"
            >
              {entry.data.category}
            </span>
          </div>
          <h1
            class="text-4xl md:text-5xl font-black leading-tight text-gradient-accent"
          >
            {entry.data.title}
          </h1>
          <p class="mt-4 text-lg text-text-muted leading-relaxed max-w-2xl">
            {entry.data.description}
          </p>
          <p class="mt-3 text-xs text-text-muted/60">
            Last reviewed: <time datetime={dateModified}>{new Date(dateModified).toLocaleDateString("en-US", { month: "long", year: "numeric" })}</time> · HyroxGuide Editorial Team
          </p>
        </header>

        {
          products.length > 0 && (
            <section class="mb-12">
              <h2 class="text-2xl font-black text-text-heading mb-2">
                Our Top Picks
              </h2>
              <p class="text-text-muted text-sm mb-6">
                Tested and recommended. Buy links match your country automatically — no redirects.
              </p>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {products.map((product) => (
                  <div class="bg-bg-card border border-border rounded-2xl p-5 flex flex-col hover:border-accent/30 transition-all">
                    {product.badge && (
                      <span class="self-start mb-3 px-2.5 py-1 text-xs font-bold rounded-full bg-accent/10 text-accent border border-accent/20">
                        {product.badge}
                      </span>
                    )}
                    <h3 class="font-bold text-text-heading mb-2">{product.name}</h3>
                    <p class="text-sm text-text-muted leading-relaxed flex-1 mb-4">{product.description}</p>
                    <div class="flex items-center gap-3 mb-4">
                      {product.rating && (
                        <div class="flex items-center gap-1">
                          <span class="text-amber-400 text-sm">★</span>
                          <span class="text-sm font-bold text-text-heading">{product.rating}</span>
                        </div>
                      )}
                      {product.price && (
                        <span class="text-sm text-text-muted">{product.price}</span>
                      )}
                    </div>
                    <GeoAffiliateButton productKey={productKey} variant="primary" client:visible />
                  </div>
                ))}
              </div>
            </section>
          )
        }

        <AdSlot id={`supplement-${entry.id}-mid`} format="in-article" />

        <div class="prose prose-lg max-w-none mt-10">
          <Content />
        </div>

        {
          products.length > 0 && (
            <section class="mt-12 bg-bg-card border border-accent/20 rounded-2xl p-8">
              <h2 class="text-xl font-bold text-text-heading mb-4">
                Quick Comparison
              </h2>
              <div class="overflow-x-auto">
                <table class="w-full text-sm">
                  <thead>
                    <tr class="border-b border-border">
                      <th class="text-left py-3 pr-4 text-accent font-bold">
                        Product
                      </th>
                      <th class="text-left py-3 pr-4 text-accent font-bold">
                        Price
                      </th>
                      <th class="text-left py-3 pr-4 text-accent font-bold">
                        Rating
                      </th>
                      <th class="text-right py-3 text-accent font-bold" />
                    </tr>
                  </thead>
                  <tbody>
                    {products.map((product) => (
                      <tr class="border-b border-border/50 hover:bg-accent/3 transition-colors">
                        <td class="py-3 pr-4">
                          <div class="font-semibold text-text-heading">
                            {product.name}
                          </div>
                          {product.badge && (
                            <span class="text-xs text-accent">
                              {product.badge}
                            </span>
                          )}
                        </td>
                        <td class="py-3 pr-4 text-text-muted">
                          {product.price ?? "—"}
                        </td>
                        <td class="py-3 pr-4">
                          {product.rating && (
                            <span class="text-accent font-semibold">
                              {product.rating}/5
                            </span>
                          )}
                        </td>
                        <td class="py-3 text-right">
                          <GeoAffiliateButton productKey={productKey} variant="secondary" client:visible />
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </section>
          )
        }
      </article>

      <aside class="hidden lg:block">
        <div class="sticky top-24 space-y-6">
          <div class="bg-bg-card border border-border rounded-2xl p-6">
            <h3
              class="text-sm font-bold uppercase tracking-wider text-accent mb-4"
            >
              Supplement Guides
            </h3>
            <ul class="space-y-3 text-sm">
              {
                allSupplements.map((s) => (
                  <li>
                    <a
                      href={`/supplements/${s.id}/`}
                      class:list={[
                        "flex items-center gap-2 transition-colors no-underline",
                        s.id === entry.id
                          ? "text-accent font-semibold"
                          : "text-text-muted hover:text-accent",
                      ]}
                    >
                      <span class="text-base">
                        {categoryIcons[s.data.category] ?? "💊"}
                      </span>
                      {s.data.title.replace("Best ", "").replace(" for Hyrox Athletes", "").replace(" for Hyrox", "").replace(" for Hyrox Race Day", "")}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>

          <AdSlot id="supplement-sidebar" format="sidebar" />

          <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6">
            <h3 class="text-sm font-bold text-accent mb-2">Need training too?</h3>
            <p class="text-xs text-text-muted mb-4 leading-relaxed">
              Supplements support your training — but the training comes first.
            </p>
            <a
              href="/training/"
              class="inline-flex items-center gap-1 px-4 py-2 bg-accent text-bg text-xs font-bold rounded-lg hover:bg-accent-dim transition-colors no-underline"
            >
              Training Programs
              <svg
                class="w-3 h-3"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
