---
import BaseLayout from "../../layouts/BaseLayout.astro";
import GeoAffiliateButton from "../../components/GeoAffiliateButton";
import ContentIcons from "../../components/icons/ContentIcons.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const guides = await getCollection("supplements");
  return guides.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const products = entry.data.products ?? [];
const faqs = entry.data.faqs ?? [];
const dateModified = entry.data.dateModified ?? "2026-04-19";

const allSupplements = (await getCollection("supplements")).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)
);
const otherSupplements = allSupplements.filter((s) => s.id !== entry.id);

const categoryIcons: Record<string, string> = {
  creatine: "strength",
  protein: "shaker",
  gels: "bolt",
  "pre-workout": "flame",
  electrolytes: "droplet",
  recovery: "recovery",
};

// Product ItemList schema. We deliberately omit AggregateRating, Review, and
// Offer/priceCurrency: we don't have a multi-reviewer rating system, prices
// vary by visitor geo (GeoAffiliateButton swaps Amazon TLDs), and Google's
// review-snippet policy explicitly prohibits self-rated single-source data
// being marked up as aggregate.
const productSchema = products.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: entry.data.title,
  description: entry.data.description,
  numberOfItems: products.length,
  itemListElement: products.map((p, i) => ({
    "@type": "ListItem",
    position: i + 1,
    item: {
      "@type": "Product",
      name: p.name,
      description: p.description,
    },
  })),
} : null;

// Quick Answer TL;DR boxes for featured snippet SEO
const quickAnswers: Record<string, { question: string; answer: string }> = {
  creatine: {
    question: "Should you take creatine for Hyrox?",
    answer: "Yes. Creatine monohydrate (5g/day) is the most evidence-backed supplement for Hyrox. It directly improves power output on sled pushes, wall balls, and burpees, and speeds recovery between stations. No loading phase needed — just take 5g daily.",
  },
  protein: {
    question: "How much protein do you need for Hyrox training?",
    answer: "Aim for 1.6–2.0g of protein per kg of bodyweight per day. A whey protein shake (20–30g) post-training is the most practical way to hit your target. Prioritise food first, supplement to close the gap.",
  },
  gels: {
    question: "Should you take energy gels during a Hyrox race?",
    answer: "Yes. Take 1 gel (20–25g carbs) every 25–30 minutes from the start. Isotonic gels (no water needed) are best. Plan 2–3 gels for a race under 90 minutes, 3–4 for longer races.",
  },
  "pre-workout": {
    question: "Is pre-workout worth it for Hyrox?",
    answer: "Caffeine (3–6 mg/kg) 30–60 min before your race is the most evidence-backed performance booster — 2–6% improvement in endurance. Keep it simple: caffeine + citrulline. Take pre-workout 45–60 min before race start.",
  },
  electrolytes: {
    question: "Do you need electrolytes for Hyrox?",
    answer: "Yes — especially if you sweat heavily. Sodium is the key electrolyte lost in sweat. Take an electrolyte tablet in your water 30–60 min before racing, and drink to thirst (not beyond) during the event.",
  },
  recovery: {
    question: "What helps recovery after a Hyrox race?",
    answer: "Prioritise: 20–40g protein within 30 min post-race, tart cherry juice or omega-3s for inflammation, and sleep. Creatine also speeds muscle glycogen replenishment. Most recovery happens in the 24–48h after the race.",
  },
};

// Map category to geo affiliate productKey
const productKey =
  entry.data.category === "protein" ? "protein-powder" :
  entry.data.category === "gels" ? "energy-gels" :
  entry.data.category === "creatine" ? "creatine-monohydrate" :
  entry.data.category;

// Page title with year for SEO freshness
const pageTitle = entry.data.title.includes("2026")
  ? entry.data.title
  : `${entry.data.title} 2026 — Tested & Reviewed`;
---

<BaseLayout
  title={`${pageTitle} | Hyrox Vault`}
  description={entry.data.description}
  schemaType="Article"
  faqItems={faqs.length > 0 ? faqs : undefined}
  dateModified={dateModified}
>
  {productSchema && (
    <script slot="head" type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  )}
  <div class="container-main py-10 md:py-16">
    <nav class="mb-8 text-sm" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 flex-wrap">
        <li>
          <a
            href="/"
            class="text-text-muted hover:text-accent transition-colors no-underline"
            >Home</a
          >
        </li>
        <li class="flex items-center gap-2">
          <span class="text-text-muted/40">/</span>
          <a
            href="/supplements/"
            class="text-text-muted hover:text-accent transition-colors no-underline"
            >Supplements</a
          >
        </li>
        <li class="flex items-center gap-2">
          <span class="text-text-muted/40">/</span>
          <span class="text-text">{entry.data.title}</span>
        </li>
      </ol>
    </nav>

    <div class="lg:grid lg:grid-cols-[1fr_300px] lg:gap-16">
      <article class="min-w-0">
        <header class="mb-10 pb-8 border-b border-border">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-accent"
              ><ContentIcons name={categoryIcons[entry.data.category] ?? "capsule"} size={32} /></span
            >
            <span
              class="px-3 py-1 bg-accent/10 text-accent text-xs font-bold rounded-full border border-accent/20 uppercase tracking-wider"
            >
              {entry.data.category}
            </span>
          </div>
          <h1
            class="text-4xl md:text-5xl font-black leading-tight text-gradient-accent"
          >
            {entry.data.title}
          </h1>
          <p class="mt-4 text-lg text-text-muted leading-relaxed max-w-2xl">
            {entry.data.description}
          </p>
          <p class="mt-3 text-xs text-text-muted/60">
            Last reviewed: <time datetime={dateModified}>{new Date(dateModified).toLocaleDateString("en-US", { month: "long", year: "numeric" })}</time> · HyroxVault Editorial Team
          </p>
        </header>

        {/* Quick Answer TL;DR box — helps Google featured snippets */}
        {quickAnswers[entry.data.category] && (() => {
          const qa = quickAnswers[entry.data.category];
          return (
            <div class="mb-10 bg-accent/5 border-l-4 border-accent rounded-r-xl p-5">
              <p class="text-xs font-bold uppercase tracking-wider text-accent mb-2">Quick Answer</p>
              <p class="font-bold text-text-heading mb-1">{qa.question}</p>
              <p class="text-text-muted text-sm leading-relaxed">{qa.answer}</p>
            </div>
          );
        })()}

        {
          products.length > 0 && (() => {
            const hero = products[0];
            return (
              <section class="mb-12">
                <div class="bg-bg-card border border-accent/20 rounded-2xl p-6 flex flex-col sm:flex-row gap-6 items-start">
                  <div class="flex-1 min-w-0">
                    <span class="inline-block mb-3 px-2.5 py-1 text-xs font-bold rounded-full bg-accent/10 text-accent border border-accent/20">
                      Editor's Pick
                    </span>
                    <h2 class="text-xl font-black text-text-heading mb-2">{hero.name}</h2>
                    <p class="text-sm text-text-muted leading-relaxed mb-4">{hero.description}</p>
                    <div class="flex items-center gap-3 mb-5">
                      {hero.rating && (
                        <div class="flex items-center gap-1">
                          <span class="text-amber-400 text-sm">★</span>
                          <span class="text-sm font-bold text-text-heading">{hero.rating}/5</span>
                        </div>
                      )}
                      {hero.price && (
                        <span class="text-sm font-semibold text-accent">{hero.price}</span>
                      )}
                    </div>
                    <GeoAffiliateButton productKey={productKey} variant="primary" client:visible />
                    <p class="text-xs text-text-muted/60 mt-3">
                      We may earn a small commission via Amazon.
                    </p>
                  </div>
                </div>
              </section>
            );
          })()
        }

        <div class="prose prose-lg max-w-none mt-10">
          <Content />
        </div>

        {
          products.length > 0 && (
            <section class="mt-12 p-6 bg-bg-card border border-border rounded-2xl">
              <p class="text-sm text-text-muted mb-3">Ready to buy? Our top pick for this category, via Amazon.</p>
              <GeoAffiliateButton productKey={productKey} variant="primary" client:visible />
            </section>
          )
        }
      </article>

      <aside class="hidden lg:block">
        <div class="sticky top-24 space-y-6">
          <div class="bg-bg-card border border-border rounded-2xl p-6">
            <h3
              class="text-sm font-bold uppercase tracking-wider text-accent mb-4"
            >
              Supplement Guides
            </h3>
            <ul class="space-y-3 text-sm">
              {
                allSupplements.map((s) => (
                  <li>
                    <a
                      href={`/supplements/${s.id}/`}
                      class:list={[
                        "flex items-center gap-2 transition-colors no-underline",
                        s.id === entry.id
                          ? "text-accent font-semibold"
                          : "text-text-muted hover:text-accent",
                      ]}
                    >
                      <span class:list={[s.id === entry.id ? "text-accent" : "text-accent/70"]}>
                        <ContentIcons name={categoryIcons[s.data.category] ?? "capsule"} size={18} />
                      </span>
                      {s.data.title.replace("Best ", "").replace(" for Hyrox Athletes", "").replace(" for Hyrox", "").replace(" for Hyrox Race Day", "")}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>

          <div class="bg-accent/5 border border-accent/10 rounded-2xl p-6">
            <h3 class="text-sm font-bold text-accent mb-2">Need training too?</h3>
            <p class="text-xs text-text-muted mb-4 leading-relaxed">
              Supplements support your training — but the training comes first.
            </p>
            <a
              href="/training/"
              class="inline-flex items-center gap-1 px-4 py-2 bg-accent text-bg text-xs font-bold rounded-lg hover:bg-accent-dim transition-colors no-underline"
            >
              Training Programs
              <svg
                class="w-3 h-3"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
