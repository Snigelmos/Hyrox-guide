---
/**
 * Duotone module icons for the homepage and hero navigation.
 *
 * Style: filled background lozenge with the site accent at low opacity,
 * plus a stroke + filled glyph at full opacity. Reads at 24-64px.
 *
 * Pass `name` to pick the icon. Pass `size` (default 40) and an optional
 * `class` (forwarded to the root <svg>) to control colors via Tailwind
 * (e.g. text-accent, text-emerald-400). The accent fill uses currentColor
 * via a wrapping group, so colour theming "just works".
 */
interface Props {
  name:
    | "flag"
    | "barbell"
    | "stopwatch"
    | "spark"
    | "gauge"
    | "clipboard"
    | "compass"
    | "dumbbell"
    | "pill"
    | "route"
    | "post"
    | "trophy"
    | "map";
  size?: number;
  class?: string;
}

const { name, size = 40, class: className = "" } = Astro.props;
const stroke = 1.8;
---

{name === "flag" && (
  <svg width={size} height={size} viewBox="0 0 48 48" fill="none" class={className} aria-hidden="true">
    <rect x="3" y="3" width="42" height="42" rx="11" fill="currentColor" opacity="0.12" />
    <path d="M14 11v28" stroke="currentColor" stroke-width={stroke} stroke-linecap="round" />
    <path
      d="M14 13c4-2 8 2 12 0s8-2 12 0v12c-4-2-8 2-12 0s-8-2-12 0V13z"
      fill="currentColor"
      fill-opacity="0.55"
      stroke="currentColor"
      stroke-width={stroke}
      stroke-linejoin="round"
    />
    <circle cx="14" cy="11" r="1.6" fill="currentColor" />
  </svg>
)}

{name === "barbell" && (
  <svg width={size} height={size} viewBox="0 0 48 48" fill="none" class={className} aria-hidden="true">
    <rect x="3" y="3" width="42" height="42" rx="11" fill="currentColor" opacity="0.12" />
    <rect x="6" y="20" width="6" height="8" rx="1.5" fill="currentColor" />
    <rect x="36" y="20" width="6" height="8" rx="1.5" fill="currentColor" />
    <rect x="11" y="22" width="3" height="4" rx="0.8" fill="currentColor" opacity="0.55" />
    <rect x="34" y="22" width="3" height="4" rx="0.8" fill="currentColor" opacity="0.55" />
    <rect x="14" y="22.6" width="20" height="2.8" rx="1.4" fill="currentColor" />
  </svg>
)}

{name === "stopwatch" && (
  <svg width={size} height={size} viewBox="0 0 48 48" fill="none" class={className} aria-hidden="true">
    <rect x="3" y="3" width="42" height="42" rx="11" fill="currentColor" opacity="0.12" />
    <path d="M20 9h8" stroke="currentColor" stroke-width={stroke} stroke-linecap="round" />
    <path d="M24 13v3" stroke="currentColor" stroke-width={stroke} stroke-linecap="round" />
    <path d="M33 17l2-2" stroke="currentColor" stroke-width={stroke} stroke-linecap="round" />
    <circle cx="24" cy="28" r="11" fill="currentColor" fill-opacity="0.45" stroke="currentColor" stroke-width={stroke} />
    <path d="M24 28l5-3.5" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" />
    <circle cx="24" cy="28" r="1.6" fill="currentColor" />
  </svg>
)}

{name === "spark" && (
  <svg width={size} height={size} viewBox="0 0 48 48" fill="none" class={className} aria-hidden="true">
    <rect x="3" y="3" width="42" height="42" rx="11" fill="currentColor" opacity="0.12" />
    <path
      d="M24 8l4 9 9 1-7 6 2 9-8-5-8 5 2-9-7-6 9-1z"
      fill="currentColor"
      fill-opacity="0.55"
      stroke="currentColor"
      stroke-width={stroke}
      stroke-linejoin="round"
    />
    <path d="M24 19v6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" opacity="0.7" />
  </svg>
)}

{name === "gauge" && (
  <svg width={size} height={size} viewBox="0 0 48 48" fill="none" class={className} aria-hidden="true">
    <rect x="3" y="3" width="42" height="42" rx="11" fill="currentColor" opacity="0.12" />
    <path
      d="M9 31a15 15 0 0 1 30 0"
      fill="currentColor"
      fill-opacity="0.45"
      stroke="currentColor"
      stroke-width={stroke}
      stroke-linecap="round"
    />
    <path d="M9 31h2M37 31h2M16 18l1.4 1.4M30.6 19.4L32 18M24 14v2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
    <path d="M24 31l8-7" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" />
    <circle cx="24" cy="31" r="2" fill="currentColor" />
  </svg>
)}

{name === "clipboard" && (
  <svg width={size} height={size} viewBox="0 0 48 48" fill="none" class={className} aria-hidden="true">
    <rect x="3" y="3" width="42" height="42" rx="11" fill="currentColor" opacity="0.12" />
    <rect x="13" y="11" width="22" height="28" rx="3" fill="currentColor" fill-opacity="0.45" stroke="currentColor" stroke-width={stroke} />
    <rect x="19" y="8" width="10" height="6" rx="1.5" fill="currentColor" />
    <path d="M18 22h12M18 27h12M18 32h8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" opacity="0.85" />
  </svg>
)}

{name === "compass" && (
  <svg width={size} height={size} viewBox="0 0 48 48" fill="none" class={className} aria-hidden="true">
    <rect x="3" y="3" width="42" height="42" rx="11" fill="currentColor" opacity="0.12" />
    <circle cx="24" cy="24" r="13" fill="currentColor" fill-opacity="0.45" stroke="currentColor" stroke-width={stroke} />
    <path d="M28 16l-3 9-9 3 3-9z" fill="currentColor" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
    <circle cx="24" cy="24" r="1.6" fill="currentColor" />
  </svg>
)}

{name === "dumbbell" && (
  <svg width={size} height={size} viewBox="0 0 48 48" fill="none" class={className} aria-hidden="true">
    <rect x="3" y="3" width="42" height="42" rx="11" fill="currentColor" opacity="0.12" />
    <rect x="7" y="20" width="4" height="8" rx="1.2" fill="currentColor" />
    <rect x="11" y="17" width="4" height="14" rx="1.2" fill="currentColor" opacity="0.7" />
    <rect x="33" y="17" width="4" height="14" rx="1.2" fill="currentColor" opacity="0.7" />
    <rect x="37" y="20" width="4" height="8" rx="1.2" fill="currentColor" />
    <rect x="15" y="22.4" width="18" height="3.2" rx="1.6" fill="currentColor" />
  </svg>
)}

{name === "pill" && (
  <svg width={size} height={size} viewBox="0 0 48 48" fill="none" class={className} aria-hidden="true">
    <rect x="3" y="3" width="42" height="42" rx="11" fill="currentColor" opacity="0.12" />
    <rect
      x="9"
      y="20"
      width="30"
      height="14"
      rx="7"
      transform="rotate(-22 24 27)"
      fill="currentColor"
      fill-opacity="0.45"
      stroke="currentColor"
      stroke-width={stroke}
    />
    <rect
      x="9"
      y="20"
      width="15"
      height="14"
      rx="7"
      transform="rotate(-22 24 27)"
      fill="currentColor"
    />
  </svg>
)}

{name === "route" && (
  <svg width={size} height={size} viewBox="0 0 48 48" fill="none" class={className} aria-hidden="true">
    <rect x="3" y="3" width="42" height="42" rx="11" fill="currentColor" opacity="0.12" />
    <path
      d="M14 11a4 4 0 0 1 4 4c0 3-4 6-4 6s-4-3-4-6a4 4 0 0 1 4-4z"
      fill="currentColor"
      fill-opacity="0.55"
      stroke="currentColor"
      stroke-width={stroke}
      stroke-linejoin="round"
    />
    <circle cx="14" cy="15" r="1.4" fill="currentColor" />
    <path
      d="M34 27a4 4 0 0 1 4 4c0 3-4 6-4 6s-4-3-4-6a4 4 0 0 1 4-4z"
      fill="currentColor"
      fill-opacity="0.55"
      stroke="currentColor"
      stroke-width={stroke}
      stroke-linejoin="round"
    />
    <circle cx="34" cy="31" r="1.4" fill="currentColor" />
    <path d="M14 22c0 6 6 4 10 8s6 4 10 -1" stroke="currentColor" stroke-width={stroke} stroke-linecap="round" stroke-dasharray="2 3" />
  </svg>
)}

{name === "post" && (
  <svg width={size} height={size} viewBox="0 0 48 48" fill="none" class={className} aria-hidden="true">
    <rect x="3" y="3" width="42" height="42" rx="11" fill="currentColor" opacity="0.12" />
    <rect x="11" y="11" width="22" height="26" rx="2.5" fill="currentColor" fill-opacity="0.45" stroke="currentColor" stroke-width={stroke} />
    <path d="M16 18h12M16 23h12M16 28h8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" opacity="0.85" />
    <path d="M30 30l8-8 4 4-8 8h-4z" fill="currentColor" stroke="currentColor" stroke-width={stroke} stroke-linejoin="round" />
  </svg>
)}

{name === "trophy" && (
  <svg width={size} height={size} viewBox="0 0 48 48" fill="none" class={className} aria-hidden="true">
    <rect x="3" y="3" width="42" height="42" rx="11" fill="currentColor" opacity="0.12" />
    <path
      d="M16 10h16v8a8 8 0 0 1-16 0v-8z"
      fill="currentColor"
      fill-opacity="0.55"
      stroke="currentColor"
      stroke-width={stroke}
      stroke-linejoin="round"
    />
    <path d="M16 13H11v3a4 4 0 0 0 4 4M32 13h5v3a4 4 0 0 1-4 4" stroke="currentColor" stroke-width={stroke} stroke-linecap="round" />
    <path d="M21 26h6v5h3v3H18v-3h3v-5z" fill="currentColor" />
  </svg>
)}

{name === "map" && (
  <svg width={size} height={size} viewBox="0 0 48 48" fill="none" class={className} aria-hidden="true">
    <rect x="3" y="3" width="42" height="42" rx="11" fill="currentColor" opacity="0.12" />
    <path
      d="M9 14l9-3 12 4 9-3v22l-9 3-12-4-9 3z"
      fill="currentColor"
      fill-opacity="0.45"
      stroke="currentColor"
      stroke-width={stroke}
      stroke-linejoin="round"
    />
    <path d="M18 11v22M30 15v22" stroke="currentColor" stroke-width="1.4" stroke-dasharray="2 2" opacity="0.85" />
    <circle cx="30" cy="22" r="2.2" fill="currentColor" />
  </svg>
)}
