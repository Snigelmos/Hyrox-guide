---
const year = new Date().getFullYear();

const footerLinks = {
  Guide: [
    { label: "What is Hyrox?", href: "/racing-guide/what-is-hyrox/" },
    { label: "The 8 Stations", href: "/racing-guide/stations/" },
    { label: "Race Categories", href: "/racing-guide/categories/" },
    { label: "Race Day Tips", href: "/racing-guide/race-day-tips/" },
    { label: "Race-Day Checklist", href: "/race-day-checklist/" },
  ],
  Training: [
    { label: "All Training Plans", href: "/training-plans/" },
    { label: "Beginner Program", href: "/training/beginner/" },
    { label: "Intermediate Program", href: "/training/intermediate/" },
    { label: "Advanced Program", href: "/training/advanced/" },
    { label: "Supplements", href: "/supplements/" },
  ],
  Tools: [
    { label: "Race Time Predictor", href: "/calculator/" },
    { label: "Sled Push Watts", href: "/calculator/sled-push-watts/" },
    { label: "Time Benchmarks", href: "/times/" },
    { label: "World Records", href: "/records/" },
    { label: "Compare Hyrox", href: "/compare/" },
    { label: "Hyrox Cities", href: "/hyrox/" },
  ],
  Discover: [
    { label: "2026 Events Calendar", href: "/events/2026/" },
    { label: "All Race Years", href: "/events/" },
    { label: "Qualifiers", href: "/qualifiers/" },
    { label: "Glossary", href: "/glossary/" },
    { label: "FAQ", href: "/faq/" },
    { label: "Find a Gym", href: "/gyms/map/" },
    { label: "Competitions", href: "/competitions/" },
  ],
  More: [
    { label: "Gear Reviews", href: "/gear/" },
    { label: "Blog", href: "/blog/" },
    { label: "Editorial team", href: "/author/" },
    { label: "About", href: "/about/" },
    { label: "Methodology", href: "/methodology/" },
  ],
};
---

<footer class="bg-bg-card border-t border-border mt-16 md:mt-24">
  <div class="container-main py-10 md:py-16">
    <div class="md:hidden mb-8">
      <a href="/" class="flex items-center gap-2 mb-3">
        <div
          class="w-8 h-8 bg-accent rounded-lg flex items-center justify-center font-black text-bg text-sm"
        >
          H
        </div>
        <span class="font-black text-xl text-text-heading tracking-tight"
          >HYROX<span class="text-accent">VAULT</span></span
        >
      </a>
      <p class="text-text-muted text-sm leading-relaxed">
        An independent Hyrox resource. Race guides, training programs, gear
        reviews, and evidence-based supplement picks.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-2 lg:grid-cols-6 gap-x-6 gap-y-8 md:gap-10">
      <div class="hidden md:block">
        <a href="/" class="flex items-center gap-2 mb-4">
          <div
            class="w-8 h-8 bg-accent rounded-lg flex items-center justify-center font-black text-bg text-sm"
          >
            H
          </div>
          <span class="font-black text-xl text-text-heading tracking-tight"
            >HYROX<span class="text-accent">VAULT</span></span
          >
        </a>
        <p class="text-text-muted text-sm leading-relaxed">
          An independent Hyrox resource. Race guides, training programs, gear
          reviews, and evidence-based supplement picks.
        </p>
      </div>

      {
        Object.entries(footerLinks).map(([title, links]) => (
          <div>
            <h3 class="font-bold text-text-heading mb-3 md:mb-4 text-sm md:text-base">{title}</h3>
            <ul class="space-y-2">
              {links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-text-muted hover:text-accent transition-colors"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div
      class="mt-10 md:mt-12 pt-6 md:pt-8 border-t border-border flex flex-col md:flex-row justify-between items-center gap-4"
    >
      <p class="text-text-muted text-sm">
        &copy; {year} HyroxVault. Not affiliated with Hyrox GmbH.
      </p>
      <p class="text-text-muted text-xs">
        Some links are affiliate links. We may earn a commission at no extra
        cost to you.
      </p>
    </div>
  </div>
</footer>
