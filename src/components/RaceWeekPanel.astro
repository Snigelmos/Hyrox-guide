---
/**
 * Race-week capture block.
 *
 * Drop-in panel rendered on /events/[year]/[city].astro inside the 14-day
 * window before race start through 2 days after race end. Captures the
 * predictable race-week query cluster surfaced in GSC:
 *
 *   - "hyrox <city> <year> schedule" / local-language ("aikataulu", "Zeitplan", …)
 *   - "hyrox <city> start list"
 *   - "<city> events <date> weekend" / spectator info
 *
 * NOTE on live-tracker CTAs: the live-tracker UI is rendered in its own
 * section at the top of the city page (when the race is live). This panel
 * intentionally does NOT repeat tracker CTAs — the page should mention
 * "track an athlete" once, prominently, and then move on.
 */

import type { HyroxEvent } from "../data/events";
import {
  isRaceWeek,
  raceWeekStatusLabel,
  daysUntilRace,
  localRaceWeekTerms,
  buildResultsHyroxStartListUrl,
  buildResultsHyroxEventUrl,
} from "../lib/race-week";
import { isEventLiveNow } from "../lib/hyrox-live";
import { formatEventDate } from "../data/events";

interface Props {
  event: HyroxEvent;
}

const { event } = Astro.props as Props;
const now = new Date();
const inWindow = isRaceWeek(event, now);
// Render nothing outside the capture window — the rest of the city page is
// already a strong evergreen target for "hyrox <city> <year>" searches.
if (!inWindow) return null;

const live = isEventLiveNow(event, now);
const status = raceWeekStatusLabel(event, now) ?? "";
const days = daysUntilRace(event, now);
const terms = localRaceWeekTerms(event);

const startListUrl = buildResultsHyroxStartListUrl(event);
const eventPortalUrl = buildResultsHyroxEventUrl(event);

const scheduleHeading = terms.isLocalised
  ? `Hyrox ${event.city} ${event.year} schedule (${terms.schedule})`
  : `Hyrox ${event.city} ${event.year} schedule`;

const startListHeading = terms.isLocalised
  ? `Start list (${terms.startList})`
  : "Start list";
---

<section
  id="race-week"
  class="mb-10 pb-10 border-b border-border scroll-mt-24"
  aria-labelledby="race-week-heading"
>
  <!-- ── Hero chip + headline ───────────────────────────────────── -->
  <div class="bg-gradient-to-br from-accent/5 via-bg-card to-bg-card border border-accent/30 rounded-2xl p-5 md:p-6 mb-6">
    <div class="flex items-center gap-2 flex-wrap mb-3">
      <span class={`inline-flex items-center gap-2 rounded-full px-3 py-1 text-xs font-bold uppercase tracking-wider ${live ? "bg-emerald-500/10 border border-emerald-500/30 text-emerald-400" : "bg-accent/10 border border-accent/30 text-accent"}`}>
        {live && <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse" />}
        {status}
      </span>
      <span class="text-xs text-text-muted">
        {formatEventDate(event.startDate, event.endDate)} · {event.venue}
      </span>
    </div>

    <h2 id="race-week-heading" class="text-2xl md:text-3xl font-black text-text-heading leading-tight mb-2">
      {live
        ? `Hyrox ${event.city} ${event.year} is live now`
        : days === 0
          ? `Hyrox ${event.city} ${event.year} starts today`
          : `Hyrox ${event.city} ${event.year} race weekend`}
    </h2>
    <p class="text-text-muted leading-relaxed max-w-2xl mb-0">
      Race-day schedule, start list, and spectator info for {event.venue}.
    </p>
  </div>

  <!-- ── Two-column box grid: Schedule + Start list ──────────────── -->
  <div class="grid gap-4 md:grid-cols-2 mb-6">
    <!-- Schedule card -->
    <div id="race-week-schedule" class="bg-bg-card border border-border rounded-2xl p-5 md:p-6 scroll-mt-24">
      <div class="flex items-center gap-2 flex-wrap mb-3">
        <span class="text-xs font-bold uppercase tracking-wider text-accent">Schedule</span>
        {terms.isLocalised && (
          <span class="text-xs text-text-muted normal-case">/ {terms.schedule}</span>
        )}
      </div>
      <h3 class="text-lg md:text-xl font-black text-text-heading mb-3 leading-tight">
        {scheduleHeading}
      </h3>
      <ul class="space-y-2 text-sm text-text mb-4">
        <li class="flex gap-3">
          <span class="font-bold text-accent w-24 flex-shrink-0">Doors</span>
          <span class="text-text-muted">~90 min before first wave</span>
        </li>
        <li class="flex gap-3">
          <span class="font-bold text-accent w-24 flex-shrink-0">First wave</span>
          <span class="text-text-muted">Pro / Elite kick off the day</span>
        </li>
        <li class="flex gap-3">
          <span class="font-bold text-accent w-24 flex-shrink-0">Cadence</span>
          <span class="text-text-muted">~70 athletes every 8–10 min</span>
        </li>
        <li class="flex gap-3">
          <span class="font-bold text-accent w-24 flex-shrink-0">Last wave</span>
          <span class="text-text-muted">9–11 hr after first gun</span>
        </li>
        <li class="flex gap-3">
          <span class="font-bold text-accent w-24 flex-shrink-0">Awards</span>
          <span class="text-text-muted">Pro podium late afternoon</span>
        </li>
      </ul>
      <p class="text-xs text-text-muted leading-relaxed mb-3">
        Wave-specific times go live in the <a href={event.officialUrl} rel="noopener noreferrer" class="text-accent hover:underline">Hyrox app</a> and on <a href={eventPortalUrl} target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">results.hyrox.com</a> 7–10 days before race day.
      </p>
    </div>

    <!-- Start list card -->
    <div id="race-week-start-list" class="bg-bg-card border border-border rounded-2xl p-5 md:p-6 scroll-mt-24">
      <div class="flex items-center gap-2 flex-wrap mb-3">
        <span class="text-xs font-bold uppercase tracking-wider text-accent">Start list</span>
        {terms.isLocalised && (
          <span class="text-xs text-text-muted normal-case">/ {terms.startList}</span>
        )}
      </div>
      <h3 class="text-lg md:text-xl font-black text-text-heading mb-3 leading-tight">
        {startListHeading} — Hyrox {event.city} {event.year}
      </h3>
      <p class="text-sm text-text-muted leading-relaxed mb-4">
        Looking for a specific athlete's wave or bib number? Hyrox publishes the official start list a few days before race day. Open the season's event list, pick Hyrox {event.city}, and switch to the Start List tab.
      </p>
      <a
        href={startListUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-accent text-bg font-bold text-sm rounded-xl px-4 py-2 hover:bg-accent/90 transition-colors no-underline"
      >
        Open official start list
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
      </a>
    </div>
  </div>

  <!-- ── Spectator info card ─────────────────────────────────────── -->
  <div id="race-week-spectator" class="bg-bg-card border border-border rounded-2xl p-5 md:p-6 scroll-mt-24">
    <div class="text-xs font-bold uppercase tracking-wider text-accent mb-3">Spectator info</div>
    <h3 class="text-lg md:text-xl font-black text-text-heading mb-4 leading-tight">
      Spectating Hyrox {event.city} — venue, transit, and timing
    </h3>
    <div class="grid gap-3 sm:grid-cols-2">
      <div class="bg-bg border border-border rounded-xl p-4">
        <div class="text-xs font-bold uppercase tracking-wider text-accent mb-1">When to arrive</div>
        <p class="text-sm text-text leading-relaxed mb-0">30–45 min before your athlete's wave. Plan for 75–110 min for an Open finisher (60–80 min for Pro).</p>
      </div>
      <div class="bg-bg border border-border rounded-xl p-4">
        <div class="text-xs font-bold uppercase tracking-wider text-accent mb-1">Best vantage points</div>
        <p class="text-sm text-text leading-relaxed mb-0">SkiErg / Wall Balls corner sees every athlete twice. Sled Push is the most theatrical to watch live.</p>
      </div>
      <div class="bg-bg border border-border rounded-xl p-4">
        <div class="text-xs font-bold uppercase tracking-wider text-accent mb-1">Transit</div>
        <p class="text-sm text-text leading-relaxed mb-0">Public transport is almost always faster than driving on race weekend. Plan the door-to-venue leg the night before.</p>
      </div>
      <div class="bg-bg border border-border rounded-xl p-4">
        <div class="text-xs font-bold uppercase tracking-wider text-accent mb-1">Tickets &amp; food</div>
        <p class="text-sm text-text leading-relaxed mb-0">Some venues require a small spectator pass — see <a href={event.officialUrl} rel="noopener noreferrer" class="text-accent hover:underline">hyrox.com</a>. Food queues spike 12:00–13:00.</p>
      </div>
    </div>
  </div>
</section>
