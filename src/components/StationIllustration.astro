---
import StationIcons from "./icons/StationIcons.astro";

interface Props {
  station: string;
  name: string;
  metric: string;
  number: number;
}

const { station, name, metric, number } = Astro.props;
---

<div class="not-prose my-8 flex items-center gap-6 bg-bg-card border border-border rounded-2xl p-6">
  <div class="flex-shrink-0 text-accent/80">
    <StationIcons station={station} size={80} />
  </div>
  <div>
    <div class="flex items-center gap-3 mb-1">
      <span class="text-xs font-bold text-accent bg-accent/10 px-2.5 py-0.5 rounded-full">
        Station {number}
      </span>
      <span class="text-xs text-text-muted">{metric}</span>
    </div>
    <h3 class="text-lg font-bold text-text-heading">{name}</h3>
  </div>
</div>
