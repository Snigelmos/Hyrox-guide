---
interface Props {
  partnerName?: string;
  partnerUrl?: string;
  message?: string;
}

const {
  partnerName = "Partner",
  partnerUrl = "#",
  message = "Check out our featured partner for exclusive Hyrox deals.",
} = Astro.props;
---

<div class="bg-accent/5 border border-accent/10 rounded-2xl p-6 my-8">
  <div class="flex items-center gap-2 mb-2">
    <span class="text-xs font-bold uppercase tracking-wider text-accent/60">Featured Partner</span>
  </div>
  <p class="text-text-muted text-sm mb-3">{message}</p>
  <a
    href={partnerUrl}
    target="_blank"
    rel="noopener noreferrer sponsored"
    class="inline-flex items-center gap-1 text-sm font-semibold text-accent hover:text-accent-dim transition-colors"
  >
    Visit {partnerName}
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
    </svg>
  </a>
</div>
