---
import ContentIcons from "./icons/ContentIcons.astro";

interface Props {
  context?: "training" | "racing" | "general";
}

const { context = "general" } = Astro.props;

const products = [
  { name: "Creatine Monohydrate", desc: "More power on every station", tag: "BEST SELLER", href: "/supplements/creatine/", badge: "bg-emerald-400/10 text-emerald-400 border-emerald-400/20" },
  { name: "Pre-Workout", desc: "2-6% performance boost on race day", tag: "RACE DAY", href: "/supplements/pre-workout/", badge: "bg-amber-400/10 text-amber-400 border-amber-400/20" },
  { name: "Protein Powder", desc: "Recover faster between sessions", tag: "RECOVERY", href: "/supplements/protein-powder/", badge: "bg-sky-400/10 text-sky-400 border-sky-400/20" },
];

const links = context === "training"
  ? [
      { label: "Sample Workouts", href: "/workouts/", icon: "lift" },
      { label: "Station Drills", href: "/training/stations/", icon: "target" },
      { label: "Find a Hyrox Gym", href: "/gyms/map/", icon: "pin" },
      { label: "Time Calculator", href: "/calculator/", icon: "stopwatch" },
    ]
  : context === "racing"
  ? [
      { label: "Training Programs", href: "/training/", icon: "clipboard" },
      { label: "Station Benchmarks", href: "/racing-guide/times/", icon: "stopwatch" },
      { label: "Find a Hyrox Gym", href: "/gyms/map/", icon: "pin" },
      { label: "Supplements Guide", href: "/supplements/", icon: "capsule" },
    ]
  : [
      { label: "Racing Guide", href: "/racing-guide/", icon: "flag" },
      { label: "Training Programs", href: "/training/", icon: "clipboard" },
      { label: "Find a Hyrox Gym", href: "/gyms/map/", icon: "pin" },
      { label: "Time Calculator", href: "/calculator/", icon: "stopwatch" },
    ];
---

<div class="not-prose mt-12 space-y-8">
  {/* Product recommendations */}
  <div class="bg-bg-card border border-border rounded-2xl p-6 md:p-8">
    <h3 class="text-sm font-bold uppercase tracking-wider text-accent mb-1">Fuel Your Training</h3>
    <p class="text-xs text-text-muted mb-5">Top supplements used by competitive Hyrox athletes</p>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
      {products.map((p) => (
        <a
          href={p.href}
          class="group block bg-bg border border-border rounded-xl p-4 hover:border-accent/30 transition-all"
        >
          <span class={`inline-block text-xs font-bold uppercase tracking-wider px-2 py-0.5 rounded-full border mb-3 ${p.badge}`}>
            {p.tag}
          </span>
          <h4 class="text-sm font-bold text-text-heading group-hover:text-accent transition-colors">{p.name}</h4>
          <p class="text-xs text-text-muted mt-1">{p.desc}</p>
        </a>
      ))}
    </div>
  </div>

  {/* Related pages */}
  <div class="flex flex-wrap gap-3">
    {links.map((link) => (
      <a
        href={link.href}
        class="inline-flex items-center gap-2 px-4 py-2.5 bg-bg-card border border-border rounded-xl text-sm font-semibold text-text hover:border-accent/30 hover:text-accent transition-all min-h-[44px]"
      >
        <ContentIcons name={link.icon} size={18} class="text-accent" />
        {link.label}
      </a>
    ))}
  </div>
</div>
