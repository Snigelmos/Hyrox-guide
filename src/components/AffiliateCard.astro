---
interface Props {
  name: string;
  description: string;
  price?: string;
  rating?: number;
  image?: string;
  affiliateUrl: string;
  badge?: string;
}

const { name, description, price, rating, image, affiliateUrl, badge } = Astro.props;

const stars = rating ? Math.round(rating) : 0;
---

<div class="bg-bg-card border border-border rounded-2xl overflow-hidden hover:border-accent/30 transition-all group flex flex-col">
  {image && (
    <div class="aspect-[4/3] bg-bg overflow-hidden flex-shrink-0">
      <img
        src={image}
        alt={name}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    </div>
  )}
  <div class="p-6 flex flex-col flex-1">
    {badge && (
      <span class="inline-block px-3 py-1 bg-accent/10 text-accent text-xs font-bold rounded-full mb-3 self-start">
        {badge}
      </span>
    )}
    <h3 class="text-lg font-bold text-text-heading mb-2">{name}</h3>
    <p class="text-text-muted text-sm mb-4 flex-1">{description}</p>
    {rating && (
      <div class="flex items-center gap-1 mb-2">
        {Array.from({ length: 5 }).map((_, i) => (
          <svg
            class:list={["w-4 h-4", i < stars ? "text-accent" : "text-border"]}
            fill="currentColor"
            viewBox="0 0 20 20"
          >
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        ))}
        <span class="text-xs text-text-muted ml-1">{rating}</span>
      </div>
    )}
    {price && <div class="text-accent font-bold mb-4">{price}</div>}
    <a
      href={affiliateUrl}
      target="_blank"
      rel="noopener noreferrer sponsored"
      class="inline-flex items-center justify-center gap-1 w-full px-5 py-2.5 bg-accent text-bg text-sm font-bold rounded-lg hover:bg-accent-dim transition-colors min-h-[44px] mt-auto"
    >
      View Deal
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
      </svg>
    </a>
  </div>
</div>
