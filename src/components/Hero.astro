---
---

<section class="relative overflow-hidden border-b border-border">
  <div class="absolute inset-0 bg-gradient-to-b from-sky-500/10 via-bg-card/20 to-bg"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_0%,rgba(56,189,248,0.08),transparent)]"></div>

  <div class="container-main relative z-10 py-20 md:py-28 text-center">
    <div class="max-w-3xl mx-auto">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-accent/10 border border-accent/20 rounded-full mb-6">
        <div class="w-2 h-2 bg-accent rounded-full animate-pulse"></div>
        <span class="text-accent text-sm font-medium">Independent Hyrox Resource</span>
      </div>

      <h1 class="text-5xl sm:text-6xl md:text-7xl font-black tracking-tight mb-5 leading-[1.05]">
        <span class="text-text-heading">The Hyrox</span><br />
        <span class="text-gradient-accent">Vault</span>
      </h1>

      <p class="text-xl md:text-2xl text-text-muted mb-10 max-w-2xl mx-auto leading-relaxed">
        Everything you need to race, train, and fuel your best Hyrox — all in one place.
      </p>

      <nav aria-label="Primary sections" class="grid grid-cols-2 md:grid-cols-5 gap-3 max-w-3xl mx-auto">
        <a
          href="/racing-guide/what-is-hyrox/"
          class="group flex flex-col items-center justify-center gap-2 px-3 py-4 min-h-[88px] bg-bg-card/70 border border-border rounded-xl text-text-muted hover:text-accent hover:border-accent/40 hover:bg-bg-card hover:-translate-y-0.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/60 transition-all"
        >
          <span class="text-2xl leading-none" aria-hidden="true">🏁</span>
          <span class="text-sm font-semibold text-center leading-tight">What is Hyrox?</span>
        </a>
        <a
          href="/training/"
          class="group flex flex-col items-center justify-center gap-2 px-3 py-4 min-h-[88px] bg-bg-card/70 border border-border rounded-xl text-text-muted hover:text-accent hover:border-accent/40 hover:bg-bg-card hover:-translate-y-0.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/60 transition-all"
        >
          <span class="text-2xl leading-none" aria-hidden="true">💪</span>
          <span class="text-sm font-semibold text-center leading-tight">Training</span>
        </a>
        <a
          href="/supplements/"
          class="group flex flex-col items-center justify-center gap-2 px-3 py-4 min-h-[88px] bg-bg-card/70 border border-border rounded-xl text-text-muted hover:text-accent hover:border-accent/40 hover:bg-bg-card hover:-translate-y-0.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/60 transition-all"
        >
          <span class="text-2xl leading-none" aria-hidden="true">⚡</span>
          <span class="text-sm font-semibold text-center leading-tight">Supplements</span>
        </a>
        <a
          href="/racing-guide/"
          class="group flex flex-col items-center justify-center gap-2 px-3 py-4 min-h-[88px] bg-bg-card/70 border border-border rounded-xl text-text-muted hover:text-accent hover:border-accent/40 hover:bg-bg-card hover:-translate-y-0.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/60 transition-all"
        >
          <span class="text-2xl leading-none" aria-hidden="true">📋</span>
          <span class="text-sm font-semibold text-center leading-tight">Race Guide<br /><span class="text-xs font-medium opacity-80">&amp; Calculator</span></span>
        </a>
        <a
          href="/blog/"
          class="group col-span-2 md:col-span-1 flex flex-col items-center justify-center gap-2 px-3 py-4 min-h-[88px] bg-bg-card/70 border border-border rounded-xl text-text-muted hover:text-accent hover:border-accent/40 hover:bg-bg-card hover:-translate-y-0.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/60 transition-all"
        >
          <span class="text-2xl leading-none" aria-hidden="true">📝</span>
          <span class="text-sm font-semibold text-center leading-tight">Blog</span>
        </a>
      </nav>
    </div>

    <div class="grid grid-cols-3 gap-6 mt-16 max-w-xs mx-auto">
      <div class="text-center">
        <div class="text-3xl font-black text-accent">8</div>
        <div class="text-xs text-text-muted mt-0.5">Stations</div>
      </div>
      <div class="text-center">
        <div class="text-3xl font-black text-accent">8km</div>
        <div class="text-xs text-text-muted mt-0.5">Running</div>
      </div>
      <div class="text-center">
        <div class="text-3xl font-black text-accent">30+</div>
        <div class="text-xs text-text-muted mt-0.5">Countries</div>
      </div>
    </div>
  </div>
</section>
