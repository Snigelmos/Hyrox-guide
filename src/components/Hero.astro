---
import HyroxCourseRibbon from "./HyroxCourseRibbon.astro";
import ModuleIcons from "./icons/ModuleIcons.astro";
import { primaryNav } from "../config/nav";
---

<section class="relative overflow-hidden border-b border-border isolate">
  <div class="absolute inset-0 -z-10 bg-gradient-to-b from-sky-500/10 via-bg-card/20 to-bg"></div>
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(ellipse_80%_50%_at_50%_0%,rgba(56,189,248,0.10),transparent)]"></div>

  <svg
    class="absolute inset-x-0 top-0 -z-10 h-full w-full opacity-[0.10] [mask-image:radial-gradient(ellipse_at_center,black,transparent_70%)]"
    aria-hidden="true"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs>
      <pattern id="hero-grid" width="56" height="56" patternUnits="userSpaceOnUse">
        <path d="M 56 0 L 0 0 0 56" stroke="rgb(56,189,248)" stroke-width="0.5" fill="none" />
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#hero-grid)" />
  </svg>

  <div class="container-main relative z-10 pt-12 pb-8 md:pt-28 md:pb-16 text-center">
    <div class="max-w-3xl mx-auto">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-accent/10 border border-accent/20 rounded-full mb-6">
        <div class="w-2 h-2 bg-accent rounded-full animate-pulse"></div>
        <span class="text-accent text-sm font-medium">Independent Hyrox Resource</span>
      </div>

      <h1 class="text-4xl sm:text-6xl md:text-7xl font-black tracking-tight mb-5 leading-[1.05]">
        <span class="text-text-heading">The Hyrox</span><br />
        <span class="text-gradient-accent">Vault</span>
      </h1>

      <p class="text-lg md:text-2xl text-text-muted mb-10 max-w-2xl mx-auto leading-relaxed">
        Everything you need to race, train, and fuel your best Hyrox — all in one place.
      </p>

      <nav
        aria-label="Primary sections"
        class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-7 gap-2 sm:gap-3 max-w-4xl mx-auto"
      >
        {primaryNav.map((link) => (
          <a
            href={link.href}
            class="group flex flex-col items-center justify-center gap-2 px-3 py-3 sm:py-4 min-h-[88px] sm:min-h-[100px] bg-bg-card/70 border border-border rounded-xl text-text-muted hover:text-accent hover:border-accent/40 hover:bg-bg-card hover:-translate-y-0.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/60 transition-all"
          >
            <span class="text-text-muted group-hover:text-accent transition-colors [&>svg]:w-7 [&>svg]:h-7 sm:[&>svg]:w-9 sm:[&>svg]:h-9">
              <ModuleIcons name={link.icon} size={36} />
            </span>
            <span class="text-sm font-semibold text-center leading-tight">
              {link.label}
            </span>
          </a>
        ))}
      </nav>
    </div>
  </div>

  <div class="container-main relative z-10 pb-12 md:pb-16">
    <div class="mx-auto max-w-5xl rounded-2xl bg-bg-card/50 border border-border px-4 sm:px-6 py-5 sm:py-6 backdrop-blur">
      <div class="flex items-center justify-between mb-3 px-1">
        <p class="text-[11px] sm:text-xs font-bold tracking-[0.18em] uppercase text-text-muted">
          The course
        </p>
        <p class="text-[11px] sm:text-xs text-text-muted/70 hidden sm:block">
          8 km running · 8 stations · same format worldwide
        </p>
        <p class="text-[11px] text-text-muted/70 sm:hidden">
          1 km run between each
        </p>
      </div>
      <div class="sm:hidden">
        <HyroxCourseRibbon compact />
      </div>
      <div class="hidden sm:block overflow-x-auto -mx-2 px-2">
        <div class="min-w-[820px]">
          <HyroxCourseRibbon />
        </div>
      </div>
    </div>

    <div class="grid grid-cols-3 gap-6 mt-6 md:mt-10 max-w-md mx-auto">
      <div class="text-center">
        <div class="text-3xl font-black text-accent">8</div>
        <div class="text-xs text-text-muted mt-0.5">Stations</div>
      </div>
      <div class="text-center">
        <div class="text-3xl font-black text-accent">8 km</div>
        <div class="text-xs text-text-muted mt-0.5">Running</div>
      </div>
      <div class="text-center">
        <div class="text-3xl font-black text-accent">30+</div>
        <div class="text-xs text-text-muted mt-0.5">Countries</div>
      </div>
    </div>
  </div>
</section>
