---
---

<section class="relative overflow-hidden border-b border-border">
  <div class="absolute inset-0 bg-gradient-to-b from-sky-500/10 via-bg-card/20 to-bg"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_0%,rgba(56,189,248,0.08),transparent)]"></div>

  <div class="container-main relative z-10 py-20 md:py-28 text-center">
    <div class="max-w-3xl mx-auto">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-accent/10 border border-accent/20 rounded-full mb-6">
        <div class="w-2 h-2 bg-accent rounded-full animate-pulse"></div>
        <span class="text-accent text-sm font-medium">The #1 Hyrox Resource Online</span>
      </div>

      <h1 class="text-5xl sm:text-6xl md:text-7xl font-black tracking-tight mb-5 leading-[1.05]">
        <span class="text-text-heading">The Hyrox</span><br />
        <span class="text-gradient-accent">Vault</span>
      </h1>

      <p class="text-xl md:text-2xl text-text-muted mb-10 max-w-2xl mx-auto leading-relaxed">
        Everything you need to race, train, and fuel your best Hyrox — all in one place.
      </p>

      <div class="grid grid-cols-3 sm:grid-cols-6 gap-2 max-w-2xl mx-auto">
        <a href="/racing-guide/what-is-hyrox/" class="flex flex-col items-center gap-1.5 px-2 py-3 bg-bg-card border border-border rounded-xl hover:border-accent/40 hover:bg-accent/5 transition-all group">
          <span class="text-xl">🏁</span>
          <span class="text-xs font-bold text-text-muted group-hover:text-accent transition-colors leading-tight text-center">What is Hyrox?</span>
        </a>
        <a href="/training/" class="flex flex-col items-center gap-1.5 px-2 py-3 bg-bg-card border border-border rounded-xl hover:border-accent/40 hover:bg-accent/5 transition-all group">
          <span class="text-xl">💪</span>
          <span class="text-xs font-bold text-text-muted group-hover:text-accent transition-colors leading-tight text-center">Training</span>
        </a>
        <a href="/supplements/" class="flex flex-col items-center gap-1.5 px-2 py-3 bg-bg-card border border-border rounded-xl hover:border-accent/40 hover:bg-accent/5 transition-all group">
          <span class="text-xl">⚡</span>
          <span class="text-xs font-bold text-text-muted group-hover:text-accent transition-colors leading-tight text-center">Supplements</span>
        </a>
        <a href="/calculator/" class="flex flex-col items-center gap-1.5 px-2 py-3 bg-accent text-bg rounded-xl hover:bg-accent-dim transition-all group">
          <span class="text-xl">⏱️</span>
          <span class="text-xs font-bold leading-tight text-center">Calculator</span>
        </a>
        <a href="/racing-guide/" class="flex flex-col items-center gap-1.5 px-2 py-3 bg-bg-card border border-border rounded-xl hover:border-accent/40 hover:bg-accent/5 transition-all group">
          <span class="text-xl">📋</span>
          <span class="text-xs font-bold text-text-muted group-hover:text-accent transition-colors leading-tight text-center">Race Guide</span>
        </a>
        <a href="/blog/" class="flex flex-col items-center gap-1.5 px-2 py-3 bg-bg-card border border-border rounded-xl hover:border-accent/40 hover:bg-accent/5 transition-all group">
          <span class="text-xl">📝</span>
          <span class="text-xs font-bold text-text-muted group-hover:text-accent transition-colors leading-tight text-center">Blog</span>
        </a>
      </div>
    </div>

    <div class="grid grid-cols-3 gap-6 mt-16 max-w-xs mx-auto">
      <div class="text-center">
        <div class="text-3xl font-black text-accent">8</div>
        <div class="text-xs text-text-muted mt-0.5">Stations</div>
      </div>
      <div class="text-center">
        <div class="text-3xl font-black text-accent">8km</div>
        <div class="text-xs text-text-muted mt-0.5">Running</div>
      </div>
      <div class="text-center">
        <div class="text-3xl font-black text-accent">50+</div>
        <div class="text-xs text-text-muted mt-0.5">Countries</div>
      </div>
    </div>
  </div>
</section>
