<section class="relative overflow-hidden border-b border-border">
  <!-- Lighter gradient background — sky tint at top, fading to site bg -->
  <div class="absolute inset-0 bg-gradient-to-b from-sky-500/10 via-bg-card/20 to-bg"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_0%,rgba(56,189,248,0.08),transparent)]"></div>

  <div class="container-main relative z-10 pt-14 pb-10 text-center">
    <div class="max-w-3xl mx-auto">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-accent/10 border border-accent/20 rounded-full mb-6">
        <div class="w-2 h-2 bg-accent rounded-full animate-pulse"></div>
        <span class="text-accent text-sm font-medium">Free Hyrox Tools & Evidence-Based Guides</span>
      </div>

      <h1 class="text-4xl sm:text-5xl md:text-6xl font-black tracking-tight mb-4 leading-[1.1]">
        <span class="text-text-heading">Predict Your</span><br />
        <span class="text-gradient-accent">Hyrox Finish Time</span>
      </h1>

      <p class="text-lg md:text-xl text-text-muted max-w-xl mx-auto">
        Enter your 5K pace and strength numbers — get a full race split breakdown and know exactly where to focus training.
      </p>
    </div>
  </div>
</section>
