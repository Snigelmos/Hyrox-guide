---
/**
 * StickyTOC
 *
 * Auto-extracts H2/H3 headings from rendered Markdown content and renders
 * a table of contents.
 *
 * Variants:
 * - "aside" (default): the sticky desktop sidebar panel (hidden on <lg).
 * - "mobile": a collapsible <details> panel for narrow screens (hidden on lg+).
 *
 * Both variants can be rendered on the same page; the inline script is
 * deduplicated by Astro and populates every TOC instance from the same
 * article source. If fewer than 3 H2/H3 headings exist, all instances are
 * hidden.
 */

interface Props {
  /** CSS selector for the article content scope. Defaults to "article". */
  scopeSelector?: string;
  /** Optional title shown above the TOC list. */
  title?: string;
  /** Render style. */
  variant?: "aside" | "mobile";
}

const {
  scopeSelector = "article",
  title = "On this page",
  variant = "aside",
} = Astro.props;
---

{variant === "mobile" ? (
  <details
    data-toc-scope={scopeSelector}
    class="lg:hidden mb-6 bg-bg-card/40 border border-border rounded-xl group"
  >
    <summary class="flex items-center justify-between px-5 py-3 cursor-pointer min-h-[44px] text-sm font-semibold text-text-heading select-none">
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7" />
        </svg>
        {title}
      </span>
      <svg class="w-4 h-4 text-text-muted transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </summary>
    <div class="px-5 pb-4 pt-1 border-t border-border/50">
      <ul data-toc-list class="space-y-1.5 text-sm">
        <li class="text-text-muted text-xs italic">Building outline…</li>
      </ul>
    </div>
  </details>
) : (
  <div data-toc-scope={scopeSelector} class="bg-bg-card/40 border border-border rounded-xl p-4 max-h-[calc(100vh-8rem)] overflow-y-auto">
    <p class="text-xs font-bold uppercase tracking-wider text-accent mb-3">{title}</p>
    <ul data-toc-list class="space-y-1.5 text-sm">
      <li class="text-text-muted text-xs italic">Building outline…</li>
    </ul>
  </div>
)}

<script>
  // Build a TOC from the rendered article H2/H3 elements.
  //
  // Astro deduplicates inline component scripts, so this runs once even when
  // both the mobile <details> and desktop <aside> StickyTOC instances are on
  // the page. We then populate every [data-toc-list] UL from the shared
  // article source.
  function buildToc() {
    const wrappers = document.querySelectorAll<HTMLElement>("[data-toc-scope]");
    if (wrappers.length === 0) return;
    const scopeSel = wrappers[0].getAttribute("data-toc-scope") ?? "article";
    const article = document.querySelector(scopeSel);
    const lists = document.querySelectorAll<HTMLUListElement>("[data-toc-list]");
    if (!article || lists.length === 0) return;

    const headings = Array.from(
      article.querySelectorAll<HTMLHeadingElement>("h2, h3"),
    );

    if (headings.length < 3) {
      wrappers.forEach((w) => w.classList.add("hidden"));
      return;
    }

    function buildItems() {
      const frag = document.createDocumentFragment();
      headings.forEach((h) => {
        const id = h.id;
        if (!id) return;
        const li = document.createElement("li");
        li.className = h.tagName === "H3" ? "pl-3" : "";
        const a = document.createElement("a");
        a.href = `#${id}`;
        a.textContent = h.textContent ?? "";
        a.className =
          "block text-text-muted hover:text-accent transition-colors no-underline leading-tight py-0.5";
        a.dataset.tocLink = id;
        li.appendChild(a);
        frag.appendChild(li);
      });
      return frag;
    }

    lists.forEach((list) => {
      list.innerHTML = "";
      list.appendChild(buildItems());
    });

    // Active-section tracking. Highlight the heading currently in view by
    // toggling text-accent on every matching anchor across all TOC instances.
    const observer = new IntersectionObserver(
      (entries) => {
        const intersecting = entries.filter((e) => e.isIntersecting);
        if (intersecting.length === 0) return;
        const top = intersecting.sort(
          (a, b) => a.boundingClientRect.top - b.boundingClientRect.top,
        )[0];
        const id = (top.target as HTMLElement).id;
        document
          .querySelectorAll<HTMLAnchorElement>("[data-toc-link]")
          .forEach((a) => {
            a.classList.toggle("text-accent", a.dataset.tocLink === id);
            a.classList.toggle("font-semibold", a.dataset.tocLink === id);
          });
      },
      { rootMargin: "0px 0px -80% 0px" },
    );
    headings.forEach((h) => observer.observe(h));
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", buildToc);
  } else {
    buildToc();
  }
</script>
