---
import StationIcons from "./icons/StationIcons.astro";

interface Session {
  day: string;
  type: "run" | "gym" | "rest" | "race-sim" | "combo";
  title: string;
  highlights?: string[];
  stations?: string[];
}

interface Props {
  weekNumber: number;
  focus: string;
  sessions: Session[];
}

const { weekNumber, focus, sessions } = Astro.props;

const typeConfig: Record<string, { color: string; bg: string; label: string }> = {
  run: { color: "text-sky-400", bg: "bg-sky-400/10", label: "Run" },
  gym: { color: "text-amber-400", bg: "bg-amber-400/10", label: "Gym" },
  rest: { color: "text-zinc-500", bg: "bg-zinc-500/10", label: "Rest" },
  "race-sim": { color: "text-rose-400", bg: "bg-rose-400/10", label: "Race Sim" },
  combo: { color: "text-violet-400", bg: "bg-violet-400/10", label: "Run + Gym" },
};
---

<div class="not-prose my-8 bg-bg-card border border-border rounded-2xl overflow-hidden">
  <div class="px-4 sm:px-6 py-4 border-b border-border flex items-center justify-between gap-3">
    <div class="min-w-0">
      <span class="text-xs font-bold text-accent uppercase tracking-wider">Week {weekNumber}</span>
      <h3 class="text-base sm:text-lg font-bold text-text-heading mt-0.5 truncate">{focus}</h3>
    </div>
    <div class="text-xs text-text-muted whitespace-nowrap flex-shrink-0">{sessions.filter(s => s.type !== "rest").length} sessions</div>
  </div>

  <div class="divide-y divide-border/50">
    {sessions.map((session) => {
      const config = typeConfig[session.type] ?? typeConfig.gym;
      return (
        <div class="px-4 sm:px-6 py-4 flex items-start gap-3 sm:gap-4">
          <div class="flex-shrink-0 w-11 sm:w-14 text-center">
            <div class="text-[10px] sm:text-xs font-bold text-text-muted uppercase">{session.day}</div>
            <span class={`inline-block mt-1 text-[10px] sm:text-xs font-bold uppercase tracking-wider px-1.5 sm:px-2 py-0.5 rounded-full ${config.color} ${config.bg}`}>
              {config.label}
            </span>
          </div>

          <div class="flex-1 min-w-0">
            <div class="font-semibold text-sm text-text-heading leading-snug">{session.title}</div>
            {session.highlights && session.highlights.length > 0 && (
              <ul class="mt-1.5 space-y-0.5">
                {session.highlights.map((h) => (
                  <li class="text-xs text-text-muted flex items-start gap-1.5 leading-snug">
                    <span class="text-accent/50 mt-0.5 flex-shrink-0">›</span>
                    <span class="min-w-0">{h}</span>
                  </li>
                ))}
              </ul>
            )}
          </div>

          {session.stations && session.stations.length > 0 && (
            <div class="hidden md:flex items-center gap-1 flex-shrink-0">
              {session.stations.map((st) => (
                <div class="text-accent/40" title={st}>
                  <StationIcons station={st} size={28} />
                </div>
              ))}
            </div>
          )}
        </div>
      );
    })}
  </div>
</div>
