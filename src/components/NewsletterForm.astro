---
interface Props {
  heading?: string;
  subtext?: string;
}

const {
  heading = "Get Hyrox Tips in Your Inbox",
  subtext = "Weekly training tips, gear deals, and race updates. No spam, unsubscribe anytime.",
} = Astro.props;
---

<section class="bg-bg-card border border-border rounded-2xl p-8 md:p-12 text-center">
  <h2 class="text-2xl md:text-3xl font-black text-text-heading mb-3">{heading}</h2>
  <p class="text-text-muted mb-8 max-w-md mx-auto">{subtext}</p>
  <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto" onsubmit="return false;">
    <input
      type="email"
      placeholder="your@email.com"
      required
      class="flex-1 px-5 py-3 bg-bg border border-border rounded-xl text-text placeholder:text-text-muted focus:outline-none focus:border-accent transition-colors"
    />
    <button
      type="submit"
      class="px-6 py-3 bg-accent text-bg font-bold rounded-xl hover:bg-accent-dim hover:glow-accent transition-all"
    >
      Subscribe
    </button>
  </form>
</section>
