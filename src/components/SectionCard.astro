---
interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
  accent?: boolean;
}

const { title, description, href, icon, accent = false } = Astro.props;
---

<a
  href={href}
  class:list={[
    "group block p-8 rounded-2xl border transition-all duration-300 hover:-translate-y-1",
    accent
      ? "bg-accent/5 border-accent/20 hover:border-accent/50 hover:glow-accent"
      : "bg-bg-card border-border hover:border-border-hover hover:bg-bg-card-hover",
  ]}
>
  <div class="text-4xl mb-4">{icon}</div>
  <h3 class="text-xl font-bold text-text-heading mb-2 group-hover:text-accent transition-colors">
    {title}
  </h3>
  <p class="text-text-muted text-sm leading-relaxed">{description}</p>
  <div class="mt-4 flex items-center gap-1 text-sm font-medium text-accent opacity-0 group-hover:opacity-100 transition-opacity">
    Explore
    <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </div>
</a>
