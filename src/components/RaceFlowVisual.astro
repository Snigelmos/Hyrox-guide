---
import StationIcons from "./icons/StationIcons.astro";

const stations = [
  { id: "skierg", name: "SkiErg", metric: "1,000m" },
  { id: "sled-push", name: "Sled Push", metric: "50m" },
  { id: "sled-pull", name: "Sled Pull", metric: "50m" },
  { id: "burpee-broad-jump", name: "Burpee Broad Jumps", metric: "80m" },
  { id: "rowing", name: "Rowing", metric: "1,000m" },
  { id: "farmers-carry", name: "Farmers Carry", metric: "200m" },
  { id: "sandbag-lunges", name: "Sandbag Lunges", metric: "100m" },
  { id: "wall-balls", name: "Wall Balls", metric: "75–100 reps" },
];
---

<div class="not-prose my-10">
  <div class="bg-bg-card border border-border rounded-2xl p-6 md:p-8">
    <h3 class="text-lg font-bold text-text-heading mb-6 text-center">The Full Race Flow</h3>
    <div class="space-y-2">
      {stations.map((station, i) => (
        <div>
          <div class="flex items-center gap-3 px-4 py-3 rounded-xl bg-accent/[0.03] border border-transparent hover:border-accent/10 transition-colors">
            <div class="flex-shrink-0 w-6 text-center">
              <span class="text-xs font-black text-accent">{i + 1}</span>
            </div>
            <div class="flex-shrink-0 text-accent/60 hidden sm:block">
              <StationIcons station={station.id} size={36} />
            </div>
            <div class="flex-1 min-w-0">
              <span class="font-semibold text-sm text-text-heading">{station.name}</span>
              <span class="text-xs text-text-muted ml-2">{station.metric}</span>
            </div>
          </div>
          {i < stations.length - 1 && (
            <div class="flex items-center gap-3 px-4 py-1.5 ml-3">
              <div class="flex-shrink-0 w-6 text-center">
                <svg class="w-3 h-3 mx-auto text-text-muted/30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
                </svg>
              </div>
              <div class="flex-shrink-0 hidden sm:block w-9"></div>
              <span class="text-xs text-text-muted/50 font-medium flex items-center gap-1.5">
                <StationIcons station="running" size={16} class="opacity-40" />
                1km Run
              </span>
            </div>
          )}
        </div>
      ))}
    </div>
    <div class="mt-6 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-accent/10 text-accent text-sm font-bold rounded-full">
        🏁 Finish Line
      </div>
    </div>
  </div>
</div>
