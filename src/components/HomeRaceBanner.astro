---
/**
 * Homepage race banner.
 *
 * Drop-in strip rendered between the Hero and "What is Hyrox" sections on
 * the landing page. Captures the predictable spike in race-day and
 * race-week search traffic (Helsinki gave us the proof on the day this
 * was built — Finnish "hyrox helsinki aikataulu" / "hyrox finland live
 * results" queries surged) by surfacing the next-up race(s) front and
 * centre on the homepage.
 *
 * Display logic:
 *
 *   1. If any event is on the floor right now (start <= today <= end),
 *      that's the featured race — emerald-styled "Race live now" hero
 *      with primary CTAs to /live/ and the city event page.
 *   2. Else, if any event starts within the next 14 days, the nearest
 *      one is featured — accent-styled "Race week" hero with countdown
 *      ("3 days to go") and CTAs to the city event page.
 *   3. All other events within the 14-day window become a secondary
 *      "Also racing" chip rail underneath the featured card.
 *   4. If absolutely nothing is happening within 14 days, the component
 *      renders nothing so the homepage falls back cleanly to the Hero
 *      → "What is Hyrox" flow.
 */

import {
  getActiveEventsOn,
  getUpcomingEvents,
  daysUntilEvent,
  liveEventDayLabel,
} from "../lib/hyrox-live";
import { formatEventDate, type HyroxEvent } from "../data/events";

const now = new Date();

// Live now (any race whose date span includes today). Sorted by start
// ascending so multi-day races that started earlier come first.
const liveEvents = getActiveEventsOn(now).sort((a, b) =>
  a.startDate.localeCompare(b.startDate),
);

// Future races starting in the next 14 days, ascending. Excludes
// anything currently live (those are in `liveEvents`).
const upcoming14 = getUpcomingEvents(now, 14);

const allActiveOrUpcoming: HyroxEvent[] = [...liveEvents, ...upcoming14];

const featured: HyroxEvent | undefined = allActiveOrUpcoming[0];
const secondary: HyroxEvent[] = allActiveOrUpcoming.slice(1);

if (!featured) return null;

const featuredIsLive = liveEvents.includes(featured);
const featuredDays = daysUntilEvent(featured, now);
const featuredDayLabel = featuredIsLive ? liveEventDayLabel(featured, now) : null;

// Headline status pill copy
const statusLabel = featuredIsLive
  ? "Race live now"
  : featuredDays === 0
    ? "Race day"
    : featuredDays === 1
      ? "1 day to go"
      : `${featuredDays} days to go`;

const featuredHref = `/events/${featured.year}/${featured.slug}/`;
---

<section
  class="relative isolate border-b border-border overflow-hidden"
  aria-label="Upcoming Hyrox races"
>
  <!-- Backdrop: emerald glow if a race is live, accent glow otherwise -->
  <div
    class={`absolute inset-0 -z-10 ${
      featuredIsLive
        ? "bg-gradient-to-b from-emerald-500/10 via-bg-card/30 to-bg-card/10"
        : "bg-gradient-to-b from-accent/10 via-bg-card/30 to-bg-card/10"
    }`}
  />

  <div class="container-main py-6 md:py-8">
    <!-- Featured race card -->
    <a
      href={featuredHref}
      class={`group relative flex flex-col md:flex-row md:items-center gap-4 md:gap-6 p-5 md:p-6 rounded-2xl border no-underline transition-all hover:-translate-y-0.5 ${
        featuredIsLive
          ? "bg-emerald-500/5 border-emerald-500/30 hover:border-emerald-500/50"
          : "bg-accent/5 border-accent/30 hover:border-accent/50"
      }`}
    >
      <!-- Status block -->
      <div class="flex flex-col gap-1.5 md:min-w-[10rem]">
        <span
          class={`inline-flex items-center gap-2 self-start rounded-full px-3 py-1 text-xs font-bold uppercase tracking-wider ${
            featuredIsLive
              ? "bg-emerald-500/15 border border-emerald-500/40 text-emerald-400"
              : "bg-accent/15 border border-accent/40 text-accent"
          }`}
        >
          {featuredIsLive && <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse" />}
          {statusLabel}
        </span>
        <span class="text-xs text-text-muted">
          {featuredIsLive && featuredDayLabel
            ? `${featuredDayLabel} · ${formatEventDate(featured.startDate, featured.endDate)}`
            : formatEventDate(featured.startDate, featured.endDate)}
        </span>
      </div>

      <!-- Headline + venue -->
      <div class="flex-1 min-w-0">
        <h2 class="text-xl md:text-2xl font-black text-text-heading leading-tight mb-1 group-hover:text-accent transition-colors">
          {featuredIsLive
            ? `Hyrox ${featured.city} ${featured.year} is live now`
            : `Hyrox ${featured.city} ${featured.year}`}
        </h2>
        <p class="text-sm text-text-muted leading-relaxed mb-0">
          {featured.venue}, {featured.country}
          {featuredIsLive
            ? " · splits landing on the official portal in real time."
            : featured.populationDescriptor
              ? ` · ${featured.populationDescriptor}`
              : ""}
        </p>
      </div>

      <!-- CTAs (the whole card is clickable; these are visual cues) -->
      <div class="flex flex-wrap items-center gap-2 md:gap-3 md:flex-shrink-0">
        {featuredIsLive && (
          <span
            class="hidden sm:inline-flex items-center gap-1.5 bg-bg-card border border-border rounded-xl px-3 py-2 text-xs font-bold uppercase tracking-wider text-text"
          >
            Track an athlete →
          </span>
        )}
        <span
          class={`inline-flex items-center gap-1.5 rounded-xl px-4 py-2 text-sm font-bold transition-colors ${
            featuredIsLive
              ? "bg-emerald-500 text-white group-hover:bg-emerald-400"
              : "bg-accent text-bg group-hover:bg-accent/90"
          }`}
        >
          {featuredIsLive ? "Open race page" : "View details"}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </span>
      </div>
    </a>

    {featuredIsLive && (
      <!-- Live-tracker handoff: only when something is actually live, this
           is the one extra CTA that's worth a duplicate (the featured card
           already deep-links to the city page, which is where the embedded
           tracker lives, but a direct /live/ shortcut catches the
           "I just want the tracker" intent). -->
      <div class="mt-3 text-center md:text-left">
        <a
          href="/live/"
          class="inline-flex items-center gap-1.5 text-xs font-bold uppercase tracking-wider text-emerald-400 hover:text-emerald-300 no-underline"
        >
          Or open the live-tracker hub →
        </a>
      </div>
    )}

    {secondary.length > 0 && (
      <!-- Chip rail: every other race in the 14-day window. Each chip is
           a deep link into the city page, where the race-week panel
           takes over. -->
      <div class="mt-5 md:mt-6">
        <div class="flex items-baseline justify-between flex-wrap gap-2 mb-3">
          <span class="text-xs font-bold uppercase tracking-wider text-text-muted">
            Also racing in the next 2 weeks
          </span>
          <a
            href="/events/2026/"
            class="text-xs font-bold uppercase tracking-wider text-accent hover:underline no-underline"
          >
            Full {now.getFullYear()} calendar →
          </a>
        </div>
        <div class="flex flex-wrap gap-2">
          {secondary.map((event) => {
            const isLive = liveEvents.includes(event);
            const days = daysUntilEvent(event, now);
            const chipLabel = isLive
              ? "LIVE"
              : days === 0
                ? "Today"
                : days === 1
                  ? "Tomorrow"
                  : `+${days}d`;
            return (
              <a
                href={`/events/${event.year}/${event.slug}/`}
                class={`inline-flex items-center gap-2 rounded-full px-3 py-1.5 text-sm border transition-colors no-underline ${
                  isLive
                    ? "bg-emerald-500/10 border-emerald-500/30 text-emerald-400 hover:bg-emerald-500/15"
                    : "bg-bg-card border-border text-text hover:border-accent/40 hover:text-accent"
                }`}
              >
                <span class={`text-xs font-bold uppercase tracking-wider ${isLive ? "" : "text-text-muted"}`}>
                  {chipLabel}
                </span>
                <span class="font-bold">{event.city}</span>
                <span class="text-xs text-text-muted hidden sm:inline">
                  {formatEventDate(event.startDate, event.endDate)}
                </span>
              </a>
            );
          })}
        </div>
      </div>
    )}
  </div>
</section>
